@model MedicalOnboardingApplication.Models.Question

@{
    ViewData["Title"] = "Delete Question";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm border-danger">
            <div class="card-body">

                <h4 class="text-danger mb-3">
                    <i class="bi bi-exclamation-triangle"></i>
                    Delete Question
                </h4>

                <p>
                    Are you sure you want to delete this question?
                </p>

                <blockquote class="blockquote bg-light p-3 rounded">
                    @Model.Text
                </blockquote>

                <p class="text-muted">
                    This will permanently remove the question and all its answers.
                </p>

                <form asp-action="Delete" method="post">
                    @Html.AntiForgeryToken()

                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="CourseId" />

                    <div class="d-flex justify-content-between mt-4">
                        <a asp-controller="AdminCourses"
                           asp-action="Manage"
                           asp-route-id="@Model.CourseId"
                           class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Cancel
                        </a>

                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash"></i> Delete Question
                        </button>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

@model EditQuestionViewModel

@{
    ViewData["Title"] = "Edit Question";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Edit Question</h1>
    <a asp-controller="Tests"
       asp-action="Details"
       asp-route-id="@Model.TestId"
       class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Back to Test
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="TestId" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <!-- Question Text -->
                    <div class="mb-4">
                        <label asp-for="QuestionText" class="form-label">Question</label>
                        <input asp-for="QuestionText" class="form-control" placeholder="Enter the question" />
                        <span asp-validation-for="QuestionText" class="text-danger"></span>
                    </div>

                    <!-- Answers -->
                    <h5>Answers</h5>
                    @for (int i = 0; i < 4; i++)
                    {
                        <div class="mb-2 d-flex align-items-center">
                            <input type="radio"
                                   name="CorrectAnswerIndex"
                                   value="@i"
                                   class="form-check-input me-2"
                                   @(Model.CorrectAnswerIndex == i ? "checked" : "") />

                            <input name="Answers[@i]"
                                   value="@Model.Answers[i]"
                                   class="form-control"
                                   placeholder="Answer @(i + 1)" />
                        </div>
                    }

                    <div class="d-flex justify-content-end mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save-fill"></i> Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

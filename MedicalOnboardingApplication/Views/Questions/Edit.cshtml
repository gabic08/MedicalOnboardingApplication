@using MedicalOnboardingApplication.Data
@model MedicalOnboardingApplication.Models.EditQuestionViewModel

@{
    ViewData["Title"] = "Edit Question";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Edit Question</h1>

    <a asp-controller="AdminCourses"
       asp-action="Manage"
       asp-route-id="@Model.CourseId"
       class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Back to Course
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body">

                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()

                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="CourseId" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <!-- Question Text -->
                    <div class="mb-3">
                        <label asp-for="QuestionText" class="form-label">Question</label>
                        <textarea asp-for="QuestionText"
                                  class="form-control"
                                  rows="3"></textarea>
                        <span asp-validation-for="QuestionText" class="text-danger"></span>
                    </div>

                    <!-- Difficulty -->
                    <div class="mb-4">
                        <label asp-for="Difficulty" class="form-label">Difficulty</label>
                        <select asp-for="Difficulty"
                                asp-items="Html.GetEnumSelectList<QuestionDifficulty>()"
                                class="form-select">
                        </select>
                    </div>

                    <!-- Answers -->
                    <h5 class="mb-2">Answers</h5>
                    <p class="text-muted small">
                        Select exactly one correct answer. Minimum 2 answers required.
                    </p>

                    <div id="answersContainer">
                        @for (int i = 0; i < Model.Answers.Count; i++)
                        {
                            <div class="input-group mb-2 align-items-center">
                                <span class="input-group-text">
                                    <input type="radio"
                                           name="CorrectAnswerIndex"
                                           value="@i"
                                           @(Model.CorrectAnswerIndex == i ? "checked" : "") />
                                </span>

                                <input type="hidden" name="Answers[@i].Id" value="@Model.Answers[i].Id" />

                                <input type="text"
                                       name="Answers[@i].Text"
                                       value="@Model.Answers[i].Text"
                                       class="form-control"
                                       placeholder="Answer text" />

                                <button type="button"
                                        class="btn btn-outline-danger"
                                        onclick="removeAnswer(this)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        }
                    </div>

                    <button type="button"
                            class="btn btn-outline-primary btn-sm mt-2"
                            onclick="addAnswer()">
                        <i class="bi bi-plus-circle"></i> Add Answer
                    </button>

                    <div class="d-flex justify-content-end mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save"></i> Save Changes
                        </button>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function addAnswer() {
            const container = document.getElementById("answersContainer");
            const index = container.children.length;

            const html = `
                <div class="input-group mb-2 align-items-center">
                    <span class="input-group-text">
                        <input type="radio" name="CorrectAnswerIndex" value="${index}">
                    </span>

                    <input type="hidden" name="Answers[${index}].Id" value="0" />

                    <input type="text"
                           name="Answers[${index}].Text"
                           class="form-control"
                           placeholder="Answer text" />

                    <button type="button"
                            class="btn btn-outline-danger"
                            onclick="removeAnswer(this)">
                        <i class="bi bi-trash"></i>
                    </button>
                </div>
            `;

            container.insertAdjacentHTML("beforeend", html);
        }

        function removeAnswer(button) {
            const row = button.closest(".input-group");
            row.remove();
        }
    </script>
}

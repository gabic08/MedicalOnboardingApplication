@using MedicalOnboardingApplication.Data
@using MedicalOnboardingApplication.ViewModels
@model CreateQuestionViewModel

@{
    ViewData["Title"] = "Adaugă Întrebare";
}

<div class="mb-4">
    <a asp-controller="AdminCourses"
       asp-action="Manage"
       asp-route-id="@Model.CourseId"
       class="btn btn-outline-secondary mb-2">
        <i class="bi bi-arrow-left"></i> Înapoi la Curs
    </a>
    <h1 class="mb-0">Adaugă Întrebare</h1>
</div>

<div class="row">
    <div class="col-12 col-lg-10 mx-auto">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="CourseId" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <!-- Question -->
            <div class="card shadow-sm mb-3">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase fw-semibold mb-3">
                        <i class="bi bi-question-circle me-1"></i> Întrebare
                    </h6>
                    <textarea asp-for="QuestionText"
                              class="form-control"
                              rows="3"
                              placeholder="Introdu întrebarea..."></textarea>
                    <span asp-validation-for="QuestionText" class="text-danger"></span>
                </div>
            </div>

            <!-- Difficulty -->
            <div class="card shadow-sm mb-3">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase fw-semibold mb-3">
                        <i class="bi bi-bar-chart me-1"></i> Dificultate
                    </h6>
                    <select asp-for="Difficulty"
                            asp-items="Html.GetEnumSelectList<QuestionDifficulty>()"
                            class="form-select">
                    </select>
                </div>
            </div>

            <!-- Answers -->
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase fw-semibold mb-1">
                        <i class="bi bi-list-check me-1"></i> Răspunsuri
                    </h6>
                    <small class="text-muted d-block mb-3">
                        Selectează butonul radio de lângă răspunsul corect.
                        Sunt necesare minimum 2 răspunsuri.
                    </small>

                    <div id="answers-container">
                        @for (int i = 0; i < Model.Answers.Count; i++)
                        {
                            <div class="d-flex align-items-center mb-2 gap-2 answer-row">
                                <div class="form-check mb-0">
                                    <input type="radio"
                                           name="CorrectAnswerIndex"
                                           value="@i"
                                           class="form-check-input"
                                           title="Marchează ca corect"
                                           @(Model.CorrectAnswerIndex == i ? "checked" : "") />
                                </div>
                                <input name="Answers[@i]"
                                       value="@Model.Answers[i]"
                                       class="form-control"
                                       placeholder="Răspuns @(i + 1)" />
                                <button type="button"
                                        class="btn btn-outline-danger btn-sm remove-answer-btn"
                                        title="Șterge">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        }
                    </div>

                    <button type="button"
                            id="add-answer-btn"
                            class="btn btn-outline-secondary btn-sm mt-2">
                        <i class="bi bi-plus-circle"></i> Adaugă Răspuns
                    </button>
                </div>
            </div>

            <div class="d-flex justify-content-end">
                <button type="submit" class="btn btn-primary px-4">
                    <i class="bi bi-save"></i> Salvează Întrebarea
                </button>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.getElementById("add-answer-btn").addEventListener("click", function () {
            const container = document.getElementById("answers-container");
            const index = container.children.length;

            const row = document.createElement("div");
            row.className = "d-flex align-items-center mb-2 gap-2 answer-row";

            row.innerHTML = `
                <div class="form-check mb-0">
                    <input type="radio"
                           name="CorrectAnswerIndex"
                           value="${index}"
                           class="form-check-input"
                           title="Marchează ca corect" />
                </div>
                <input name="Answers[${index}]"
                       class="form-control"
                       placeholder="Răspuns ${index + 1}" />
                <button type="button"
                        class="btn btn-outline-danger btn-sm remove-answer-btn"
                        title="Șterge">
                    <i class="bi bi-trash"></i>
                </button>
            `;

            container.appendChild(row);
            attachRemoveHandler(row.querySelector('.remove-answer-btn'));
        });

        function attachRemoveHandler(btn) {
            btn.addEventListener("click", function () {
                this.closest(".answer-row").remove();
                reindexAnswers();
            });
        }

        function reindexAnswers() {
            const rows = document.querySelectorAll(".answer-row");
            rows.forEach((row, i) => {
                row.querySelector("input[type='radio']").value = i;
                row.querySelector("input[type='text'], input:not([type='radio'])")
                   .setAttribute("name", `Answers[${i}]`);
                row.querySelector("input:not([type='radio'])")
                   .setAttribute("placeholder", `Răspuns ${i + 1}`);
            });
        }

        document.querySelectorAll(".remove-answer-btn").forEach(btn => {
            attachRemoveHandler(btn);
        });
    </script>
}

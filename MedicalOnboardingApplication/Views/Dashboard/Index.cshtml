@{
    ViewData["Title"] = "Panou Principal";
    bool isWorkingNow = ViewBag.IsWorkingNow ?? true;
    string nextShiftInfo = ViewBag.NextShiftInfo ?? "";
}

<div class="rm-dashboard-wrap">

    <!-- Welcome -->
    <div class="rm-dashboard-hero">
        <h1 class="rm-dashboard-title">Bine ai revenit!</h1>
        <p class="rm-dashboard-subtitle">Continuă procesul de integrare de unde ai rămas</p>
    </div>

    <!-- Out of hours notice -->
    @if (!isWorkingNow)
    {
        <div class="rm-dashboard-notice">
            <div class="rm-dashboard-notice-icon">
                <i class="bi bi-clock-history"></i>
            </div>
            <div>
                <strong>În afara orelor de lucru.</strong>
                Cursurile și testele sunt disponibile doar în timpul programului tău.
                @if (!string.IsNullOrEmpty(nextShiftInfo))
                {
                    <span style="margin-left:4px;">@nextShiftInfo</span>
                }
            </div>
        </div>
    }

    <!-- Cards -->
    <div class="rm-dashboard-cards">

        <!-- Courses -->
        @if (isWorkingNow)
        {
            <a asp-controller="Courses" asp-action="Index" class="rm-dash-card">
                <div class="rm-dash-card-stripe" style="background:var(--rm-red);"></div>
                <div class="rm-dash-card-body">
                    <div class="rm-dash-card-icon icon-red">
                        <i class="bi bi-journal-text"></i>
                    </div>
                    <h3 class="rm-dash-card-title">Cursuri</h3>
                    <p class="rm-dash-card-desc">
                        Explorează și finalizează cursurile de integrare atribuite ție.
                    </p>
                    <div class="rm-dash-card-cta">
                        Vezi Cursurile <i class="bi bi-arrow-right"></i>
                    </div>
                </div>
            </a>
        }
        else
        {
            <div class="rm-dash-card rm-dash-card--disabled">
                <div class="rm-dash-card-stripe" style="background:#e5e7eb;"></div>
                <div class="rm-dash-card-body">
                    <div class="rm-dash-card-icon" style="background:#f5f5f5;color:#bbb;">
                        <i class="bi bi-journal-text"></i>
                    </div>
                    <h3 class="rm-dash-card-title" style="color:#bbb;">Cursuri</h3>
                    <p class="rm-dash-card-desc">
                        Explorează și finalizează cursurile de integrare atribuite ție.
                    </p>
                    <div class="rm-dash-card-cta rm-dash-card-cta--locked">
                        <i class="bi bi-lock"></i> Indisponibil
                    </div>
                </div>
            </div>
        }

        <!-- Tests -->
        @if (isWorkingNow)
        {
            <a asp-controller="Tests" asp-action="Index" class="rm-dash-card">
                <div class="rm-dash-card-stripe" style="background:#f59e0b;"></div>
                <div class="rm-dash-card-body">
                    <div class="rm-dash-card-icon" style="background:#fef9c3;color:#ca8a04;">
                        <i class="bi bi-patch-question"></i>
                    </div>
                    <h3 class="rm-dash-card-title">Teste</h3>
                    <p class="rm-dash-card-desc">
                        Susține teste adaptive pentru a-ți evalua cunoștințele și a urmări progresul.
                    </p>
                    <div class="rm-dash-card-cta" style="background:#fef9c3;color:#ca8a04;">
                        Vezi Testele <i class="bi bi-arrow-right"></i>
                    </div>
                </div>
            </a>
        }
        else
        {
            <div class="rm-dash-card rm-dash-card--disabled">
                <div class="rm-dash-card-stripe" style="background:#e5e7eb;"></div>
                <div class="rm-dash-card-body">
                    <div class="rm-dash-card-icon" style="background:#f5f5f5;color:#bbb;">
                        <i class="bi bi-patch-question"></i>
                    </div>
                    <h3 class="rm-dash-card-title" style="color:#bbb;">Teste</h3>
                    <p class="rm-dash-card-desc">
                        Susține teste adaptive pentru a-ți evalua cunoștințele și a urmări progresul.
                    </p>
                    <div class="rm-dash-card-cta rm-dash-card-cta--locked">
                        <i class="bi bi-lock"></i> Indisponibil
                    </div>
                </div>
            </div>
        }

    </div>
</div>
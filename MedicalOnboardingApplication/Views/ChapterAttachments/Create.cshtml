@{
    ViewData["Title"] = "Add Attachment";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Add Attachment</h1>
    <a asp-controller="AdminCourses"
       asp-action="Manage"
       asp-route-id="@ViewBag.CourseId"
       class="btn btn-outline-secondary">
        Back
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm">
            <div class="card-body p-4">

                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()

                    <input type="hidden" name="chapterId" value="@ViewBag.ChapterId" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label class="form-label">File</label>
                        <input type="file"
                               name="file"
                               class="form-control"
                               accept=".jpg,.jpeg,.png,.gif,.webp,.mp4,.webm,.mov,.pdf"
                               required />
                        <div class="form-text">
                            Allowed: Images, Videos, PDFs
                        </div>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-controller="AdminCourses"
                           asp-action="Manage"
                           asp-route-id="@ViewBag.CourseId"
                           class="btn btn-outline-secondary">
                            Cancel
                        </a>

                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-upload"></i> Upload File
                        </button>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

@model MedicalOnboardingApplication.Models.Test

@{
    ViewData["Title"] = "Test Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">@Model.Title</h1>
    <a asp-controller="Courses"
       asp-action="Details"
       asp-route-id="@Model.CourseId"
       class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Back to Course
    </a>
</div>

<!-- Test Info Card -->
<div class="card mb-4 shadow-sm">
    <div class="card-body">
        <h5 class="card-title">@Model.Title</h5>
        <p><strong>Course ID:</strong> @Model.CourseId</p>
    </div>
</div>

<!-- Questions Section -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>Questions</h4>
    <a asp-controller="Questions"
       asp-action="Create"
       asp-route-testId="@Model.Id"
       class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Add Question
    </a>
</div>

@if (Model.Questions == null || !Model.Questions.Any())
{
    <div class="alert alert-info">
        No questions have been added to this test yet.
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 g-4">
        @foreach (var question in Model.Questions)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h5 class="card-title mb-0">@question.Text</h5>
                            <div>
                                <a asp-controller="Questions"
                                   asp-action="Edit"
                                   asp-route-id="@question.Id"
                                   class="btn btn-sm btn-outline-secondary me-1">
                                    Edit
                                </a>
                                <a asp-controller="Questions"
                                   asp-action="Delete"
                                   asp-route-id="@question.Id"
                                   class="btn btn-sm btn-outline-danger">
                                    Delete
                                </a>
                            </div>
                        </div>
                        <hr />
                        <ul class="mb-0">
                            @foreach (var answer in question.Answers)
                            {
                                <li>
                                    @answer.Text
                                    @if (answer.IsCorrect)
                                    {
                                        <strong class="text-success"> (Correct)</strong>
                                    }
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        }
    </div>
}

<div class="mt-4">
    <a asp-controller="Courses"
       asp-action="Details"
       asp-route-id="@Model.CourseId"
       class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Back to Course
    </a>
</div>

@model MedicalOnboardingApplication.Models.Test

@{
    ViewData["Title"] = "Delete Test";
}

<div class="container">
    <div class="card shadow-sm border-danger">
        <div class="card-body">
            <h4 class="text-danger">Delete Test</h4>
            <p>
                Are you sure you want to delete this test?
                <strong>@Model.Title</strong>
            </p>

            <p class="text-muted">
                This will also delete all questions and answers in this test.
            </p>

            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <div class="d-flex justify-content-between">
                    <a asp-controller="AdminCourses"
                       asp-action="Details"
                       asp-route-id="@Model.CourseId"
                       class="btn btn-outline-secondary">
                        Cancel
                    </a>

                    <button type="submit" class="btn btn-danger">
                        Delete Test
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

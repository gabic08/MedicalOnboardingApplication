@model MedicalOnboardingApplication.Models.Test

@{
    ViewData["Title"] = "Create Test";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Create Test</h1>
    <a asp-controller="AdminCourses"
       asp-action="Manage"
       asp-route-id="@Model.CourseId"
       class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Back to Course
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm">
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="CourseId" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">Test Title</label>
                        <input asp-for="Title" class="form-control" placeholder="Enter test title" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="d-flex justify-content-end mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save-fill"></i> Save Test
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

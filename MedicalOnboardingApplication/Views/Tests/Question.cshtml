@model MedicalOnboardingApplication.Models.TestSessionQuestion
@{
    ViewData["Title"] = "Întrebare";
    var answeredCount = ViewBag.AnsweredCount as int? ?? 0;
    var totalQuestions = ViewBag.TotalQuestions as int? ?? 15;
    var progress = ViewBag.Progress as int? ?? 0;
    var currentDifficulty = ViewBag.CurrentDifficulty as int? ?? 1;
    var sessionId = ViewBag.SessionId as int? ?? 0;

    var diffLabel = (int diff) => diff switch
    {
        1 => ("bg-success", "1 - Foarte Ușor"),
        2 => ("bg-primary", "2 - Ușor"),
        3 => ("bg-warning text-dark", "3 - Mediu"),
        4 => ("bg-danger bg-opacity-75", "4 - Dificil"),
        5 => ("bg-danger", "5 - Foarte Dificil"),
        _ => ("bg-secondary", diff.ToString())
    };

    var showFeedback = ViewBag.ShowFeedback as bool? ?? false;
    var isCorrect = ViewBag.IsCorrect as bool? ?? false;
    var correctAnswerId = ViewBag.CorrectAnswerId as int? ?? 0;
    var selectedAnswerId = ViewBag.SelectedAnswerId as int? ?? 0;
    var windowAvg = ViewBag.WindowAvg as double?;
    var lastWindow = ViewBag.LastWindow as List<double> ?? new List<double>();
    var windowSize = ViewBag.WindowSize as int? ?? 3;
    var increaseThreshold = ViewBag.IncreaseThreshold as double? ?? 0.8;
    var decreaseThreshold = ViewBag.DecreaseThreshold as double? ?? 0.5;
    var isLastQuestion = ViewBag.IsLastQuestion as bool? ?? false;
    var nextDifficulty = ViewBag.NextDifficulty as int? ?? currentDifficulty;
}

<!-- Progress -->
<div class="mb-4">
    <div class="d-flex justify-content-between align-items-center mb-1">
        <small class="text-muted">Întrebarea @(answeredCount + (showFeedback ? 0 : 1)) din @totalQuestions</small>
        <span class="badge @diffLabel(currentDifficulty).Item1">
            <i class="bi bi-bar-chart me-1"></i> @diffLabel(currentDifficulty).Item2
        </span>
    </div>
    <div class="progress" style="height: 8px;">
        <div class="progress-bar @(showFeedback ? (isCorrect ? "bg-success" : "bg-danger") : "")"
             role="progressbar"
             style="width: @progress%">
        </div>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-12 col-lg-8">

        @if (showFeedback)
        {
            <!-- Result Banner -->
            <div class="alert @(isCorrect ? "alert-success" : "alert-danger") d-flex align-items-center gap-3 mb-4 shadow-sm">
                <i class="bi @(isCorrect ? "bi-check-circle-fill" : "bi-x-circle-fill") fs-3"></i>
                <div>
                    <strong class="fs-5">@(isCorrect ? "Corect!" : "Incorect!")</strong>
                    <p class="mb-0 small">
                        @if (!isCorrect)
                        {
                            var correct = Model.Question.Answers.FirstOrDefault(a => a.Id == correctAnswerId);
                            <text>Răspunsul corect era: <strong>@correct?.Text</strong></text>
                        }
                        else
                        {
                            <text>Felicitări, ai selectat răspunsul corect.</text>
                        }
                    </p>
                </div>
            </div>
        }

        <!-- Question Card -->
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
                <p class="text-muted small text-uppercase fw-semibold mb-0">
                    <i class="bi bi-patch-question me-1"></i> Întrebarea @(answeredCount + (showFeedback ? 0 : 1))
                </p>
                <span class="badge bg-secondary bg-opacity-10 text-secondary small">
                    <i class="bi bi-journal-text me-1"></i> @Model.Question.Course?.Title
                </span>
            </div>
            <div class="card-body p-4">
                <h5 class="fw-semibold lh-base mb-0">@Model.Question.Text</h5>
            </div>
        </div>

        <!-- Answers -->
        @if (!showFeedback)
        {
            <form asp-action="Answer" method="post" id="answerForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="sessionId" value="@sessionId" />
                <input type="hidden" name="sessionQuestionId" value="@Model.Id" />
                <input type="hidden" name="answerId" id="selectedAnswerId" value="" />

                <div class="row g-3 mb-4">
                    @foreach (var answer in Model.Question.Answers)
                    {
                        <div class="col-md-6">
                            <div class="answer-card card shadow-sm border-0 h-100"
                                 data-answer-id="@answer.Id"
                                 onclick="selectAnswer(@answer.Id, this)"
                                 style="cursor: pointer; transition: all 0.15s ease;">
                                <div class="card-body p-3 d-flex align-items-center gap-3">
                                    <div class="answer-indicator rounded-circle border border-2 flex-shrink-0"
                                         style="width: 28px; height: 28px; transition: all 0.15s ease;">
                                    </div>
                                    <span class="fw-medium">@answer.Text</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="d-flex justify-content-end">
                    <button type="submit"
                            id="submitBtn"
                            class="btn btn-primary px-5 py-2 disabled"
                            disabled>
                        Trimite <i class="bi bi-arrow-right ms-1"></i>
                    </button>
                </div>
            </form>
        }
        else
        {
            <!-- Answers with feedback colors -->
            <div class="row g-3 mb-4">
                @foreach (var answer in Model.Question.Answers)
                {
                    var isRight = answer.IsCorrect;
                    var wasSelected = answer.Id == selectedAnswerId;

                    string cardClass = "border-0 bg-light";
                    string iconClass = "bi-circle text-muted";

                    if (isRight)
                    {
                        cardClass = "border-success bg-success bg-opacity-10";
                        iconClass = "bi-check-circle-fill text-success";
                    }
                    else if (wasSelected && !isRight)
                    {
                        cardClass = "border-danger bg-danger bg-opacity-10";
                        iconClass = "bi-x-circle-fill text-danger";
                    }

                    <div class="col-md-6">
                        <div class="card @cardClass border h-100">
                            <div class="card-body p-3 d-flex align-items-center gap-3">
                                <i class="bi @iconClass fs-5 flex-shrink-0"></i>
                                <span class="fw-medium">@answer.Text</span>
                                @if (wasSelected && isRight)
                                {
                                    <span class="badge bg-success ms-auto">Răspunsul tău</span>
                                }
                                else if (wasSelected && !isRight)
                                {
                                    <span class="badge bg-danger ms-auto">Răspunsul tău</span>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Difficulty Formula -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="mb-0 fw-semibold text-muted text-uppercase">
                        <i class="bi bi-calculator me-1"></i> Ajustare Dificultate
                    </h6>
                </div>
                <div class="card-body p-4">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <div>
                            <div class="text-muted small fw-semibold mb-1">Curentă</div>
                            <span class="badge @diffLabel(currentDifficulty).Item1 px-3 py-2">
                                @diffLabel(currentDifficulty).Item2
                            </span>
                        </div>
                        <i class="bi bi-arrow-right text-muted fs-5 mt-3"></i>
                        <div>
                            <div class="text-muted small fw-semibold mb-1">Următoarea</div>
                            <span class="badge @diffLabel(nextDifficulty).Item1 px-3 py-2">
                                @diffLabel(nextDifficulty).Item2
                            </span>
                        </div>
                    </div>

                    <hr />

                    <p class="small text-muted mb-2">
                        <strong>Formulă:</strong> media ultimelor @windowSize răspunsuri
                        → dacă &gt; @increaseThreshold.ToString("0.0") crește,
                        dacă &lt; @decreaseThreshold.ToString("0.0") scade,
                        altfel rămâne aceeași.
                    </p>

                    <div class="d-flex align-items-center gap-2 mb-2">
                        <span class="small text-muted fw-semibold">Ultimele @windowSize răspunsuri:</span>
                        @foreach (var val in lastWindow)
                        {
                            <span class="badge @(val == 1 ? "bg-success" : "bg-danger")">
                                @(val == 1 ? "✓" : "✗")
                            </span>
                        }
                        @for (int i = lastWindow.Count; i < windowSize; i++)
                        {
                            <span class="badge bg-secondary bg-opacity-25 text-secondary">—</span>
                        }
                    </div>

                    @if (windowAvg.HasValue)
                    {
                        <p class="small mb-0">
                            <strong>Medie:</strong>
                            <span class="@(windowAvg.Value > increaseThreshold ? "text-success" : windowAvg.Value < decreaseThreshold ? "text-danger" : "text-muted") fw-semibold">
                                @windowAvg.Value.ToString("0.00")
                            </span>
                            —
                            @if (windowAvg.Value > increaseThreshold)
                            {
                                <span class="text-success">Dificultatea crește <i class="bi bi-arrow-up"></i></span>
                            }
                            else if (windowAvg.Value < decreaseThreshold)
                            {
                                <span class="text-danger">Dificultatea scade <i class="bi bi-arrow-down"></i></span>
                            }
                            else
                            {
                                <span class="text-muted">Dificultatea rămâne aceeași <i class="bi bi-dash"></i></span>
                            }
                        </p>
                    }
                    else
                    {
                        <p class="small text-muted mb-0">
                            Dificultatea se va ajusta după colectarea a @windowSize răspunsuri
                            (@lastWindow.Count / @windowSize până acum).
                        </p>
                    }
                </div>
            </div>

            <!-- Next Button -->
            <div class="d-flex justify-content-end">
                @if (isLastQuestion)
                {
                    <a asp-action="Complete"
                       asp-route-sessionId="@sessionId"
                       class="btn btn-success px-5 py-2">
                        <i class="bi bi-check-circle me-2"></i> Vezi Rezultatele
                    </a>
                }
                else
                {
                    <a asp-action="Question"
                       asp-route-sessionId="@sessionId"
                       class="btn btn-primary px-5 py-2">
                        Următoarea Întrebare <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                }
            </div>
        }

    </div>
</div>

<style>
    .answer-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.1) !important;
        border-color: #0d6efd !important;
    }

    .answer-card.selected {
        border: 2px solid #0d6efd !important;
        background-color: #f0f5ff;
    }

        .answer-card.selected .answer-indicator {
            background-color: #0d6efd;
            border-color: #0d6efd !important;
        }
</style>

@section Scripts {
    <script>
        function selectAnswer(answerId, card) {
            document.querySelectorAll('.answer-card').forEach(c => c.classList.remove('selected'));
            card.classList.add('selected');
            document.getElementById('selectedAnswerId').value = answerId;
            const btn = document.getElementById('submitBtn');
            btn.classList.remove('disabled');
            btn.disabled = false;
        }

        document.getElementById('answerForm')?.addEventListener('submit', function () {
            const btn = document.getElementById('submitBtn');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Se trimite...';
        });
    </script>
}

@model MedicalOnboardingApplication.Models.TestSessionQuestion
@{
    ViewData["Title"] = "Întrebare";
    var answeredCount = ViewBag.AnsweredCount as int? ?? 0;
    var totalQuestions = ViewBag.TotalQuestions as int? ?? 15;
    var progress = ViewBag.Progress as int? ?? 0;
    var currentDifficulty = ViewBag.CurrentDifficulty as int? ?? 1;
    var sessionId = ViewBag.SessionId as int? ?? 0;
    var showFeedback = ViewBag.ShowFeedback as bool? ?? false;
    var isCorrect = ViewBag.IsCorrect as bool? ?? false;
    var correctAnswerId = ViewBag.CorrectAnswerId as int? ?? 0;
    var selectedAnswerId = ViewBag.SelectedAnswerId as int? ?? 0;
    var windowAvg = ViewBag.WindowAvg as double?;
    var lastWindow = ViewBag.LastWindow as List<double> ?? new List<double>();
    var windowSize = ViewBag.WindowSize as int? ?? 3;
    var increaseThreshold = ViewBag.IncreaseThreshold as double? ?? 0.8;
    var decreaseThreshold = ViewBag.DecreaseThreshold as double? ?? 0.5;
    var isLastQuestion = ViewBag.IsLastQuestion as bool? ?? false;
    var nextDifficulty = ViewBag.NextDifficulty as int? ?? currentDifficulty;

    Func<int, (string cls, string label)> diffLabel = (int diff) => diff switch
    {
        1 => (cls: "rm-status-green", label: "1 — Foarte Ușor"),
        2 => (cls: "rm-status-blue", label: "2 — Ușor"),
        3 => (cls: "rm-status-yellow", label: "3 — Mediu"),
        4 => (cls: "rm-status-red", label: "4 — Dificil"),
        5 => (cls: "rm-status-red", label: "5 — Foarte Dificil"),
        _ => (cls: "rm-status-gray", label: diff.ToString())
    };

    var questionNumber = answeredCount + (showFeedback ? 0 : 1);
}

<!-- Progress Bar -->
<div class="rm-test-progress">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
        <span style="font-size:0.8rem;color:var(--rm-text-muted);">
            Întrebarea @questionNumber din @totalQuestions
        </span>
        <span class="rm-status-badge @diffLabel(currentDifficulty).cls">
            <i class="bi bi-bar-chart" style="font-size:0.7rem;"></i>
            @diffLabel(currentDifficulty).label
        </span>
    </div>
    <div class="rm-progress-bar" style="height:6px;">
        <div class="rm-progress-fill @(showFeedback ? (isCorrect ? "rm-progress-green" : "rm-progress-red") : "rm-progress-blue")"
             style="width:@progress%;"></div>
    </div>
</div>

<div style="max-width:720px;margin:0 auto;">

    <!-- Feedback Banner -->
    @if (showFeedback)
    {
        <div class="rm-feedback-banner @(isCorrect ? "rm-feedback-correct" : "rm-feedback-wrong") mb-4">
            <div class="rm-feedback-icon">
                <i class="bi @(isCorrect ? "bi-check-circle-fill" : "bi-x-circle-fill")"></i>
            </div>
            <div>
                <div style="font-weight:700;font-size:1rem;margin-bottom:3px;">
                    @(isCorrect ? "Corect!" : "Incorect!")
                </div>
                <div style="font-size:0.875rem;">
                    @if (!isCorrect)
                    {
                        var correct = Model.Question.Answers.FirstOrDefault(a => a.Id == correctAnswerId);
                        <text>Răspunsul corect era: <strong>@correct?.Text</strong></text>
                    }
                    else
                    {
                        <text>Felicitări, ai selectat răspunsul corect.</text>
                    }
                </div>
            </div>
        </div>
    }

    <!-- Question Card -->
    <div class="rm-form-card mb-4">
        <div class="rm-form-card-header" style="justify-content:space-between;">
            <div style="display:flex;align-items:center;gap:8px;">
                <i class="bi bi-patch-question" style="color:var(--rm-red);"></i>
                Întrebarea @questionNumber
            </div>
            @if (Model.Question.Course != null)
            {
                <span class="rm-badge">
                    <i class="bi bi-journal-text" style="font-size:0.7rem;"></i>
                    @Model.Question.Course.Title
                </span>
            }
        </div>
        <div class="rm-form-card-body">
            <p style="font-size:1.05rem;font-weight:600;line-height:1.6;margin:0;color:var(--rm-text);">
                @Model.Question.Text
            </p>
        </div>
    </div>

    <!-- Answers -->
    @if (!showFeedback)
    {
        <form asp-action="Answer" method="post" id="answerForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="sessionId" value="@sessionId" />
            <input type="hidden" name="sessionQuestionId" value="@Model.Id" />
            <input type="hidden" name="answerId" id="selectedAnswerId" value="" />

            <div class="rm-answers-grid mb-4">
                @foreach (var answer in Model.Question.Answers)
                {
                    <div class="rm-answer-option" data-answer-id="@answer.Id"
                         onclick="selectAnswer(@answer.Id, this)">
                        <div class="rm-answer-option-dot"></div>
                        <span class="rm-answer-option-text">@answer.Text</span>
                    </div>
                }
            </div>

            <div class="d-flex justify-content-end">
                <button type="submit" id="submitBtn"
                        class="btn-rm-primary"
                        style="opacity:0.4;pointer-events:none;padding:11px 32px;font-size:0.95rem;"
                        disabled>
                    Trimite <i class="bi bi-arrow-right"></i>
                </button>
            </div>
        </form>
    }
    else
    {
        <!-- Answers with feedback -->
        <div class="rm-answers-grid mb-4">
            @foreach (var answer in Model.Question.Answers)
            {
                var isRight = answer.IsCorrect;
                var wasChosen = answer.Id == selectedAnswerId;

                string optClass = "rm-answer-option rm-answer-option--static";
                string iconClass = "bi-circle";
                string iconColor = "#ccc";

                if (isRight)
                {
                    optClass += " rm-answer-option--correct";
                    iconClass = "bi-check-circle-fill";
                    iconColor = "#16a34a";
                }
                else if (wasChosen)
                {
                    optClass += " rm-answer-option--wrong";
                    iconClass = "bi-x-circle-fill";
                    iconColor = "#dc2626";
                }

                <div class="@optClass">
                    <i class="bi @iconClass" style="color:@iconColor;font-size:1rem;flex-shrink:0;"></i>
                    <span class="rm-answer-option-text">@answer.Text</span>
                    @if (wasChosen)
                    {
                        <span class="rm-status-badge @(isRight ? "rm-status-green" : "rm-status-red") ms-auto" style="flex-shrink:0;">
                            Răspunsul tău
                        </span>
                    }
                </div>
            }
        </div>

        <!-- Difficulty Adjustment Card -->
        <div class="rm-form-card mb-4">
            <div class="rm-form-card-header">
                <i class="bi bi-calculator" style="color:var(--rm-red);"></i>
                Ajustare Dificultate
            </div>
            <div class="rm-form-card-body">

                <!-- Current → Next -->
                <div style="display:flex;align-items:center;gap:16px;margin-bottom:20px;">
                    <div>
                        <div style="font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.07em;color:#bbb;margin-bottom:6px;">Curentă</div>
                        <span class="rm-status-badge @diffLabel(currentDifficulty).cls" style="font-size:0.82rem;padding:6px 12px;">
                            @diffLabel(currentDifficulty).label
                        </span>
                    </div>
                    <i class="bi bi-arrow-right" style="color:#ccc;font-size:1.1rem;margin-top:18px;"></i>
                    <div>
                        <div style="font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.07em;color:#bbb;margin-bottom:6px;">Următoarea</div>
                        <span class="rm-status-badge @diffLabel(nextDifficulty).cls" style="font-size:0.82rem;padding:6px 12px;">
                            @diffLabel(nextDifficulty).label
                        </span>
                    </div>
                </div>

                <div style="border-top:1px solid var(--rm-border);margin-bottom:16px;"></div>

                <!-- Formula -->
                <p style="font-size:0.82rem;color:var(--rm-text-muted);margin-bottom:12px;">
                    <strong>Formulă:</strong> media ultimelor @windowSize răspunsuri
                    → dacă &gt; @increaseThreshold.ToString("0.0") crește,
                    dacă &lt; @decreaseThreshold.ToString("0.0") scade,
                    altfel rămâne aceeași.
                </p>

                <!-- Window pills -->
                <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;flex-wrap:wrap;">
                    <span style="font-size:0.78rem;font-weight:600;color:var(--rm-text-muted);">
                        Ultimele @windowSize:
                    </span>
                    @foreach (var val in lastWindow)
                    {
                        <span class="rm-status-badge @(val == 1 ? "rm-status-green" : "rm-status-red")" style="padding:3px 10px;">
                            @(val == 1 ? "✓" : "✗")
                        </span>
                    }
                    @for (int i = lastWindow.Count; i < windowSize; i++)
                    {
                        <span class="rm-status-badge rm-status-gray" style="padding:3px 10px;">—</span>
                    }
                </div>

                @if (windowAvg.HasValue)
                {
                    <p style="font-size:0.82rem;margin:0;">
                        <strong>Medie:</strong>
                        <span style="font-weight:700;color:@(windowAvg.Value > increaseThreshold ? "#16a34a" : windowAvg.Value < decreaseThreshold ? "#dc2626" : "var(--rm-text-muted)");">
                            @windowAvg.Value.ToString("0.00")
                        </span>
                        —
                        @if (windowAvg.Value > increaseThreshold)
                        {
                            <span style="color:#16a34a;">Dificultatea crește <i class="bi bi-arrow-up"></i></span>
                        }
                        else if (windowAvg.Value < decreaseThreshold)
                        {
                            <span style="color:#dc2626;">Dificultatea scade <i class="bi bi-arrow-down"></i></span>
                        }
                        else
                        {
                            <span style="color:var(--rm-text-muted);">Dificultatea rămâne aceeași <i class="bi bi-dash"></i></span>
                        }
                    </p>
                }
                else
                {
                    <p style="font-size:0.82rem;color:var(--rm-text-muted);margin:0;">
                        Dificultatea se va ajusta după colectarea a @windowSize răspunsuri
                        (@lastWindow.Count / @windowSize până acum).
                    </p>
                }
            </div>
        </div>

        <!-- Next / Finish -->
        <div class="d-flex justify-content-end">
            @if (isLastQuestion)
            {
                <a asp-action="Complete" asp-route-sessionId="@sessionId"
                       class="btn-rm-success" style="padding:11px 32px;font-size:0.95rem;">
                    <i class="bi bi-check-circle"></i> Vezi Rezultatele
                </a>
            }
            else
            {
                <a asp-action="Question" asp-route-sessionId="@sessionId"
                       class="btn-rm-primary" style="padding:11px 32px;font-size:0.95rem;">
                    Următoarea Întrebare <i class="bi bi-arrow-right"></i>
                </a>
            }
        </div>
    }

</div>

@section Scripts {
    <script>
        function selectAnswer(answerId, card) {
            document.querySelectorAll('.rm-answer-option').forEach(c => c.classList.remove('rm-answer-option--selected'));
            card.classList.add('rm-answer-option--selected');
            document.getElementById('selectedAnswerId').value = answerId;
            const btn = document.getElementById('submitBtn');
            btn.style.opacity = '1';
            btn.style.pointerEvents = 'auto';
            btn.disabled = false;
        }

        document.getElementById('answerForm')?.addEventListener('submit', function () {
            const btn = document.getElementById('submitBtn');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" style="width:14px;height:14px;"></span> Se trimite...';
        });
    </script>
}
@model IEnumerable<MedicalOnboardingApplication.Models.TestSession>
@{
    ViewData["Title"] = "Teste";
    var canStart = ViewBag.CanStartTest as bool? ?? false;
    var questionCount = ViewBag.QuestionCount as int? ?? 0;
    var activeSessionId = ViewBag.ActiveSessionId as int?;

    Func<int, (string cls, string label)> diffLabel = (int diff) => diff switch
    {
        1 => (cls: "rm-status-green", label: "1 — Foarte Ușor"),
        2 => (cls: "rm-status-blue", label: "2 — Ușor"),
        3 => (cls: "rm-status-yellow", label: "3 — Mediu"),
        4 => (cls: "rm-status-red", label: "4 — Dificil"),
        5 => (cls: "rm-status-red", label: "5 — Foarte Dificil"),
        _ => (cls: "rm-status-gray", label: diff.ToString())
    };
}

<!-- Page Header -->
<div class="rm-page-header">
    <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
        <div>
            <div class="breadcrumb-label">
                <a asp-controller="Dashboard" asp-action="Index" class="text-decoration-none" style="color:inherit;">Panou</a>
                <i class="bi bi-chevron-right mx-1" style="font-size:0.65rem;"></i>
                Teste
            </div>
            <a asp-controller="Dashboard"
                   asp-action="Index"
                   class="btn btn-outline-secondary btn-rm-back mb-2"
                   style="color:var(--rm-red);border-color:var(--rm-red);">
                <i class="bi bi-arrow-left"></i> Înapoi la Panou
            </a>
            <h1>Teste</h1>
            <p>Susține teste adaptive pentru a-ți evalua cunoștințele</p>
        </div>
    </div>
</div>

@if (TempData["Error"] != null)
{
    <div class="rm-alert rm-alert-error mb-4">
        <i class="bi bi-exclamation-circle-fill"></i>
        @TempData["Error"]
    </div>
}

<!-- Start Test Card -->
<div class="rm-form-card mb-4">
    <div class="rm-form-card-body">
        <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:24px;flex-wrap:wrap;">
            <div style="flex:1;min-width:260px;">
                <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;">
                    <div style="width:40px;height:40px;border-radius:10px;background:#fef9c3;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                        <i class="bi bi-patch-question" style="color:#ca8a04;font-size:1.2rem;"></i>
                    </div>
                    <h5 style="font-weight:700;margin:0;font-size:1rem;">Test Adaptiv</h5>
                </div>
                <p style="font-size:0.875rem;color:var(--rm-text-muted);margin-bottom:8px;line-height:1.65;">
                    Testul constă în 15 întrebări. Dificultatea se ajustează automat în funcție de ultimele 3 răspunsuri.
                    Întrebările sunt extrase din cursurile atribuite tipului tău de angajat.
                </p>
                <p style="font-size:0.82rem;color:var(--rm-text-muted);margin-bottom:0;">
                    <i class="bi bi-info-circle me-1"></i>
                    Se recomandă să finalizezi toate cursurile atribuite înainte de a susține testul.
                </p>

                @if (activeSessionId.HasValue)
                {
                    <div class="rm-modal-warning mt-3">
                        <i class="bi bi-exclamation-triangle"></i>
                        Ai un test nefinalizat. Completează-l înainte de a începe unul nou.
                    </div>
                }
                else if (!canStart)
                {
                    <div class="rm-modal-warning mt-3">
                        <i class="bi bi-exclamation-triangle"></i>
                        Nu sunt suficiente întrebări disponibile (@questionCount găsite, 15 necesare).
                        Solicită administratorului să adauge mai multe întrebări.
                    </div>
                }
            </div>

            <div style="flex-shrink:0;display:flex;align-items:center;">
                @if (activeSessionId.HasValue)
                {
                    <a asp-action="Question" asp-route-sessionId="@activeSessionId"
                           class="btn-rm-warning" style="font-size:0.9rem;padding:11px 24px;">
                        <i class="bi bi-play-circle-fill"></i> Continuă Testul
                    </a>
                }
                else if (canStart)
                {
                    <form asp-action="Start" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-rm-warning" style="font-size:0.9rem;padding:11px 24px;">
                            <i class="bi bi-play-circle-fill"></i> Începe Test Nou
                        </button>
                    </form>
                }
                else
                {
                    <button class="btn-rm-warning" style="font-size:0.9rem;padding:11px 24px;opacity:0.5;pointer-events:none;" disabled>
                        <i class="bi bi-play-circle"></i> Începe Test Nou
                    </button>
                }
            </div>
        </div>
    </div>
</div>

<!-- Test History -->
<div class="rm-form-card">
    <div class="rm-form-card-header" style="justify-content:space-between;">
        <div style="display:flex;align-items:center;gap:8px;">
            <i class="bi bi-clock-history" style="color:var(--rm-red);"></i>
            Istoric Teste
            <span class="rm-count-badge" style="background:#f0f0f0;color:#666;">@Model.Count()</span>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="rm-form-card-body">
            <div class="rm-empty-state">
                <i class="bi bi-patch-question"></i>
                <p>Niciun test susținut încă. Începe primul test de mai sus!</p>
            </div>
        </div>
    }
    else
    {
        <table class="rm-table">
            <thead>
                <tr>
                    <th>Dată</th>
                    <th>Scor</th>
                    <th>Corecte</th>
                    <th>Dificultate Medie</th>
                    <th>Status</th>
                    <th style="text-align:right;">Acțiuni</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var session in Model)
                {
                    var scorePct = session.TotalQuestions > 0
                        ? (int)Math.Round((double)session.CorrectAnswers / session.TotalQuestions * 100)
                        : 0;
                    var scoreColor = scorePct >= 80 ? "#16a34a" : scorePct >= 50 ? "#ca8a04" : "#dc2626";
                    var dl = session.IsCompleted ? diffLabel((int)Math.Round(session.AverageDifficulty)) : (cls: "rm-status-gray", label: "—");
                    <tr>
                        <td>
                            <span style="font-weight:600;font-size:0.875rem;">
                                @session.StartedAt.ToLocalTime().ToString("dd MMM yyyy")
                            </span>
                            <br />
                            <small style="color:var(--rm-text-muted);">
                                @session.StartedAt.ToLocalTime().ToString("HH:mm")
                            </small>
                        </td>
                        <td>
                            @if (session.IsCompleted)
                            {
                                <span style="font-weight:700;font-size:1.1rem;color:@scoreColor;">@scorePct%</span>
                            }
                            else
                            {
                                <span style="color:var(--rm-text-muted);">—</span>
                            }
                        </td>
                        <td style="color:var(--rm-text-muted);font-size:0.875rem;">
                            @if (session.IsCompleted)
                            {
                                <span>@session.CorrectAnswers / @session.TotalQuestions</span>
                            }
                            else
                            {
                                <span>— / @session.TotalQuestions</span>
                            }
                        </td>
                        <td>
                            @if (session.IsCompleted)
                            {
                                <span class="rm-status-badge @dl.cls">
                                    @session.AverageDifficulty.ToString("0.0")
                                </span>
                            }
                            else
                            {
                                <span style="color:var(--rm-text-muted);">—</span>
                            }
                        </td>
                        <td>
                            @if (session.IsCompleted)
                            {
                                <span class="rm-status-badge rm-status-green">
                                    <i class="bi bi-check-circle"></i> Finalizat
                                </span>
                            }
                            else
                            {
                                <span class="rm-status-badge rm-status-yellow">
                                    <i class="bi bi-hourglass-split"></i> În Progres
                                </span>
                            }
                        </td>
                        <td style="text-align:right;">
                            @if (session.IsCompleted)
                            {
                                <a asp-action="Results" asp-route-sessionId="@session.Id"
                                       class="btn-rm-outline">
                                    <i class="bi bi-bar-chart"></i> Rezultate
                                </a>
                            }
                            else
                            {
                                <a asp-action="Question" asp-route-sessionId="@session.Id"
                                       class="btn-rm-outline" style="border-color:#fde68a;color:#ca8a04;">
                                    <i class="bi bi-play-circle"></i> Continuă
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
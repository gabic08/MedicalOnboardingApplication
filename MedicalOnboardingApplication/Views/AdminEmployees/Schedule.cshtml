@{
    ViewData["Title"] = "Program Angajat";
    var employee = ViewBag.Employee as MedicalOnboardingApplication.Models.ApplicationUser;
    var schedules = ViewBag.Schedules as List<MedicalOnboardingApplication.Models.WorkSchedule>;
    var dayNames = ViewBag.DayNames as Dictionary<DayOfWeek, string>;

    var order = new[] {
        DayOfWeek.Monday, DayOfWeek.Tuesday, DayOfWeek.Wednesday,
        DayOfWeek.Thursday, DayOfWeek.Friday, DayOfWeek.Saturday, DayOfWeek.Sunday
    };
}

<!-- Page Header -->
<div class="rm-page-header">
    <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
        <div>
            <div class="breadcrumb-label">
                <a asp-controller="Admin" asp-action="Index" class="text-decoration-none" style="color:inherit;">Panou Admin</a>
                <i class="bi bi-chevron-right mx-1" style="font-size:0.65rem;"></i>
                <a asp-action="Index" class="text-decoration-none" style="color:inherit;">Angajați</a>
                <i class="bi bi-chevron-right mx-1" style="font-size:0.65rem;"></i>
                Program
            </div>
            <a asp-controller="AdminEmployees"
                   asp-action="Index"
                   class="btn btn-outline-secondary btn-rm-back mb-2"
                   style="color:var(--rm-red);border-color:var(--rm-red);">
                <i class="bi bi-arrow-left"></i> Înapoi la Angajați
            </a>
            <h1>@employee.FirstName @employee.LastName</h1>
            @if (employee.EmployeeType != null)
            {
                <p>
                    <span class="rm-badge" style="font-size:0.8rem;">
                        <i class="bi bi-person-badge" style="font-size:0.7rem;"></i>
                        @employee.EmployeeType.Name
                    </span>
                </p>
            }
        </div>
        <a asp-action="Edit" asp-route-id="@employee.Id" class="btn-rm-secondary align-self-end">
            <i class="bi bi-pencil"></i> Editează Programul
        </a>
    </div>
</div>

<!-- Schedule Card -->
<div class="rm-form-card" style="max-width:680px;">
    <div class="rm-form-card-header">
        <i class="bi bi-calendar-week" style="color:var(--rm-red);"></i>
        Program Săptămânal
    </div>
    <div class="rm-schedule-list">
        @foreach (var day in order)
        {
            var dayShifts = schedules.Where(s => s.Day == day).ToList();
            bool isDayOff = !dayShifts.Any();
            bool isWeekend = day == DayOfWeek.Saturday || day == DayOfWeek.Sunday;

            <div class="rm-schedule-row" style="@(isDayOff ? "opacity:0.5;" : "")">
                <div class="d-flex align-items-center justify-content-between">
                    <span class="rm-schedule-day-name" style="width:110px;flex-shrink:0;">
                        @dayNames[day]
                        @if (isWeekend)
                        {
                            <span style="font-size:0.65rem;color:var(--rm-text-muted);font-weight:400;margin-left:4px;">WE</span>
                        }
                    </span>
                    @if (isDayOff)
                    {
                        <span class="rm-badge">
                            <i class="bi bi-moon" style="font-size:0.7rem;"></i> Zi liberă
                        </span>
                    }
                    else
                    {
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var shift in dayShifts)
                            {
                                <span class="rm-shift-badge">
                                    <i class="bi bi-clock" style="font-size:0.7rem;"></i>
                                    @shift.StartTime.ToString("HH:mm") — @shift.EndTime.ToString("HH:mm")
                                </span>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>
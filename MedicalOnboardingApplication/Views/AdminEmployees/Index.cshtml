@model IEnumerable<MedicalOnboardingApplication.Models.ApplicationUser>

@{
    var search = ViewBag.Search as string;
    var employeeTypeId = ViewBag.EmployeeTypeId as int?;
    var employeeTypes = ViewBag.EmployeeTypes as List<MedicalOnboardingApplication.Models.EmployeeType>;
    var showArchived = (bool)(ViewBag.ShowArchived ?? false);
}

<!-- Page Header -->
<div class="rm-page-header">
    <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
        <div>
            <div class="breadcrumb-label">
                <a asp-controller="Admin" asp-action="Index" class="text-decoration-none" style="color:inherit;">Panou Admin</a>
                <i class="bi bi-chevron-right mx-1" style="font-size:0.65rem;"></i>
                Angajați
            </div>
            <a asp-controller="Admin"
                   asp-action="Index"
                   class="btn btn-outline-secondary btn-rm-back mb-2"
                   style="color:var(--rm-red);border-color:var(--rm-red);">
                <i class="bi bi-arrow-left"></i> Înapoi la Panou
            </a>
            <h1>Angajați</h1>
            <p>Gestionează conturile și progresul angajaților</p>
        </div>
        <div class="d-flex gap-2 align-self-end">
            @if (showArchived)
            {
                <a asp-action="Index" class="btn-rm-secondary">
                    <i class="bi bi-people"></i> Angajați Activi
                </a>
            }
            else
            {
                <a asp-action="Index" asp-route-showArchived="true" class="btn-rm-secondary">
                    <i class="bi bi-archive"></i> Angajați Arhivați
                </a>
            }
            <a asp-controller="EmployeeTypes" asp-action="Index" class="btn-rm-secondary">
                <i class="bi bi-briefcase"></i> Tipuri de Angajați
            </a>
            @if (!showArchived)
            {
                <a asp-action="Create" class="btn-rm-primary">
                    <i class="bi bi-plus-lg"></i> Adaugă Angajat
                </a>
            }
        </div>
    </div>
</div>

<!-- Filter Bar -->
<form method="get" class="rm-filter-bar">
    <input type="hidden" name="showArchived" value="@showArchived.ToString().ToLower()" />
    <div style="flex:1;min-width:220px;">
        <div style="position:relative;">
            <i class="bi bi-search" style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:#bbb;font-size:0.85rem;"></i>
            <input type="text"
                   name="search"
                   value="@search"
                   class="form-control"
                   style="padding-left:36px;"
                   placeholder="Caută după nume sau email..." />
        </div>
    </div>
    <div style="min-width:200px;">
        <select name="employeeTypeId" class="form-select">
            <option value="">Toate Tipurile de Angajați</option>
            @foreach (var type in employeeTypes)
            {
                <option value="@type.Id" selected="@(employeeTypeId == type.Id)">
                    @type.Name
                </option>
            }
        </select>
    </div>
    <button type="submit" class="btn-rm-primary">
        <i class="bi bi-search"></i> Caută
    </button>
    @if (!string.IsNullOrEmpty(search) || employeeTypeId.HasValue)
    {
        <a asp-action="Index" asp-route-showArchived="@showArchived" class="btn-rm-secondary">
            <i class="bi bi-x"></i> Resetează
        </a>
    }
</form>

@if (TempData["Error"] != null)
{
    <div class="rm-alert rm-alert-error mb-4">
        <i class="bi bi-exclamation-circle-fill"></i>
        @TempData["Error"]
    </div>
}

@if (showArchived)
{
    <div class="rm-alert mb-3" style="background:var(--rm-bg-muted,#f8f9fa);border:1px solid #dee2e6;border-radius:8px;padding:12px 16px;display:flex;align-items:center;gap:10px;font-size:0.875rem;color:var(--rm-text-muted);">
        <i class="bi bi-archive" style="font-size:1rem;"></i>
        Se afișează angajații arhivați. Poți să îi dezarhivezi pentru a le restaura accesul.
    </div>
}

<!-- Results summary -->
@if (Model.Any())
{
    <div class="d-flex align-items-center mb-3">
        <p class="mb-0" style="font-size:0.85rem;color:var(--rm-text-muted);">
            <strong style="color:var(--rm-text);">@Model.Count()</strong> @(showArchived ? "angajați arhivați găsiți" : "angajați găsiți")
        </p>
    </div>
}

<!-- Employees Table -->
<div class="rm-table-card">
    <table class="rm-table">
        <thead>
            <tr>
                <th style="width:35%;">Angajat</th>
                <th>Email</th>
                <th>Tip Angajat</th>
                <th style="width:@(showArchived ? "200px" : "260px");text-align:right;">Acțiuni</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var emp in Model)
            {
                <tr>
                    <td>
                        <div class="d-flex align-items-center gap-3">
                            <img src="@(emp.ProfileImagePath ?? "/required/NoProfileImage.jpg")"
                                 class="rm-avatar"
                                 alt="@emp.FirstName @emp.LastName"
                                 style="@(showArchived ? "opacity:0.5;" : "")" />
                            <div>
                                <span style="font-weight:600;color:var(--rm-text);@(showArchived ? "opacity:0.6;" : "")">@emp.FirstName @emp.LastName</span>
                                @if (showArchived && emp.ArchivedAt.HasValue)
                                {
                                    <div style="font-size:0.75rem;color:var(--rm-text-muted);">
                                        Arhivat la @emp.ArchivedAt.Value.ToLocalTime().ToString("dd MMM yyyy")
                                    </div>
                                }
                            </div>
                        </div>
                    </td>
                    <td style="color:var(--rm-text-muted);font-size:0.875rem;">@emp.Email</td>
                    <td>
                        @if (emp.EmployeeType != null)
                        {
                            <span class="rm-badge">
                                <i class="bi bi-person-badge" style="font-size:0.7rem;"></i>
                                @emp.EmployeeType.Name
                            </span>
                        }
                        else
                        {
                            <span style="color:#ccc;font-size:0.85rem;">—</span>
                        }
                    </td>
                    <td>
                        <div class="rm-table-actions">
                            @if (showArchived)
                            {
                                <form asp-controller="AdminEmployees" asp-action="Unarchive" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@emp.Id" />
                                    <button type="submit"
                                            class="btn-rm-outline"
                                            onclick="return confirm('Ești sigur că vrei să dezarhivezi angajatul \'@emp.FirstName @emp.LastName\'?\n\nAngajatul va putea accesa din nou aplicația.');">
                                        <i class="bi bi-arrow-counterclockwise"></i> Dezarhivează
                                    </button>
                                </form>
                            }
                            else
                            {
                                <a asp-controller="AdminEmployees"
                                       asp-action="Report"
                                       asp-route-id="@emp.Id"
                                       class="btn-rm-outline">
                                    <i class="bi bi-file-earmark-bar-graph"></i> Raport
                                </a>
                                <a asp-action="Edit" asp-route-id="@emp.Id" class="btn-rm-outline">
                                    <i class="bi bi-pencil"></i> Editează
                                </a>
                                <a asp-action="Schedule" asp-route-id="@emp.Id" class="btn-rm-outline">
                                    <i class="bi bi-calendar-week"></i> Program
                                </a>
                                <form asp-controller="AdminEmployees" asp-action="Archive" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@emp.Id" />
                                    <button type="submit"
                                            class="btn-rm-outline btn-rm-outline-danger"
                                            onclick="return confirm('Ești sigur că vrei să arhivezi angajatul \'@emp.FirstName @emp.LastName\'?\n\nAngajatul nu va mai putea accesa aplicația.');">
                                        <i class="bi bi-archive"></i> Arhivează
                                    </button>
                                </form>
                            }
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="4">
                        <div class="rm-empty-state">
                            <i class="bi bi-@(showArchived ? "archive" : "people")"></i>
                            <p>@(showArchived ? "Niciun angajat arhivat găsit." : "Niciun angajat găsit. Încearcă să modifici filtrele sau adaugă un angajat nou.")</p>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>


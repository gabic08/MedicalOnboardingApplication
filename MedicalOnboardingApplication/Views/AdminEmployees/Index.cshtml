@model IEnumerable<MedicalOnboardingApplication.Models.ApplicationUser>

<div class="mb-4">
    <a asp-controller="Admin" asp-action="Index" class="btn btn-outline-secondary mb-2">
        <i class="bi bi-arrow-left"></i> Back to Dashboard
    </a>
    <h2 class="mb-0">Employees</h2>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div class="d-flex gap-2">
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus"></i> Add Employee
        </a>
    </div>
    <div>
        <a asp-controller="EmployeeTypes"
           asp-action="Index"
           class="btn btn-outline-secondary">
            <i class="bi bi-briefcase"></i> Manage Employee Types
        </a>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4">Employee</th>
                    <th>Email</th>
                    <th>Employee Type</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var emp in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <div class="d-flex align-items-center gap-3">
                                <img src="@(emp.ProfileImagePath ?? "/required/NoProfileImage.jpg")"
                                     class="rounded-circle border"
                                     style="width: 40px; height: 40px; object-fit: cover;"
                                     alt="@emp.FirstName @emp.LastName" />
                                <span class="fw-semibold">@emp.FirstName @emp.LastName</span>
                            </div>
                        </td>
                        <td class="text-muted">@emp.Email</td>
                        <td>
                            @if (emp.EmployeeType != null)
                            {
                                <span class="badge bg-secondary bg-opacity-10 text-secondary">
                                    <i class="bi bi-person-badge me-1"></i> @emp.EmployeeType.Name
                                </span>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                        <td class="text-end pe-4">
                            <a asp-action="Edit" asp-route-id="@emp.Id" class="btn btn-sm btn-outline-warning me-1">
                                <i class="bi bi-pencil me-1"></i> Edit
                            </a>
                            <a asp-action="Delete" asp-route-id="@emp.Id" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash me-1"></i> Delete
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
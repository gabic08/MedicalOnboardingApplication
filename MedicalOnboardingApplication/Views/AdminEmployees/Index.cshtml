@model IEnumerable<MedicalOnboardingApplication.Models.ApplicationUser>

@{
    var search = ViewBag.Search as string;
    var employeeTypeId = ViewBag.EmployeeTypeId as int?;
    var employeeTypes = ViewBag.EmployeeTypes as List<MedicalOnboardingApplication.Models.EmployeeType>;
}

<!-- Page Header -->
<div class="rm-page-header">
    <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
        <div>
            <div class="breadcrumb-label">
                <a asp-controller="Admin" asp-action="Index" class="text-decoration-none" style="color:inherit;">Panou Admin</a>
                <i class="bi bi-chevron-right mx-1" style="font-size:0.65rem;"></i>
                Angajați
            </div>
            <a asp-controller="Admin"
                   asp-action="Index"
                   class="btn btn-outline-secondary btn-rm-back mb-2"
                   style="color:var(--rm-red);border-color:var(--rm-red);">
                <i class="bi bi-arrow-left"></i> Înapoi la Panou
            </a>
            <h1>Angajați</h1>
            <p>Gestionează conturile și progresul angajaților</p>
        </div>
        <div class="d-flex gap-2 align-self-end">
            <a asp-controller="EmployeeTypes" asp-action="Index" class="btn-rm-secondary">
                <i class="bi bi-briefcase"></i> Tipuri de Angajați
            </a>
            <a asp-action="Create" class="btn-rm-primary">
                <i class="bi bi-plus-lg"></i> Adaugă Angajat
            </a>
        </div>
    </div>
</div>

<!-- Filter Bar -->
<form method="get" class="rm-filter-bar">
    <div style="flex:1;min-width:220px;">
        <div style="position:relative;">
            <i class="bi bi-search" style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:#bbb;font-size:0.85rem;"></i>
            <input type="text"
                   name="search"
                   value="@search"
                   class="form-control"
                   style="padding-left:36px;"
                   placeholder="Caută după nume sau email..." />
        </div>
    </div>
    <div style="min-width:200px;">
        <select name="employeeTypeId" class="form-select">
            <option value="">Toate Tipurile de Angajați</option>
            @foreach (var type in employeeTypes)
            {
                <option value="@type.Id" selected="@(employeeTypeId == type.Id)">
                    @type.Name
                </option>
            }
        </select>
    </div>
    <button type="submit" class="btn-rm-primary">
        <i class="bi bi-search"></i> Caută
    </button>
    @if (!string.IsNullOrEmpty(search) || employeeTypeId.HasValue)
    {
        <a asp-action="Index" class="btn-rm-secondary">
            <i class="bi bi-x"></i> Resetează
        </a>
    }
</form>

<!-- Results summary -->
@if (Model.Any())
{
    <div class="d-flex align-items-center mb-3">
        <p class="mb-0" style="font-size:0.85rem;color:var(--rm-text-muted);">
            <strong style="color:var(--rm-text);">@Model.Count()</strong> angajați găsiți
        </p>
    </div>
}

<!-- Employees Table -->
<div class="rm-table-card">
    <table class="rm-table">
        <thead>
            <tr>
                <th style="width:35%;">Angajat</th>
                <th>Email</th>
                <th>Tip Angajat</th>
                <th style="width:260px;text-align:right;">Acțiuni</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var emp in Model)
            {
                <tr>
                    <td>
                        <div class="d-flex align-items-center gap-3">
                            <img src="@(emp.ProfileImagePath ?? "/required/NoProfileImage.jpg")"
                                 class="rm-avatar"
                                 alt="@emp.FirstName @emp.LastName" />
                            <span style="font-weight:600;color:var(--rm-text);">@emp.FirstName @emp.LastName</span>
                        </div>
                    </td>
                    <td style="color:var(--rm-text-muted);font-size:0.875rem;">@emp.Email</td>
                    <td>
                        @if (emp.EmployeeType != null)
                        {
                            <span class="rm-badge">
                                <i class="bi bi-person-badge" style="font-size:0.7rem;"></i>
                                @emp.EmployeeType.Name
                            </span>
                        }
                        else
                        {
                            <span style="color:#ccc;font-size:0.85rem;">—</span>
                        }
                    </td>
                    <td>
                        <div class="rm-table-actions">
                            <a asp-controller="AdminEmployees"
                                   asp-action="Report"
                                   asp-route-id="@emp.Id"
                                   class="btn-rm-outline">
                                <i class="bi bi-file-earmark-bar-graph"></i> Raport
                            </a>
                            <a asp-action="Edit" asp-route-id="@emp.Id" class="btn-rm-outline">
                                <i class="bi bi-pencil"></i> Editează
                            </a>
                            <a asp-action="Schedule" asp-route-id="@emp.Id" class="btn-rm-outline">
                                <i class="bi bi-calendar-week"></i> Program
                            </a>
                            <button type="button"
                                    class="btn-rm-outline btn-rm-outline-danger"
                                    data-bs-toggle="modal"
                                    data-bs-target="#deleteEmployeeModal"
                                    data-employee-id="@emp.Id"
                                    data-employee-name="@emp.FirstName @emp.LastName">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="4">
                        <div class="rm-empty-state">
                            <i class="bi bi-people"></i>
                            <p>Niciun angajat găsit. Încearcă să modifici filtrele sau adaugă un angajat nou.</p>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Hidden Form -->
<form id="deleteEmployeeForm" asp-action="Delete" method="post" class="d-none">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="deleteEmployeeId" />
</form>

<!-- Delete Employee Modal -->
<div class="modal fade" id="deleteEmployeeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="rm-modal-content">
            <div class="rm-modal-header">
                <div class="rm-modal-icon rm-modal-icon-danger">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                </div>
                <button type="button" class="rm-modal-close" data-bs-dismiss="modal">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="rm-modal-body">
                <h5 class="rm-modal-title">Șterge Angajatul</h5>
                <p class="rm-modal-text">Ești sigur că vrei să ștergi <strong id="deleteEmployeeName"></strong>?</p>
                <div class="rm-modal-warning">
                    <i class="bi bi-info-circle"></i>
                    Această acțiune nu poate fi anulată.
                </div>
            </div>
            <div class="rm-modal-footer">
                <button type="button" class="btn-rm-secondary" data-bs-dismiss="modal">Anulează</button>
                <button type="button" class="btn-rm-danger"
                        onclick="document.getElementById('deleteEmployeeForm').submit();">
                    <i class="bi bi-trash"></i> Da, Șterge
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('deleteEmployeeModal').addEventListener('show.bs.modal', function (e) {
            const btn = e.relatedTarget;
            document.getElementById('deleteEmployeeId').value = btn.getAttribute('data-employee-id');
            document.getElementById('deleteEmployeeName').innerText = btn.getAttribute('data-employee-name');
        });
    </script>
}
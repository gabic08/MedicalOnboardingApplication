@model MedicalOnboardingApplication.ViewModels.EditEmployeeViewModel
@{
    ViewData["Title"] = "Editare Angajat";
}

<div class="mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary mb-2">
        <i class="bi bi-arrow-left"></i> Înapoi la Angajați
    </a>
    <h1 class="mb-0">Editare Angajat</h1>
</div>

<div class="row">
    <div class="col-12 col-lg-10 mx-auto">
        <form asp-action="Edit" method="post" data-prefix="Schedule">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-3"></div>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="mb-0 fw-semibold text-muted text-uppercase">
                        <i class="bi bi-pencil-square me-2 text-warning"></i> Detalii Angajat
                    </h6>
                </div>
                <div class="card-body p-4">
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="FirstName" class="form-label fw-semibold small"></label>
                            <input asp-for="FirstName" class="form-control" />
                            <span asp-validation-for="FirstName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LastName" class="form-label fw-semibold small"></label>
                            <input asp-for="LastName" class="form-control" />
                            <span asp-validation-for="LastName" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold small"></label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="EmployeeTypeId" class="form-label fw-semibold small"></label>
                        <select asp-for="EmployeeTypeId"
                                asp-items="ViewBag.EmployeeTypes"
                                class="form-select">
                            <option value="">— Selectează tipul —</option>
                        </select>
                        <span asp-validation-for="EmployeeTypeId" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            @await Html.PartialAsync("_SchedulePartial", Model.Schedule,
                new ViewDataDictionary(ViewData) { { "Prefix", "Schedule" } })

            <div class="d-flex justify-content-end mt-4">
                <button type="submit" class="btn btn-primary px-4">
                    <i class="bi bi-save me-1"></i> Salvează Modificările
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
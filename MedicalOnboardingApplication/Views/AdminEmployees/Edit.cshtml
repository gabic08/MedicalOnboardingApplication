@model MedicalOnboardingApplication.ViewModels.EditEmployeeViewModel
@{
    ViewData["Title"] = "Editare Angajat";
}

<!-- Page Header -->
<div class="rm-page-header">
    <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
        <div>
            <div class="breadcrumb-label">
                <a asp-controller="Admin" asp-action="Index" class="text-decoration-none" style="color:inherit;">Panou Admin</a>
                <i class="bi bi-chevron-right mx-1" style="font-size:0.65rem;"></i>
                <a asp-controller="AdminEmployees" asp-action="Index" class="text-decoration-none" style="color:inherit;">Angajați</a>
                <i class="bi bi-chevron-right mx-1" style="font-size:0.65rem;"></i>
                Editare
            </div>
            <h1>Editare Angajat</h1>
            <p>Modifică detaliile și programul angajatului</p>
        </div>
    </div>
</div>

<form asp-action="Edit" method="post" data-prefix="Schedule">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    @if (ViewData.ModelState.ErrorCount > 0)
    {
        <div class="rm-alert rm-alert-error mb-4">
            <i class="bi bi-exclamation-circle-fill"></i>
            <div asp-validation-summary="ModelOnly"></div>
        </div>
    }

    <div class="rm-two-col">

        <!-- LEFT: Employee Details -->
        <div class="rm-two-col-main">
            <div class="rm-form-card mb-4">
                <div class="rm-form-card-header">
                    <i class="bi bi-person" style="color:var(--rm-red);"></i>
                    Detalii Angajat
                </div>
                <div class="rm-form-card-body">
                    <div class="rm-field mb-3">
                        <label asp-for="FirstName" class="rm-label"></label>
                        <input asp-for="FirstName" class="rm-input" />
                        <span asp-validation-for="FirstName" class="rm-field-error"></span>
                    </div>
                    <div class="rm-field mb-3">
                        <label asp-for="LastName" class="rm-label"></label>
                        <input asp-for="LastName" class="rm-input" />
                        <span asp-validation-for="LastName" class="rm-field-error"></span>
                    </div>
                    <div class="rm-field mb-3">
                        <label asp-for="Email" class="rm-label"></label>
                        <input asp-for="Email" class="rm-input" />
                        <span asp-validation-for="Email" class="rm-field-error"></span>
                    </div>
                    <div class="rm-field mb-4">
                        <label asp-for="EmployeeTypeId" class="rm-label"></label>
                        @if (ViewBag.EmployeeTypes is SelectList empTypes && empTypes.Any())
                        {
                            <select asp-for="EmployeeTypeId"
                                    asp-items="ViewBag.EmployeeTypes"
                                    class="rm-input rm-select">
                                <option value="">— Selectează tipul —</option>
                            </select>
                            <span asp-validation-for="EmployeeTypeId" class="rm-field-error"></span>
                        }
                        else
                        {
                            <div class="rm-modal-warning mt-1">
                                <i class="bi bi-exclamation-triangle"></i>
                                Nu există niciun tip de angajat creat.
                                <a asp-controller="EmployeeTypes" asp-action="Index"
                                       style="color:inherit;font-weight:700;margin-left:4px;">
                                    Adaugă un tip de angajat
                                </a> înainte de a crea un angajat.
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-end">
                <button type="submit" class="btn-rm-primary">
                    <i class="bi bi-save"></i> Salvează Modificările
                </button>
            </div>
        </div>

        <!-- RIGHT: Schedule -->
        <div class="rm-two-col-side">
            @await Html.PartialAsync("_SchedulePartial", Model.Schedule,
                new ViewDataDictionary(ViewData) { { "Prefix", "Schedule" } })
        </div>

    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
@model MedicalOnboardingApplication.Models.ApplicationUser

<div class="mb-4">
    <a asp-controller="AdminEmployees" asp-action="Index" class="btn btn-outline-secondary mb-2">
        <i class="bi bi-arrow-left"></i> Back to Employees
    </a>
    <h2 class="mb-0">Create Employee</h2>
</div>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label>Email</label>
        <input asp-for="Email" class="form-control" />
    </div>
    <div class="mb-3">
        <label>First Name</label>
        <input asp-for="FirstName" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Last Name</label>
        <input asp-for="LastName" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Employee Type</label>
        <select asp-for="EmployeeTypeId"
                asp-items="ViewBag.EmployeeTypes"
                class="form-select">
        </select>
    </div>
    <div class="alert alert-info">
        Default password will be: <strong>P@ssw0rd</strong>
    </div>
    <button type="submit" class="btn btn-primary">
        Create Employee
    </button>
</form>
@{
    ViewData["Title"] = "Raport Angajat";

    var employee = ViewBag.Employee as MedicalOnboardingApplication.Models.ApplicationUser;
    var assignedCourses = ViewBag.AssignedCourses as List<MedicalOnboardingApplication.Models.Course> ?? new();
    var completedCourseIds = ViewBag.CompletedCourseIds as List<int> ?? new();
    var completedChapterIds = ViewBag.CompletedChapterIds as List<int> ?? new();
    var chapterProgressMap = ViewBag.ChapterProgressMap as Dictionary<int, DateTime> ?? new();
    var courseProgressMap = ViewBag.CourseProgressMap as Dictionary<int, DateTime> ?? new();
    var testSessions = ViewBag.TestSessions as List<MedicalOnboardingApplication.Models.TestSession> ?? new();
    var isCompliant = ViewBag.IsCompliant as bool? ?? false;
    var nonCompliantReason = ViewBag.NonCompliantReason as string ?? "";
    var averageTestScore = ViewBag.AverageTestScore as double? ?? 0;
    var passingScore = ViewBag.PassingScore as double? ?? 70;
    var reportDate = ViewBag.ReportDate as DateTime? ?? DateTime.Now;
    var clinicName = ViewBag.ClinicName as string ?? "";

    var bestScore = testSessions.Any()
        ? testSessions.Max(s => s.TotalQuestions > 0 ? (double)s.CorrectAnswers / s.TotalQuestions * 100 : 0)
        : 0;
    var latestScore = testSessions.Any()
        ? (double)testSessions.Last().CorrectAnswers / testSessions.Last().TotalQuestions * 100
        : 0;
}

<!-- Page Header -->
<div class="rm-page-header">
    <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
        <div>
            <div class="breadcrumb-label">
                <a asp-controller="Admin" asp-action="Index" class="text-decoration-none" style="color:inherit;">Panou Admin</a>
                <i class="bi bi-chevron-right mx-1" style="font-size:0.65rem;"></i>
                <a asp-controller="AdminEmployees" asp-action="Index" class="text-decoration-none" style="color:inherit;">Angajați</a>
                <i class="bi bi-chevron-right mx-1" style="font-size:0.65rem;"></i>
                Raport
            </div>
            <h1>Raport Angajat</h1>
            <p>Progres cursuri, capitole și performanță teste</p>
        </div>
        <button onclick="window.print()" class="btn-rm-secondary align-self-end">
            <i class="bi bi-printer"></i> Printează Raportul
        </button>
    </div>
</div>

<!-- ===================== -->
<!-- EMPLOYEE HEADER CARD -->
<!-- ===================== -->
<div class="rm-form-card mb-4">
    <div class="rm-form-card-body">
        <div class="d-flex align-items-center gap-4 flex-wrap">
            <img src="@(employee.ProfileImagePath ?? "/required/NoProfileImage.jpg")"
                 style="width:80px;height:80px;border-radius:50%;object-fit:cover;border:3px solid var(--rm-border);flex-shrink:0;" />
            <div class="flex-grow-1">
                <h3 style="font-weight:700;margin-bottom:6px;font-size:1.4rem;">
                    @employee.FirstName @employee.LastName
                </h3>
                <div class="d-flex flex-wrap gap-3" style="font-size:0.85rem;color:var(--rm-text-muted);">
                    <span><i class="bi bi-person-badge me-1"></i>@(employee.EmployeeType?.Name ?? "—")</span>
                    <span><i class="bi bi-hospital me-1"></i>@clinicName</span>
                    <span><i class="bi bi-envelope me-1"></i>@employee.Email</span>
                </div>
            </div>
            <div style="text-align:right;flex-shrink:0;">
                <div style="font-size:0.78rem;color:var(--rm-text-muted);margin-bottom:3px;">Raport generat la</div>
                <div style="font-weight:600;font-size:0.9rem;">@reportDate.ToString("dd MMM yyyy HH:mm")</div>
            </div>
        </div>
    </div>
</div>

<!-- ===================== -->
<!-- COMPLIANCE VERDICT -->
<!-- ===================== -->
<div class="rm-form-card mb-4" style="border-left: 4px solid @(isCompliant ? "#16a34a" : "#dc2626");">
    <div class="rm-form-card-body">
        <div class="d-flex align-items-center gap-4 flex-wrap">
            <div style="width:60px;height:60px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.6rem;flex-shrink:0;background:@(isCompliant ? "#dcfce7" : "#fef2f2");">
                <i class="bi @(isCompliant ? "bi-shield-fill-check" : "bi-shield-fill-x")"
                   style="color:@(isCompliant ? "#16a34a" : "#dc2626");"></i>
            </div>
            <div class="flex-grow-1">
                <h4 style="font-weight:700;margin-bottom:4px;color:@(isCompliant ? "#16a34a" : "#dc2626");">
                    @(isCompliant ? "Conform" : "Neconform")
                </h4>
                @if (isCompliant)
                {
                    <p style="font-size:0.875rem;color:var(--rm-text-muted);margin:0;">
                        Toate cursurile atribuite au fost finalizate și scorul mediu la teste îndeplinește pragul necesar.
                    </p>
                }
                else
                {
                    <p style="font-size:0.875rem;color:#dc2626;margin:0;">
                        <i class="bi bi-exclamation-triangle me-1"></i>@nonCompliantReason
                    </p>
                }
            </div>
            <div class="d-flex gap-4 flex-shrink-0">
                <div class="rm-stat-cell">
                    <div class="rm-stat-label">Cursuri Finalizate</div>
                    <div class="rm-stat-value">@completedCourseIds.Count <span class="rm-stat-total">/ @assignedCourses.Count</span></div>
                </div>
                <div class="rm-stat-cell">
                    <div class="rm-stat-label">Teste Susținute</div>
                    <div class="rm-stat-value">@testSessions.Count</div>
                </div>
                <div class="rm-stat-cell">
                    <div class="rm-stat-label">Scor Mediu</div>
                    <div class="rm-stat-value" style="color:@(averageTestScore >= passingScore ? "#16a34a" : "#dc2626");">
                        @(testSessions.Any() ? $"{averageTestScore:0.0}%" : "—")
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ===================== -->
<!-- COURSE PROGRESS -->
<!-- ===================== -->
<div class="rm-form-card mb-4">
    <div class="rm-form-card-header" style="justify-content:space-between;">
        <div style="display:flex;align-items:center;gap:8px;">
            <i class="bi bi-journal-text" style="color:var(--rm-red);"></i>
            Progres Cursuri
            <span class="rm-count-badge" style="background:#eff6ff;color:#2563eb;">@assignedCourses.Count</span>
        </div>
    </div>

    @if (!assignedCourses.Any())
    {
        <div class="rm-form-card-body">
            <div class="rm-empty-state">
                <i class="bi bi-journal-x"></i>
                <p>Niciun curs atribuit.</p>
            </div>
        </div>
    }
    else
    {
        <div class="accordion rm-accordion-flush" id="coursesAccordion">
            @foreach (var course in assignedCourses)
            {
                var isCourseCompleted = completedCourseIds.Contains(course.Id);
                var totalChapters = course.Chapters?.Count ?? 0;
                var completedCount = course.Chapters?.Count(ch => completedChapterIds.Contains(ch.Id)) ?? 0;
                var progressPct = totalChapters > 0 ? (int)Math.Round((double)completedCount / totalChapters * 100) : 0;
                var isInProgress = completedCount > 0 && !isCourseCompleted;
                var collapseId = $"course_{course.Id}";
                var completedAt = courseProgressMap.ContainsKey(course.Id)
                    ? courseProgressMap[course.Id].ToString("dd MMM yyyy") : null;

                <div class="rm-report-course-item">
                    <button class="rm-report-course-btn collapsed"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#@collapseId">
                        <div style="display:flex;align-items:center;gap:12px;width:100%;">
                            @if (isCourseCompleted)
                            {
                                <i class="bi bi-check-circle-fill" style="color:#16a34a;font-size:1.1rem;flex-shrink:0;"></i>
                            }
                            else if (isInProgress)
                            {
                                <i class="bi bi-hourglass-split" style="color:#2563eb;font-size:1.1rem;flex-shrink:0;"></i>
                            }
                            else
                            {
                                <i class="bi bi-circle" style="color:#ccc;font-size:1.1rem;flex-shrink:0;"></i>
                            }
                            <span style="font-weight:600;flex:1;">@course.Title</span>
                            <div style="display:flex;align-items:center;gap:12px;flex-shrink:0;">
                                <span style="font-size:0.8rem;color:var(--rm-text-muted);">@completedCount / @totalChapters capitole</span>
                                @if (isCourseCompleted)
                                {
                                    <span class="rm-status-badge rm-status-green">
                                        <i class="bi bi-check-circle"></i> Finalizat @completedAt
                                    </span>
                                }
                                else if (isInProgress)
                                {
                                    <span class="rm-status-badge rm-status-blue">În Progres</span>
                                }
                                else
                                {
                                    <span class="rm-status-badge rm-status-gray">Neînceput</span>
                                }
                            </div>
                        </div>
                        <i class="bi bi-chevron-down rm-accordion-chevron" style="margin-left:12px;"></i>
                    </button>

                    <div id="@collapseId" class="accordion-collapse collapse">
                        <div class="rm-report-course-body">
                            <!-- Progress bar -->
                            <div style="margin-bottom:16px;">
                                <div style="display:flex;justify-content:space-between;margin-bottom:5px;font-size:0.78rem;color:var(--rm-text-muted);">
                                    <span>Progres</span><span>@progressPct%</span>
                                </div>
                                <div class="rm-progress-bar">
                                    <div class="rm-progress-fill @(isCourseCompleted ? "rm-progress-green" : "rm-progress-blue")"
                                         style="width:@progressPct%;"></div>
                                </div>
                            </div>
                            <!-- Chapters -->
                            <div class="rm-chapter-list">
                                @foreach (var chapter in course.Chapters?.OrderBy(c => c.Order) ?? Enumerable.Empty<MedicalOnboardingApplication.Models.Chapter>())
                                {
                                    var chCompleted = completedChapterIds.Contains(chapter.Id);
                                    var chDate = chapterProgressMap.ContainsKey(chapter.Id)
                                        ? chapterProgressMap[chapter.Id].ToString("dd MMM yyyy") : null;
                                    <div class="rm-chapter-item">
                                        <i class="bi @(chCompleted ? "bi-check-circle-fill" : "bi-circle")"
                                           style="color:@(chCompleted ? "#16a34a" : "#ccc");flex-shrink:0;"></i>
                                        <span style="font-size:0.875rem;@(chCompleted ? "" : "color:var(--rm-text-muted)");">
                                            @chapter.Order. @chapter.Title
                                        </span>
                                        @if (chCompleted && chDate != null)
                                        {
                                            <span style="font-size:0.78rem;color:var(--rm-text-muted);margin-left:auto;">@chDate</span>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- ===================== -->
<!-- TEST PERFORMANCE -->
<!-- ===================== -->
<div class="rm-form-card mb-4">
    <div class="rm-form-card-header" style="justify-content:space-between;">
        <div style="display:flex;align-items:center;gap:8px;">
            <i class="bi bi-patch-question" style="color:#f59e0b;"></i>
            Performanță Teste
            <span class="rm-count-badge rm-count-yellow">@testSessions.Count</span>
        </div>
    </div>
    <div class="rm-form-card-body">
        @if (!testSessions.Any())
        {
            <div class="rm-empty-state">
                <i class="bi bi-patch-question"></i>
                <p>Niciun test susținut încă.</p>
            </div>
        }
        else
        {
            <!-- Stat Cards -->
            <div class="rm-stat-grid mb-4">
                <div class="rm-stat-card">
                    <div class="rm-stat-card-label">Scor Mediu</div>
                    <div class="rm-stat-card-value" style="color:@(averageTestScore >= passingScore ? "#16a34a" : "#dc2626");">
                        @averageTestScore.ToString("0.0")%
                    </div>
                    <div class="rm-stat-card-sub">Necesar ≥ @passingScore%</div>
                </div>
                <div class="rm-stat-card">
                    <div class="rm-stat-card-label">Cel Mai Bun Scor</div>
                    <div class="rm-stat-card-value" style="color:#2563eb;">@bestScore.ToString("0.0")%</div>
                </div>
                <div class="rm-stat-card">
                    <div class="rm-stat-card-label">Ultimul Scor</div>
                    <div class="rm-stat-card-value" style="color:@(latestScore >= passingScore ? "#16a34a" : "#dc2626");">
                        @latestScore.ToString("0.0")%
                    </div>
                </div>
                <div class="rm-stat-card">
                    <div class="rm-stat-card-label">Teste Susținute</div>
                    <div class="rm-stat-card-value">@testSessions.Count</div>
                </div>
            </div>

            <!-- Test History Table -->
            <div class="rm-table-card">
                <table class="rm-table">
                    <thead>
                        <tr>
                            <th style="width:40px;">#</th>
                            <th>Dată</th>
                            <th>Scor</th>
                            <th>Corecte</th>
                            <th>Dificultate Medie</th>
                            <th style="text-align:right;">Rezultat</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int testNum = 1; }
                        @foreach (var session in testSessions)
                        {
                            var scorePct = session.TotalQuestions > 0
                                ? (double)session.CorrectAnswers / session.TotalQuestions * 100 : 0;
                            var passed = scorePct >= passingScore;

                            <tr>
                                <td style="color:var(--rm-text-muted);font-size:0.8rem;">@testNum</td>
                                <td>
                                    <span style="font-weight:600;font-size:0.875rem;">
                                        @session.StartedAt.ToLocalTime().ToString("dd MMM yyyy")
                                    </span>
                                    <br />
                                    <small style="color:var(--rm-text-muted);">
                                        @session.StartedAt.ToLocalTime().ToString("HH:mm")
                                    </small>
                                </td>
                                <td>
                                    <span style="font-weight:700;color:@(passed ? "#16a34a" : "#dc2626");">
                                        @scorePct.ToString("0.0")%
                                    </span>
                                </td>
                                <td style="color:var(--rm-text-muted);font-size:0.875rem;">
                                    @session.CorrectAnswers / @session.TotalQuestions
                                </td>
                                <td>
                                    <span class="rm-status-badge @(session.AverageDifficulty >= 4 ? "rm-status-red" : session.AverageDifficulty >= 3 ? "rm-status-yellow" : "rm-status-green")">
                                        @session.AverageDifficulty.ToString("0.0")
                                    </span>
                                </td>
                                <td style="text-align:right;">
                                    @if (passed)
                                    {
                                        <span class="rm-status-badge rm-status-green">
                                            <i class="bi bi-check-circle"></i> Promovat
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="rm-status-badge rm-status-red">
                                            <i class="bi bi-x-circle"></i> Nepromovat
                                        </span>
                                    }
                                </td>
                            </tr>
                            testNum++;
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<style>
    @@media print {
        .btn-rm-secondary, .rm-accordion-chevron { display: none !important; }
        .accordion-collapse { display: block !important; }
        .rm-form-card { box-shadow: none !important; border: 1px solid #eaeaea !important; }
    }
</style>
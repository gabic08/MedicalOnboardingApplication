@{
    ViewData["Title"] = "Panou Administrator";
    var hasClinic = ViewBag.HasClinic as bool? ?? false;
}

@if (!hasClinic)
{
    <div class="alert alert-warning d-flex align-items-center gap-3 mb-4 rounded-3 shadow-sm">
        <i class="bi bi-exclamation-triangle-fill fs-4 flex-shrink-0"></i>
        <div>
            <strong>Clinica nu este configurată.</strong>
            Trebuie să îți configurezi clinica înainte de a putea gestiona angajații și cursurile.
            <a asp-controller="Clinic" asp-action="Details" class="alert-link ms-1">
                Configurează clinica →
            </a>
        </div>
    </div>
}

<div class="admin-page-header">
    <h1>Panou Administrator</h1>
    <p>Gestionează sistemul de integrare dintr-un singur loc</p>
</div>

<p class="section-title">Gestionare</p>
<div class="row g-3 mb-4">

    <div class="col-md-4">
        <a asp-controller="AdminEmployees" asp-action="Index"
               class="admin-nav-card @(!hasClinic ? "disabled" : "")">
            <div class="admin-nav-card-top bg-success"></div>
            <div class="admin-nav-card-body">
                <div class="admin-nav-icon icon-green">
                    <i class="bi bi-people-fill"></i>
                </div>
                <h5>Angajați</h5>
                <p>Gestionează angajații, atribuie roluri și urmărește progresul fiecăruia.</p>
                <span class="admin-nav-link text-success">
                    Gestionează <i class="bi bi-arrow-right"></i>
                </span>
            </div>
        </a>
    </div>

    <div class="col-md-4">
        <a asp-controller="AdminCourses" asp-action="Index"
               class="admin-nav-card @(!hasClinic ? "disabled" : "")">
            <div class="admin-nav-card-top bg-primary"></div>
            <div class="admin-nav-card-body">
                <div class="admin-nav-icon icon-blue">
                    <i class="bi bi-journal-text"></i>
                </div>
                <h5>Cursuri</h5>
                <p>Creează, editează și organizează cursuri de integrare pentru angajați.</p>
                <span class="admin-nav-link text-primary">
                    Gestionează <i class="bi bi-arrow-right"></i>
                </span>
            </div>
        </a>
    </div>

    <div class="col-md-4">
        <a asp-controller="Clinic" asp-action="Details" class="admin-nav-card">
            <div class="admin-nav-card-top" style="background: #c8102e;"></div>
            <div class="admin-nav-card-body">
                <div class="admin-nav-icon icon-red">
                    <i class="bi bi-hospital"></i>
                </div>
                <h5>Clinică</h5>
                <p>Vizualizează și actualizează informațiile clinicii, subdomeniu și contact.</p>
                <span class="admin-nav-link" style="color: #c8102e;">
                    Gestionează <i class="bi bi-arrow-right"></i>
                </span>
            </div>
        </a>
    </div>

</div>

<p class="section-title">Setări</p>
<div class="row g-3">

    <div class="col-md-4">
        <a asp-controller="EmployeeTypes" asp-action="Index"
               class="admin-nav-card @(!hasClinic ? "disabled" : "")">
            <div class="admin-nav-card-top" style="background: #7c3aed;"></div>
            <div class="admin-nav-card-body">
                <div class="admin-nav-icon icon-purple">
                    <i class="bi bi-tags"></i>
                </div>
                <h5>Tipuri de Angajați</h5>
                <p>Definește și gestionează tipurile de roluri din clinica ta.</p>
                <span class="admin-nav-link" style="color: #7c3aed;">
                    Gestionează <i class="bi bi-arrow-right"></i>
                </span>
            </div>
        </a>
    </div>

    <div class="col-md-4">
        <a asp-controller="Profile" asp-action="UserProfile" class="admin-nav-card">
            <div class="admin-nav-card-top" style="background: #e8607a;"></div>
            <div class="admin-nav-card-body">
                <div class="admin-nav-icon icon-pink">
                    <i class="bi bi-person-circle"></i>
                </div>
                <h5>Profilul Meu</h5>
                <p>Actualizează datele contului tău, parola și imaginea de profil.</p>
                <span class="admin-nav-link" style="color: #e8607a;">
                    Vezi Profilul <i class="bi bi-arrow-right"></i>
                </span>
            </div>
        </a>
    </div>

</div>
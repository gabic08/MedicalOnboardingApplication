@{
    ViewData["Title"] = "Panou Administrator";
    var hasClinic = ViewBag.HasClinic as bool? ?? false;
}
<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="fw-bold">Panou Administrator</h1>
        <p class="text-muted">Gestionează sistemul de integrare dintr-un singur loc</p>
    </div>

    @if (!hasClinic)
    {
        <div class="alert alert-warning d-flex align-items-center gap-3 mb-4 shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill fs-4 flex-shrink-0"></i>
            <div>
                <strong>Clinica nu este configurată.</strong>
                Trebuie să îți configurezi clinica înainte de a putea gestiona angajații și cursurile.
                <a asp-controller="Clinic" asp-action="Details" class="alert-link ms-1">
                    Configurează clinica →
                </a>
            </div>
        </div>
    }

    <div class="row justify-content-center g-4">
        <!-- Courses Card -->
        <div class="col-md-5 col-lg-4">
            @if (hasClinic)
            {
                <a asp-controller="AdminCourses" asp-action="Index" class="text-decoration-none">
                    <div class="card shadow-lg border-0 h-100 admin-card">
                        <div class="card-body text-center p-5">
                            <div class="mb-4 text-primary">
                                <i class="bi bi-journal-text display-3"></i>
                            </div>
                            <h3 class="fw-bold mb-2">Cursuri</h3>
                            <p class="text-muted">
                                Creează, editează și organizează cursuri de integrare pentru angajați
                            </p>
                            <div class="mt-4">
                                <span class="btn btn-primary px-4">
                                    Gestionează Cursurile
                                </span>
                            </div>
                        </div>
                    </div>
                </a>
            }
            else
            {
                <div class="card shadow-lg border-0 h-100 admin-card disabled-card">
                    <div class="card-body text-center p-5">
                        <div class="mb-4 text-primary">
                            <i class="bi bi-journal-text display-3"></i>
                        </div>
                        <h3 class="fw-bold mb-2">Cursuri</h3>
                        <p class="text-muted">
                            Creează, editează și organizează cursuri de integrare pentru angajați
                        </p>
                        <div class="mt-4">
                            <span class="btn btn-primary px-4">
                                Gestionează Cursurile
                            </span>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Clinic Card -->
        <div class="col-md-5 col-lg-4">
            <a asp-controller="Clinic" asp-action="Details" class="text-decoration-none">
                <div class="card shadow-lg border-0 h-100 admin-card">
                    <div class="card-body text-center p-5">
                        <div class="mb-4 text-danger">
                            <i class="bi bi-hospital display-3"></i>
                        </div>
                        <h3 class="fw-bold mb-2">Clinică</h3>
                        <p class="text-muted">
                            Vizualizează și gestionează informațiile clinicii tale
                        </p>
                        <div class="mt-4">
                            <span class="btn btn-danger px-4">
                                Gestionează Clinica
                            </span>
                        </div>
                    </div>
                </div>
            </a>
        </div>

        <!-- Employees Card -->
        <div class="col-md-5 col-lg-4">
            @if (hasClinic)
            {
                <a asp-controller="AdminEmployees" asp-action="Index" class="text-decoration-none">
                    <div class="card shadow-lg border-0 h-100 admin-card">
                        <div class="card-body text-center p-5">
                            <div class="mb-4 text-success">
                                <i class="bi bi-people-fill display-3"></i>
                            </div>
                            <h3 class="fw-bold mb-2">Angajați</h3>
                            <p class="text-muted">
                                Gestionează angajații, atribuie roluri și actualizează informațiile acestora
                            </p>
                            <div class="mt-4">
                                <span class="btn btn-success px-4">
                                    Gestionează Angajații
                                </span>
                            </div>
                        </div>
                    </div>
                </a>
            }
            else
            {
                <div class="card shadow-lg border-0 h-100 admin-card disabled-card">
                    <div class="card-body text-center p-5">
                        <div class="mb-4 text-success">
                            <i class="bi bi-people-fill display-3"></i>
                        </div>
                        <h3 class="fw-bold mb-2">Angajați</h3>
                        <p class="text-muted">
                            Gestionează angajații, atribuie roluri și actualizează informațiile acestora
                        </p>
                        <div class="mt-4">
                            <span class="btn btn-success px-4">
                                Gestionează Angajații
                            </span>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
<style>
    .admin-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        border-radius: 1rem;
    }

        .admin-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 1rem 2rem rgba(0, 0, 0, 0.15);
        }

    .disabled-card {
        opacity: 0.5;
        pointer-events: none;
        cursor: not-allowed;
    }

        .disabled-card:hover {
            transform: none;
            box-shadow: none;
        }
</style>

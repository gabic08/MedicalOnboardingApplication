@using MedicalOnboardingApplication.ViewModels
@model UserProfileViewModel
@{
    ViewData["Title"] = "Profilul Meu";
}

@{
    var backUrl = User.IsInRole("Admin")
        ? Url.Action("Index", "Admin")
        : Url.Action("Index", "Dashboard");
}

<div class="mb-4">
    <a href="@backUrl" class="btn btn-outline-secondary mb-2">
        <i class="bi bi-arrow-left"></i> Înapoi la Panou
    </a>
    <h1 class="mb-0">Profilul Meu</h1>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<form method="post" enctype="multipart/form-data" novalidate>
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="row g-4">

        <!-- LEFT: Avatar + Name -->
        <div class="col-lg-4">
            <div class="card shadow-sm h-100">
                <div class="card-body d-flex flex-column align-items-center text-center py-4">

                    <div class="mb-3">
                        <img id="avatarPreview"
                             src="@(Model.ExistingProfileImagePath ?? "/required/NoProfileImage.jpg")"
                             class="rounded-circle border"
                             style="width: 130px; height: 130px; object-fit: cover;" />
                    </div>

                    <input asp-for="NewProfileImage"
                           id="NewProfileImage"
                           type="file"
                           class="d-none"
                           accept="image/*"
                           onchange="previewAvatar(this)" />
                    <span asp-validation-for="NewProfileImage" class="text-danger small"></span>

                    <input type="hidden" id="removeProfileImageHidden" name="RemoveProfileImage" value="false" />

                    <div class="d-flex gap-2 flex-wrap justify-content-center mb-3">
                        <!-- Upload -->
                        <button type="button"
                                class="btn btn-outline-primary btn-sm"
                                onclick="document.getElementById('NewProfileImage').click()">
                            <i class="bi bi-upload me-1"></i> Încarcă
                        </button>

                        <!-- View -->
                        @if (!string.IsNullOrEmpty(Model.ExistingProfileImagePath))
                        {
                            <a href="@Model.ExistingProfileImagePath"
                               target="_blank"
                               class="btn btn-outline-secondary btn-sm">
                                <i class="bi bi-eye me-1"></i> Vizualizează
                            </a>
                        }

                        <!-- Remove -->
                        @if (!string.IsNullOrEmpty(Model.ExistingProfileImagePath))
                        {
                            <button type="button"
                                    id="removeBtn"
                                    class="btn btn-outline-danger btn-sm"
                                    onclick="toggleRemoveImage(this)">
                                <i class="bi bi-trash me-1"></i> Șterge
                            </button>
                        }
                    </div>

                    <h5 class="mb-0">@Model.FirstName @Model.LastName</h5>

                    <hr class="w-100 my-4" />

                    <div class="w-100">
                        <div class="mb-3 text-start">
                            <label asp-for="FirstName" class="form-label fw-semibold"></label>
                            <input asp-for="FirstName" class="form-control" />
                            <span asp-validation-for="FirstName" class="text-danger small"></span>
                        </div>
                        <div class="mb-3 text-start">
                            <label asp-for="LastName" class="form-label fw-semibold"></label>
                            <input asp-for="LastName" class="form-control" />
                            <span asp-validation-for="LastName" class="text-danger small"></span>
                        </div>
                        <div class="mb-3 text-start">
                            <label asp-for="Email" class="form-label fw-semibold"></label>
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <!-- RIGHT: Change Password -->
        <div class="col-lg-8">
            <div class="card shadow-sm h-100">
                <div class="card-body py-4">

                    <h6 class="text-muted text-uppercase fw-semibold mb-4">
                        <i class="bi bi-lock me-1"></i> Schimbă Parola
                    </h6>

                    <p class="text-muted small mb-4">
                        Lasă aceste câmpuri goale dacă nu dorești să îți schimbi parola.
                    </p>

                    <div class="mb-3">
                        <label asp-for="CurrentPassword" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <input asp-for="CurrentPassword"
                                   type="password"
                                   id="currentPasswordField"
                                   class="form-control"
                                   placeholder="Introdu parola curentă" />
                            <button type="button"
                                    class="btn btn-outline-secondary toggle-password"
                                    data-target="currentPasswordField"
                                    tabindex="-1">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <input asp-for="NewPassword"
                                   type="password"
                                   id="newPasswordField"
                                   class="form-control"
                                   placeholder="Introdu parola nouă" />
                            <button type="button"
                                    class="btn btn-outline-secondary toggle-password"
                                    data-target="newPasswordField"
                                    tabindex="-1">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ConfirmNewPassword" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <input asp-for="ConfirmNewPassword"
                                   type="password"
                                   id="confirmPasswordField"
                                   class="form-control"
                                   placeholder="Confirmă parola nouă" />
                            <button type="button"
                                    class="btn btn-outline-secondary toggle-password"
                                    data-target="confirmPasswordField"
                                    tabindex="-1">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                    </div>

                </div>
            </div>
        </div>

    </div>

    <div class="d-flex justify-content-end mt-4">
        <button type="submit" class="btn btn-primary px-4">
            <i class="bi bi-save me-1"></i> Salvează Modificările
        </button>
    </div>

</form>

@{
    var clinic = ViewBag.Clinic as MedicalOnboardingApplication.Models.Clinic;
    var isEmployee = (bool)(ViewBag.IsEmployee ?? false);
    var schedules = ViewBag.Schedules as List<MedicalOnboardingApplication.Models.WorkSchedule>;
    var dayNames = ViewBag.DayNames as Dictionary<DayOfWeek, string>;

    var order = new[] {
        DayOfWeek.Monday, DayOfWeek.Tuesday, DayOfWeek.Wednesday,
        DayOfWeek.Thursday, DayOfWeek.Friday, DayOfWeek.Saturday, DayOfWeek.Sunday
    };
}


@if (clinic != null)
{
    <div class="row g-4 mt-1">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-body py-3">
                    <h6 class="text-muted text-uppercase fw-semibold mb-3">
                        <i class="bi bi-hospital me-1"></i> Clinica Mea
                    </h6>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <div class="d-flex align-items-center gap-2">
                                @if (!string.IsNullOrEmpty(clinic.ImagePath))
                                {
                                    <img src="@clinic.ImagePath"
                                         class="rounded border"
                                         style="width: 48px; height: 48px; object-fit: cover;" />
                                }
                                else
                                {
                                    <div class="rounded border d-flex align-items-center justify-content-center bg-light"
                                         style="width: 48px; height: 48px;">
                                        <i class="bi bi-hospital text-muted"></i>
                                    </div>
                                }
                                <div>
                                    <div class="fw-semibold">@clinic.Name</div>
                                    @if (!string.IsNullOrEmpty(clinic.City))
                                    {
                                        <div class="text-muted small">@clinic.City@(!string.IsNullOrEmpty(clinic.Country) ? $", {clinic.Country}" : "")</div>
                                    }
                                </div>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(clinic.Address))
                        {
                            <div class="col-md-4">
                                <div class="text-muted small text-uppercase fw-semibold mb-1">Adresă</div>
                                <div class="small">@clinic.Address</div>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(clinic.Phone) || !string.IsNullOrEmpty(clinic.Email))
                        {
                            <div class="col-md-4">
                                @if (!string.IsNullOrEmpty(clinic.Phone))
                                {
                                    <div class="small mb-1">
                                        <i class="bi bi-telephone me-1 text-muted"></i> @clinic.Phone
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(clinic.Email))
                                {
                                    <div class="small mb-1">
                                        <i class="bi bi-envelope me-1 text-muted"></i> @clinic.Email
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(clinic.Website))
                                {
                                    <div class="small">
                                        <i class="bi bi-globe me-1 text-muted"></i>
                                        <a href="@clinic.Website" target="_blank" class="text-decoration-none">@clinic.Website</a>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@* WORK SCHEDULE — employees only *@
@if (isEmployee && schedules != null)
{
    <div class="row g-4 mt-1">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="mb-0 fw-semibold text-muted text-uppercase">
                        <i class="bi bi-calendar-week me-1"></i> Programul Meu
                    </h6>
                </div>
                <div class="card-body p-0">
                    @foreach (var day in order)
                    {
                        var dayShifts = schedules.Where(s => s.Day == day).ToList();
                        <div class="d-flex align-items-center px-4 py-3 border-bottom">
                            <div style="width: 120px;" class="fw-semibold small">
                                @dayNames[day]
                            </div>
                            @if (!dayShifts.Any())
                            {
                                <span class="badge bg-secondary bg-opacity-10 text-secondary px-3 py-2 rounded-pill">
                                    <i class="bi bi-moon me-1"></i> Zi liberă
                                </span>
                            }
                            else
                            {
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var shift in dayShifts)
                                    {
                                        <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 rounded-pill">
                                            <i class="bi bi-clock me-1"></i>
                                            @shift.StartTime.ToString("HH:mm") — @shift.EndTime.ToString("HH:mm")
                                        </span>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function previewAvatar(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => document.getElementById('avatarPreview').src = e.target.result;
                reader.readAsDataURL(input.files[0]);
                document.getElementById('removeProfileImageHidden').value = 'false';
                const removeBtn = document.getElementById('removeBtn');
                if (removeBtn) removeBtn.classList.remove('btn-danger', 'active');
            }
        }

        function toggleRemoveImage(btn) {
            const hidden = document.getElementById('removeProfileImageHidden');
            const preview = document.getElementById('avatarPreview');
            const fileInput = document.getElementById('NewProfileImage');

            const isRemoving = hidden.value === 'true';

            if (!isRemoving) {
                hidden.value = 'true';
                preview.src = '/required/NoProfileImage.jpg';
                fileInput.value = '';
                btn.innerHTML = '<i class="bi bi-arrow-counterclockwise me-1"></i> Anulează Ștergerea';
                btn.classList.remove('btn-outline-danger');
                btn.classList.add('btn-danger');
            } else {
                hidden.value = 'false';
                preview.src = '@(Model.ExistingProfileImagePath ?? "/required/NoProfileImage.jpg")';
                btn.innerHTML = '<i class="bi bi-trash me-1"></i> Șterge';
                btn.classList.remove('btn-danger');
                btn.classList.add('btn-outline-danger');
            }
        }

        document.querySelectorAll('.toggle-password').forEach(btn => {
            btn.addEventListener('click', function () {
                const target = document.getElementById(this.dataset.target);
                target.type = target.type === 'password' ? 'text' : 'password';
                this.querySelector('i').classList.toggle('bi-eye');
                this.querySelector('i').classList.toggle('bi-eye-slash');
            });
        });
    </script>
}

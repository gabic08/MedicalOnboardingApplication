@using MedicalOnboardingApplication.ViewModels
@model UserProfileViewModel

@{
    ViewData["Title"] = "My Profile";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-body">

                <h4 class="mb-3">My Profile</h4>

                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success">
                        @TempData["Success"]
                    </div>
                }

                <form method="post" enctype="multipart/form-data" novalidate>
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <!-- Profile Image -->
                    <div class="mb-3 text-center">
                        <img src="@(Model.ExistingProfileImagePath ?? "/images/default-avatar.png")"
                             class="rounded-circle mb-2"
                             width="120"
                             height="120" />
                        <input asp-for="NewProfileImage"
                               type="file"
                               class="form-control mt-2"
                               accept="image/*" />
                        <span asp-validation-for="NewProfileImage" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="FirstName" class="form-label"></label>
                        <input asp-for="FirstName" class="form-control" />
                        <span asp-validation-for="FirstName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="LastName" class="form-label"></label>
                        <input asp-for="LastName" class="form-control" />
                        <span asp-validation-for="LastName" class="text-danger"></span>
                    </div>

                    <hr />

                    <h5>Change Password</h5>

                    <div class="mb-3">
                        <label asp-for="CurrentPassword" class="form-label"></label>
                        <input asp-for="CurrentPassword" type="password" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label"></label>
                        <input asp-for="NewPassword" type="password" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="ConfirmNewPassword" class="form-label"></label>
                        <input asp-for="ConfirmNewPassword" type="password" class="form-control" />
                    </div>

                    <button class="btn btn-primary w-100">
                        Update Profile
                    </button>
                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

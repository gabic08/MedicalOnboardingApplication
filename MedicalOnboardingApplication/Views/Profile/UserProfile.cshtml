@using MedicalOnboardingApplication.ViewModels
@model UserProfileViewModel
@{
    ViewData["Title"] = "Profilul Meu";
    var backUrl = User.IsInRole("Admin")
        ? Url.Action("Index", "Admin")
        : Url.Action("Index", "Dashboard");

    var clinic = ViewBag.Clinic as MedicalOnboardingApplication.Models.Clinic;
    var isEmployee = (bool)(ViewBag.IsEmployee ?? false);
    var schedules = ViewBag.Schedules as List<MedicalOnboardingApplication.Models.WorkSchedule>;
    var dayNames = ViewBag.DayNames as Dictionary<DayOfWeek, string>;
    var order = new[] {
        DayOfWeek.Monday, DayOfWeek.Tuesday, DayOfWeek.Wednesday,
        DayOfWeek.Thursday, DayOfWeek.Friday, DayOfWeek.Saturday, DayOfWeek.Sunday
    };
}

<!-- Page Header -->
<div class="rm-page-header">
    <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
        <div>
            <div class="breadcrumb-label">
                <a href="@backUrl" class="text-decoration-none" style="color:inherit;">Panou</a>
                <i class="bi bi-chevron-right mx-1" style="font-size:0.65rem;"></i>
                Profilul Meu
            </div>
            <h1>Profilul Meu</h1>
            <p>Gestionează informațiile tale de cont și parola</p>
        </div>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="rm-alert mb-4" style="background:#dcfce7;border:1px solid #bbf7d0;color:#16a34a;">
        <i class="bi bi-check-circle-fill"></i>
        @TempData["Success"]
    </div>
}

<form method="post" enctype="multipart/form-data" novalidate>
    @Html.AntiForgeryToken()

    @if (ViewData.ModelState.ErrorCount > 0)
    {
        <div class="rm-alert rm-alert-error mb-4">
            <i class="bi bi-exclamation-circle-fill"></i>
            <div asp-validation-summary="ModelOnly"></div>
        </div>
    }

    <div class="rm-two-col" style="grid-template-columns: 300px 1fr; align-items: start;">

        <!-- LEFT: Avatar + Basic Info -->
        <div class="rm-two-col-main">
            <div class="rm-form-card">
                <div class="rm-form-card-header">
                    <i class="bi bi-person-circle" style="color:var(--rm-red);"></i>
                    Informații Personale
                </div>
                <div class="rm-form-card-body" style="display:flex;flex-direction:column;align-items:center;text-align:center;">

                    <!-- Avatar -->
                    <div style="position:relative;margin-bottom:16px;">
                        <img id="avatarPreview"
                             src="@(Model.ExistingProfileImagePath ?? "/required/NoProfileImage.jpg")"
                             style="width:110px;height:110px;border-radius:50%;object-fit:cover;border:3px solid var(--rm-border);" />
                    </div>

                    <input asp-for="NewProfileImage"
                           id="NewProfileImage"
                           type="file"
                           class="d-none"
                           accept="image/*"
                           onchange="previewAvatar(this)" />
                    <input type="hidden" id="removeProfileImageHidden" name="RemoveProfileImage" value="false" />
                    <span asp-validation-for="NewProfileImage" class="rm-field-error mb-2"></span>

                    <!-- Avatar actions -->
                    <div style="display:flex;gap:6px;flex-wrap:wrap;justify-content:center;margin-bottom:20px;">
                        <button type="button" class="btn-rm-secondary" style="font-size:0.78rem;padding:6px 12px;"
                                onclick="document.getElementById('NewProfileImage').click()">
                            <i class="bi bi-upload"></i> Încarcă
                        </button>
                        @if (!string.IsNullOrEmpty(Model.ExistingProfileImagePath))
                        {
                            <a href="@Model.ExistingProfileImagePath" target="_blank"
                                   class="btn-rm-secondary" style="font-size:0.78rem;padding:6px 12px;">
                                <i class="bi bi-eye"></i> Vizualizează
                            </a>
                            <button type="button" id="removeBtn"
                                    class="btn-rm-outline btn-rm-outline-danger"
                                    style="font-size:0.78rem;padding:6px 12px;"
                                    onclick="toggleRemoveImage(this)">
                                <i class="bi bi-trash"></i> Șterge
                            </button>
                        }
                    </div>

                    <h5 style="font-weight:700;margin-bottom:0;font-size:1rem;">@Model.FirstName @Model.LastName</h5>

                    <div style="width:100%;border-top:1px solid var(--rm-border);margin:20px 0;"></div>

                    <!-- Fields -->
                    <div style="width:100%;text-align:left;">
                        <div class="rm-field mb-3">
                            <label asp-for="FirstName" class="rm-label"></label>
                            <input asp-for="FirstName" class="rm-input" />
                            <span asp-validation-for="FirstName" class="rm-field-error"></span>
                        </div>
                        <div class="rm-field mb-3">
                            <label asp-for="LastName" class="rm-label"></label>
                            <input asp-for="LastName" class="rm-input" />
                            <span asp-validation-for="LastName" class="rm-field-error"></span>
                        </div>
                        <div class="rm-field">
                            <label asp-for="Email" class="rm-label"></label>
                            <input asp-for="Email" class="rm-input" />
                            <span asp-validation-for="Email" class="rm-field-error"></span>
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <!-- RIGHT: Change Password -->
        <div class="rm-two-col-side">
            <div class="rm-form-card mb-4">
                <div class="rm-form-card-header">
                    <i class="bi bi-lock" style="color:var(--rm-red);"></i>
                    Schimbă Parola
                </div>
                <div class="rm-form-card-body">
                    <div class="rm-info-notice mb-4">
                        <i class="bi bi-info-circle-fill"></i>
                        Lasă aceste câmpuri goale dacă nu dorești să îți schimbi parola.
                    </div>

                    <div class="rm-field mb-3">
                        <label asp-for="CurrentPassword" class="rm-label"></label>
                        <div class="rm-password-field">
                            <input asp-for="CurrentPassword"
                                   type="password"
                                   id="currentPasswordField"
                                   class="rm-input"
                                   placeholder="Introdu parola curentă" />
                            <button type="button" class="rm-password-toggle toggle-password"
                                    data-target="currentPasswordField" tabindex="-1">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                    </div>

                    <div class="rm-field mb-3">
                        <label asp-for="NewPassword" class="rm-label"></label>
                        <div class="rm-password-field">
                            <input asp-for="NewPassword"
                                   type="password"
                                   id="newPasswordField"
                                   class="rm-input"
                                   placeholder="Introdu parola nouă" />
                            <button type="button" class="rm-password-toggle toggle-password"
                                    data-target="newPasswordField" tabindex="-1">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                    </div>

                    <div class="rm-field">
                        <label asp-for="ConfirmNewPassword" class="rm-label"></label>
                        <div class="rm-password-field">
                            <input asp-for="ConfirmNewPassword"
                                   type="password"
                                   id="confirmPasswordField"
                                   class="rm-input"
                                   placeholder="Confirmă parola nouă" />
                            <button type="button" class="rm-password-toggle toggle-password"
                                    data-target="confirmPasswordField" tabindex="-1">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Clinic Info -->
            @if (clinic != null)
            {
                <div class="rm-form-card mb-4">
                    <div class="rm-form-card-header">
                        <i class="bi bi-hospital" style="color:var(--rm-red);"></i>
                        Clinica Mea
                    </div>
                    <div class="rm-form-card-body">
                        <div style="display:flex;align-items:center;gap:14px;margin-bottom:16px;">
                            @if (!string.IsNullOrEmpty(clinic.ImagePath))
                            {
                                <img src="@clinic.ImagePath"
                                     style="width:52px;height:52px;border-radius:var(--rm-radius-sm);object-fit:cover;border:1px solid var(--rm-border);flex-shrink:0;" />
                            }
                            else
                            {
                                <div style="width:52px;height:52px;border-radius:var(--rm-radius-sm);background:#f5f5f5;border:1px solid var(--rm-border);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                    <i class="bi bi-hospital" style="color:#ccc;font-size:1.2rem;"></i>
                                </div>
                            }
                            <div>
                                <div style="font-weight:700;font-size:0.95rem;">@clinic.Name</div>
                                @if (!string.IsNullOrEmpty(clinic.City))
                                {
                                    <div style="font-size:0.8rem;color:var(--rm-text-muted);">
                                        @clinic.City@(!string.IsNullOrEmpty(clinic.Country) ? $", {clinic.Country}" : "")
                                    </div>
                                }
                            </div>
                        </div>
                        <div style="display:flex;flex-direction:column;gap:6px;font-size:0.85rem;color:var(--rm-text-muted);">
                            @if (!string.IsNullOrEmpty(clinic.Address))
                            {
                                <span><i class="bi bi-geo-alt me-2"></i>@clinic.Address</span>
                            }
                            @if (!string.IsNullOrEmpty(clinic.Phone))
                            {
                                <span><i class="bi bi-telephone me-2"></i>@clinic.Phone</span>
                            }
                            @if (!string.IsNullOrEmpty(clinic.Email))
                            {
                                <span><i class="bi bi-envelope me-2"></i>@clinic.Email</span>
                            }
                            @if (!string.IsNullOrEmpty(clinic.Website))
                            {
                                <span>
                                    <i class="bi bi-globe me-2"></i>
                                    <a href="@clinic.Website" target="_blank" style="color:var(--rm-red);text-decoration:none;">@clinic.Website</a>
                                </span>
                            }
                        </div>
                    </div>
                </div>
            }

            <!-- Work Schedule -->
            @if (isEmployee && schedules != null)
            {
                <div class="rm-form-card">
                    <div class="rm-form-card-header">
                        <i class="bi bi-calendar-week" style="color:var(--rm-red);"></i>
                        Programul Meu
                    </div>
                    <div class="rm-schedule-list">
                        @foreach (var day in order)
                        {
                            var dayShifts = schedules.Where(s => s.Day == day).ToList();
                            <div class="rm-schedule-row" style="@(!dayShifts.Any() ? "opacity:0.5;" : "")">
                                <div style="display:flex;align-items:center;justify-content:space-between;">
                                    <span class="rm-schedule-day-name" style="width:110px;flex-shrink:0;">@dayNames[day]</span>
                                    @if (!dayShifts.Any())
                                    {
                                        <span class="rm-badge">
                                            <i class="bi bi-moon" style="font-size:0.7rem;"></i> Zi liberă
                                        </span>
                                    }
                                    else
                                    {
                                        <div style="display:flex;flex-wrap:wrap;gap:6px;">
                                            @foreach (var shift in dayShifts)
                                            {
                                                <span class="rm-shift-badge">
                                                    <i class="bi bi-clock" style="font-size:0.7rem;"></i>
                                                    @shift.StartTime.ToString("HH:mm") — @shift.EndTime.ToString("HH:mm")
                                                </span>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

        </div>
    </div>

    <div class="d-flex justify-content-end mt-4">
        <button type="submit" class="btn-rm-primary">
            <i class="bi bi-save"></i> Salvează Modificările
        </button>
    </div>

</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function previewAvatar(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => document.getElementById('avatarPreview').src = e.target.result;
                reader.readAsDataURL(input.files[0]);
                document.getElementById('removeProfileImageHidden').value = 'false';
                const removeBtn = document.getElementById('removeBtn');
                if (removeBtn) removeBtn.innerHTML = '<i class="bi bi-trash"></i> Șterge';
            }
        }

        function toggleRemoveImage(btn) {
            const hidden = document.getElementById('removeProfileImageHidden');
            const preview = document.getElementById('avatarPreview');
            const fileInput = document.getElementById('NewProfileImage');
            const isRemoving = hidden.value === 'true';

            if (!isRemoving) {
                hidden.value = 'true';
                preview.src = '/required/NoProfileImage.jpg';
                fileInput.value = '';
                btn.innerHTML = '<i class="bi bi-arrow-counterclockwise"></i> Anulează';
                btn.classList.remove('btn-rm-outline-danger');
                btn.style.background = '#fef2f2';
            } else {
                hidden.value = 'false';
                preview.src = '@(Model.ExistingProfileImagePath ?? "/required/NoProfileImage.jpg")';
                btn.innerHTML = '<i class="bi bi-trash"></i> Șterge';
                btn.classList.add('btn-rm-outline-danger');
                btn.style.background = '';
            }
        }

        document.querySelectorAll('.toggle-password').forEach(btn => {
            btn.addEventListener('click', function () {
                const target = document.getElementById(this.dataset.target);
                target.type = target.type === 'password' ? 'text' : 'password';
                this.querySelector('i').classList.toggle('bi-eye');
                this.querySelector('i').classList.toggle('bi-eye-slash');
            });
        });
    </script>
}
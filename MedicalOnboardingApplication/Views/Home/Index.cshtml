@{
    ViewData["Title"] = "Bun venit";
    Layout = null; // standalone page, no nav
}

<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MedicalOnboarding</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
</head>
<body class="bg-light">

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold text-primary" href="/">
                <i class="bi bi-hospital me-2"></i>MedicalOnboarding
            </a>
            <div class="ms-auto d-flex gap-2">
                <a asp-controller="Account"
                       asp-action="Login"
                       class="btn btn-outline-primary">
                    <i class="bi bi-box-arrow-in-right me-1"></i> Autentificare
                </a>
                <a asp-controller="Account"
                       asp-action="RegisterClinicAdmin"
                       class="btn btn-primary">
                    <i class="bi bi-plus-circle me-1"></i> Înregistrare
                </a>
            </div>
        </div>
    </nav>

    <!-- HERO -->
    <section class="py-5">
        <div class="container">
            <div class="row align-items-center g-5">
                <div class="col-lg-6">
                    <h1 class="display-5 fw-bold mb-3">
                        Onboarding medical <span class="text-primary">simplu și eficient</span>
                    </h1>
                    <p class="lead text-muted mb-4">
                        Platformă dedicată clinicilor medicale pentru gestionarea cursurilor,
                        testelor adaptive și progresului angajaților.
                    </p>
                    <div class="d-flex gap-3">
                        <a asp-controller="Account"
                               asp-action="RegisterClinicAdmin"
                               class="btn btn-primary btn-lg px-4">
                            <i class="bi bi-rocket me-2"></i> Începe Acum
                        </a>
                        <a asp-controller="Account"
                               asp-action="Login"
                               class="btn btn-outline-secondary btn-lg px-4">
                            Autentificare
                        </a>
                    </div>
                </div>
                <div class="col-lg-6 text-center">
                    <div class="bg-primary bg-opacity-10 rounded-4 p-5">
                        <i class="bi bi-hospital text-primary" style="font-size: 8rem;"></i>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- FEATURES -->
    <section class="py-5 bg-white">
        <div class="container">
            <h2 class="text-center fw-bold mb-5">De ce MedicalOnboarding?</h2>
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm h-100 text-center p-4">
                        <i class="bi bi-book text-primary mb-3" style="font-size: 2.5rem;"></i>
                        <h5 class="fw-semibold">Cursuri Structurate</h5>
                        <p class="text-muted">
                            Organizează cursurile pe capitole cu atașamente, videoclipuri și documente PDF.
                        </p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm h-100 text-center p-4">
                        <i class="bi bi-graph-up text-primary mb-3" style="font-size: 2.5rem;"></i>
                        <h5 class="fw-semibold">Teste Adaptive</h5>
                        <p class="text-muted">
                            Sistem de testare care se adaptează automat la nivelul fiecărui angajat.
                        </p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm h-100 text-center p-4">
                        <i class="bi bi-people text-primary mb-3" style="font-size: 2.5rem;"></i>
                        <h5 class="fw-semibold">Rapoarte Detaliate</h5>
                        <p class="text-muted">
                            Monitorizează progresul angajaților și conformitatea cu cerințele clinicii.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- FOOTER -->
    <footer class="py-4 bg-white border-top mt-5">
        <div class="container text-center text-muted small">
            © @DateTime.Now.Year MedicalOnboarding. Toate drepturile rezervate.
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
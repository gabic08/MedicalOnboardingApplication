@{
    ViewData["Title"] = "Email Trimis";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4 text-center">

                <div class="bg-success bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                     style="width: 70px; height: 70px;">
                    <i class="bi bi-envelope-check fs-2 text-success"></i>
                </div>

                <h4 class="fw-semibold mb-2">Verifică emailul</h4>
                <p class="text-muted">
                    Dacă există un cont asociat acestei adrese, vei primi un email cu instrucțiuni pentru resetarea parolei.
                </p>

                <a asp-action="Login" class="btn btn-outline-primary mt-2">
                    <i class="bi bi-arrow-left me-1"></i> Înapoi la Autentificare
                </a>

            </div>
        </div>
    </div>
</div>
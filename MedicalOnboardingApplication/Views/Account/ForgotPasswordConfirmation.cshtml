@{
    ViewData["Title"] = "Email Trimis";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="auth-card" style="text-align: center;">

    <div style="display: inline-flex; align-items: center; justify-content: center;
        width: 72px; height: 72px; background: #fff0f3;
        border-radius: 50%; margin-bottom: 20px;">
        <i class="bi bi-envelope-check" style="font-size: 2rem; color: #e8607a;"></i>
    </div>

    <h2>Verifică emailul</h2>

    <p style="color: #888; font-size: 0.95rem; margin-bottom: 32px; line-height: 1.6;">
        Dacă există un cont asociat acestei adrese, vei primi un email
        cu instrucțiuni pentru resetarea parolei.
    </p>

    <a asp-action="Login" class="btn-auth" style="display: block; text-decoration: none; text-align: center;">
        ← Înapoi la Autentificare
    </a>

</div>
@model MedicalOnboardingApplication.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Ai uitat parola?";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="auth-card">
    <h2>Ai uitat parola?</h2>
    <p style="text-align: center; color: #888; font-size: 0.9rem; margin-bottom: 24px;">
        Introdu adresa de email și îți vom trimite un link de resetare.
    </p>

    <form asp-action="ForgotPassword" method="post">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <input asp-for="Email"
               class="form-input"
               placeholder="E-mail"
               autofocus />
        <span asp-validation-for="Email" class="text-danger d-block mb-2"></span>

        <button type="submit" class="btn-auth">
            Trimite Link de Resetare
        </button>

        <div class="auth-link">
            <a asp-action="Login">
                ← Înapoi la Autentificare
            </a>
        </div>

    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
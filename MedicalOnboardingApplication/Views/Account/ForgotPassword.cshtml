@model MedicalOnboardingApplication.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Ai uitat parola?";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">

                <div class="text-center mb-4">
                    <div class="bg-primary bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                         style="width: 70px; height: 70px;">
                        <i class="bi bi-lock fs-2 text-primary"></i>
                    </div>
                    <h4 class="fw-semibold mb-1">Ai uitat parola?</h4>
                    <p class="text-muted small">
                        Introdu adresa de email și îți vom trimite un link de resetare.
                    </p>
                </div>

                <form asp-action="ForgotPassword" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold"></label>
                        <input asp-for="Email"
                               class="form-control"
                               placeholder="exemplu@email.com"
                               autofocus />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-send me-1"></i> Trimite Link de Resetare
                    </button>
                </form>

                <div class="text-center mt-3">
                    <a asp-action="Login" class="text-decoration-none small">
                        <i class="bi bi-arrow-left me-1"></i> Înapoi la Autentificare
                    </a>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
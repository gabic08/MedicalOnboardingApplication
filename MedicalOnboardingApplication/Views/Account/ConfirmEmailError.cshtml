@{
    ViewData["Title"] = "Eroare Confirmare";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4 text-center">

                <div class="bg-danger bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                     style="width: 70px; height: 70px;">
                    <i class="bi bi-x-circle fs-2 text-danger"></i>
                </div>

                <h4 class="fw-semibold mb-2">Confirmare eșuată</h4>
                <p class="text-muted">
                    Link-ul de confirmare este invalid sau a expirat. Te rugăm să soliciți un nou email.
                </p>

                <a asp-action="Login" class="btn btn-outline-primary mt-2">
                    Înapoi la Autentificare
                </a>

            </div>
        </div>
    </div>
</div>
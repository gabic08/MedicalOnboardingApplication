@using MedicalOnboardingApplication.ViewModels
@model RegisterAdminViewModel

@{
    ViewData["Title"] = "Register Admin";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-body">
                <h4 class="mb-3 text-center">Register Admin</h4>

                <form method="post" novalidate>
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="ReturnUrl" />
                    <div asp-validation-summary="ModelOnly"
                         class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="FirstName" class="form-label"></label>
                        <input asp-for="FirstName" class="form-control" />
                        <span asp-validation-for="FirstName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="LastName" class="form-label"></label>
                        <input asp-for="LastName" class="form-control" />
                        <span asp-validation-for="LastName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3 d-flex align-items-center">
                        <input asp-for="Password"
                               id="passwordField"
                               class="form-control"
                               type="password"
                               autocomplete="new-password" />

                        <label asp-for="Password"></label>

                        <button type="button"
                                class="btn btn-sm toggle-password"
                                data-target="passwordField"
                                tabindex="-1">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>

                    <span asp-validation-for="Password" class="text-danger"></span>


                    <div class="form-floating mb-3 d-flex align-items-center">
                        <input asp-for="ConfirmPassword" id="confirmPasswordField" class="form-control" type="password" autocomplete="new-password" />

                        <label asp-for="ConfirmPassword"></label>

                        <button type="button"
                                class="btn btn-sm toggle-password"
                                data-target="confirmPasswordField"
                                tabindex="-1">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>

                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>

                    <button class="btn btn-success w-100" type="submit">
                        Create Admin Account
                    </button>
                    <div class="text-center mt-3">
                        <a asp-controller="Account"
                           asp-action="Login"
                           asp-route-returnUrl="@Model.ReturnUrl"
                           class="btn btn-link text-decoration-none">
                            ← Back to Login
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        $(document).ready(function () {
            $('.toggle-password').on('click', function () {
                const target = $('#' + $(this).data('target'));
                const type = target.attr('type') === 'password' ? 'text' : 'password';
                target.attr('type', type);

                $(this).find('i')
                       .toggleClass('fa-eye')
                       .toggleClass('fa-eye-slash');
            });
        });
    </script>
}

@using MedicalOnboardingApplication.ViewModels
@model RegisterAdminViewModel
@{
    ViewData["Title"] = "Înregistrare Administrator";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="auth-card">
    <h2>Creare Cont Administrator</h2>

    <form method="post" novalidate>
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ReturnUrl" />

        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 14px;">
            <div>
                <input asp-for="FirstName"
                       class="form-input"
                       placeholder="Prenume"
                       style="margin-bottom: 0;" />
                <span asp-validation-for="FirstName" class="text-danger d-block mt-1"></span>
            </div>
            <div>
                <input asp-for="LastName"
                       class="form-input"
                       placeholder="Nume"
                       style="margin-bottom: 0;" />
                <span asp-validation-for="LastName" class="text-danger d-block mt-1"></span>
            </div>
        </div>

        <input asp-for="Email"
               class="form-input"
               placeholder="E-mail"
               autocomplete="email" />
        <span asp-validation-for="Email" class="text-danger d-block mb-2"></span>

        <input asp-for="ClinicName"
               class="form-input"
               placeholder="Numele clinicii (ex: Clinica Dr. Popescu)" />
        <span asp-validation-for="ClinicName" class="text-danger d-block mb-2"></span>

        <div style="display: flex; margin-bottom: 4px;">
            <input asp-for="Subdomain"
                   class="form-input"
                   placeholder="Subdomeniu (ex: clinica-popescu)"
                   style="margin-bottom: 0; border-radius: 8px 0 0 8px; border-right: none;"
                   oninput="this.value = this.value.toLowerCase().replace(/[^a-z0-9-]/g, '')" />
            <span style="display: flex; align-items: center; padding: 0 14px; background: #f5f5f5; border: 1.5px solid #e0e0e0; border-left: none; border-radius: 0 8px 8px 0; font-size: 0.82rem; color: #888; white-space: nowrap;">
                .@ViewBag.BaseDomain:@ViewBag.BasePort
            </span>
        </div>
        <span asp-validation-for="Subdomain" class="text-danger d-block mb-1"></span>
        <small class="d-block mb-3" style="color: #aaa; font-size: 0.78rem;">Doar litere mici, cifre și cratime.</small>

        <div class="password-wrapper">
            <input asp-for="Password"
                   id="passwordField"
                   class="form-input"
                   type="password"
                   placeholder="Parolă"
                   autocomplete="new-password"
                   style="margin-bottom: 0;" />
            <button type="button" class="toggle-pwd" id="togglePwd">
                <i class="bi bi-eye" id="toggleIcon"></i>
            </button>
        </div>
        <span asp-validation-for="Password" class="text-danger d-block mb-2"></span>

        <div class="password-wrapper">
            <input asp-for="ConfirmPassword"
                   id="confirmPasswordField"
                   class="form-input"
                   type="password"
                   placeholder="Confirmă parola"
                   autocomplete="new-password"
                   style="margin-bottom: 0;" />
            <button type="button" class="toggle-pwd" id="toggleConfirmPwd">
                <i class="bi bi-eye" id="toggleConfirmIcon"></i>
            </button>
        </div>
        <span asp-validation-for="ConfirmPassword" class="text-danger d-block mb-2"></span>

        <button type="submit" class="btn-auth" style="margin-top: 8px;">
            Creare Cont Administrator
        </button>

        <div class="auth-link">
            Ai deja un cont?
            <a asp-controller="Account"
                   asp-action="Login"
                   asp-route-returnUrl="@Model.ReturnUrl">
                Autentifică-te
            </a>
        </div>

    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('togglePwd').addEventListener('click', function () {
            const field = document.getElementById('passwordField');
            const icon = document.getElementById('toggleIcon');
            field.type = field.type === 'password' ? 'text' : 'password';
            icon.classList.toggle('bi-eye');
            icon.classList.toggle('bi-eye-slash');
        });

        document.getElementById('toggleConfirmPwd').addEventListener('click', function () {
            const field = document.getElementById('confirmPasswordField');
            const icon = document.getElementById('toggleConfirmIcon');
            field.type = field.type === 'password' ? 'text' : 'password';
            icon.classList.toggle('bi-eye');
            icon.classList.toggle('bi-eye-slash');
        });
    </script>
}

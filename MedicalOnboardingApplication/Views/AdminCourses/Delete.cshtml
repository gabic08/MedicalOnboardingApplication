@model MedicalOnboardingApplication.Models.Course

@{
    ViewData["Title"] = "Delete Course";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Delete Course</h1>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Back to Courses
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm border-danger">
            <div class="card-body">
                <div class="alert alert-danger">
                    <h5 class="mb-3"><i class="bi bi-exclamation-triangle-fill"></i> Are you sure you want to delete this course?</h5>
                </div>

                <dl class="row mb-4">
                    <dt class="col-sm-3">Title</dt>
                    <dd class="col-sm-9">@Model.Title</dd>

                    <dt class="col-sm-3">Description</dt>
                    <dd class="col-sm-9">@Model.Description</dd>

                    <dt class="col-sm-3">Order</dt>
                    <dd class="col-sm-9">@Model.Order</dd>
                </dl>

                <form asp-action="Delete" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />

                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            Cancel
                        </a>

                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash-fill"></i> Delete Course
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

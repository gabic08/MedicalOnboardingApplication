@model CourseViewModel
@using MedicalOnboardingApplication.Enums
@using MedicalOnboardingApplication.Models
@using MedicalOnboardingApplication.ViewModels
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Gestionare Curs";
    var course = ViewBag.Course as Course;
    var isPublished = course?.Status == CourseStatus.Published;
}

<!-- Page Header -->
<div class="rm-page-header">
    <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
        <div>
            <div class="breadcrumb-label">
                <a asp-controller="Admin" asp-action="Index" class="text-decoration-none" style="color:inherit;">Panou Admin</a>
                <i class="bi bi-chevron-right mx-1" style="font-size:0.65rem;"></i>
                <a asp-controller="AdminCourses" asp-action="Index" class="text-decoration-none" style="color:inherit;">Cursuri</a>
                <i class="bi bi-chevron-right mx-1" style="font-size:0.65rem;"></i>
                Gestionare
            </div>
            <a asp-controller="AdminCourses"
               asp-action="Index"
               class="btn btn-outline-secondary btn-rm-back mb-2"
               style="color:var(--rm-red);border-color:var(--rm-red);">
                <i class="bi bi-arrow-left"></i> Înapoi la Cursuri
            </a>
            <h1>@course.Title</h1>
            <p>Editează detaliile, capitolele și întrebările cursului</p>
        </div>
        <div class="d-flex align-items-center gap-2 align-self-end flex-wrap">
            @if (isPublished)
            {
                <span class="rm-badge" style="background:var(--rm-green-light,#e6f4ea);color:#1a7f37;font-weight:600;font-size:0.85rem;padding:6px 12px;">
                    <i class="bi bi-check-circle-fill"></i> Publicat — doar citire
                </span>
            }
            else
            {
                <span class="rm-badge" style="background:#fff3cd;color:#856404;font-weight:600;font-size:0.85rem;padding:6px 12px;">
                    <i class="bi bi-pencil-fill"></i> Ciornă
                </span>
                <span style="font-size:0.8rem;color:var(--rm-text-muted);"><i class="bi bi-eye-slash me-1"></i>Doar tu poți vedea acest curs până când este publicat.</span>
                <form action="/AdminCourses/Publish/@course.Id" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-rm-success"
                            onclick="return confirm('Ești sigur că vrei să publici cursul \'@course.Title\'?\n\nDupă publicare, cursul nu mai poate fi editat. Capitolele, întrebările și tipurile de angajați vor rămâne fixate.');">
                        <i class="bi bi-send-fill"></i> Publică Cursul
                    </button>
                </form>
                <form asp-controller="AdminCourses" asp-action="Delete" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@course.Id" />
                    <button type="submit" class="btn-rm-danger"
                            onclick="return confirm('Ești sigur că vrei să ștergi cursul \'@course.Title\'?\n\nAceasta va șterge și toate capitolele, atașamentele și întrebările.\nAceastă acțiune nu poate fi anulată.');">
                        <i class="bi bi-trash"></i> Șterge Cursul
                    </button>
                </form>
            }
        </div>
    </div>
</div>

@if (TempData["Error"] != null)
{
    <div class="rm-alert rm-alert-error mb-4">
        <i class="bi bi-exclamation-triangle-fill"></i>
        @TempData["Error"]
    </div>
}

<!-- ===================== -->
<!-- COURSE EDIT FORM -->
<!-- ===================== -->
<div class="rm-form-card mb-4">
    <div class="rm-form-card-header">
        <i class="bi bi-pencil-square" style="color:var(--rm-red);"></i>
        Detalii Curs
    </div>
    <div class="rm-form-card-body">
        @if (isPublished)
        {
            <div class="rm-modal-warning mb-4" style="background:#e6f4ea;border-color:#1a7f37;color:#1a7f37;">
                <i class="bi bi-lock-fill"></i>
                Cursul este publicat și nu mai poate fi editat.
            </div>

            <!-- Read-only display when published — no form needed -->
            <div class="row g-3 mb-4">
                <div class="col-md-5">
                    <div class="rm-field">
                        <label class="rm-label">Title</label>
                        <input class="rm-input" value="@course.Title" readonly />
                    </div>
                </div>
                <div class="col-md-5">
                    <div class="rm-field">
                        <label class="rm-label">Description</label>
                        <input class="rm-input" value="@course.Description" readonly />
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="rm-field">
                        <label class="rm-label">Order</label>
                        <input class="rm-input" value="@course.Order" readonly />
                    </div>
                </div>
            </div>

            <div class="mb-4">
                <p class="rm-section-sublabel">
                    <i class="bi bi-people me-1"></i> Tipuri de Angajați
                </p>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var et in Model.EmployeeTypes.Where(e => e.IsSelected))
                    {
                        <span class="rm-toggle-btn active" style="opacity:0.7;cursor:default;">
                            <i class="bi bi-person-badge"></i>
                            @et.Name
                        </span>
                    }
                </div>
            </div>
        }
        else
        {
            <form asp-controller="AdminCourses" asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                @if (ViewData.ModelState.ErrorCount > 0)
                {
                    <div class="rm-alert rm-alert-error mb-4">
                        <i class="bi bi-exclamation-circle-fill"></i>
                        <div asp-validation-summary="ModelOnly"></div>
                    </div>
                }

                <div class="row g-3 mb-4">
                    <div class="col-md-5">
                        <div class="rm-field">
                            <label asp-for="Title" class="rm-label"></label>
                            <input asp-for="Title" class="rm-input" />
                            <span asp-validation-for="Title" class="rm-field-error"></span>
                        </div>
                    </div>
                    <div class="col-md-5">
                        <div class="rm-field">
                            <label asp-for="Description" class="rm-label"></label>
                            <input asp-for="Description" class="rm-input" />
                            <span asp-validation-for="Description" class="rm-field-error"></span>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="rm-field">
                            <label asp-for="Order" class="rm-label"></label>
                            <input asp-for="Order" class="rm-input" />
                            <span asp-validation-for="Order" class="rm-field-error"></span>
                        </div>
                    </div>
                </div>

                <div class="mb-4">
                    <p class="rm-section-sublabel">
                        <i class="bi bi-people me-1"></i> Tipuri de Angajați
                    </p>
                    <div class="d-flex flex-wrap gap-2" id="employeeTypeContainer">
                        @for (int i = 0; i < Model.EmployeeTypes.Count; i++)
                        {
                            var checkId = $"empType_{i}";
                            <div>
                                <input type="checkbox"
                                       class="rm-btn-check emp-type-check"
                                       asp-for="EmployeeTypes[i].IsSelected"
                                       id="@checkId"
                                       autocomplete="off" />
                                <label class="rm-toggle-btn" for="@checkId">
                                    <i class="bi bi-person-badge"></i>
                                    @Model.EmployeeTypes[i].Name
                                </label>
                                <input type="hidden" asp-for="EmployeeTypes[i].Id" />
                                <input type="hidden" asp-for="EmployeeTypes[i].Name" />
                            </div>
                        }
                    </div>
                </div>

                <div class="d-flex justify-content-end">
                    <button type="submit" class="btn-rm-primary">
                        <i class="bi bi-save"></i> Salvează Modificările
                    </button>
                </div>
            </form>
        }
    </div>
</div>

<!-- ===================== -->
<!-- CHAPTERS SECTION -->
<!-- ===================== -->
<div class="rm-form-card mb-4">
    <div class="rm-form-card-header" style="justify-content:space-between;">
        <div style="display:flex;align-items:center;gap:8px;">
            <i class="bi bi-journals" style="color:#16a34a;"></i>
            Capitole
            <span class="rm-count-badge rm-count-green">@(course.Chapters?.Count ?? 0)</span>
        </div>
        @if (!isPublished)
        {
            <a asp-controller="Chapters"
               asp-action="Create"
               asp-route-courseId="@course.Id"
               class="btn-rm-success" style="font-size:0.78rem;padding:6px 14px;">
                <i class="bi bi-plus-lg"></i> Adaugă Capitol
            </a>
        }
    </div>
    <div class="rm-form-card-body">
        @if (course.Chapters == null || !course.Chapters.Any())
        {
            <div class="rm-empty-state">
                <i class="bi bi-journal-x"></i>
                <p>Niciun capitol adăugat. Adaugă primul capitol pentru a începe.</p>
            </div>
        }
        else
        {
            <div class="accordion rm-accordion" id="chaptersAccordion">
                @foreach (var chapter in course.Chapters.OrderBy(c => c.Order))
                {
                    var collapseId = $"collapse_{chapter.Id}";
                    var previewLength = 1000;
                    var content = chapter.Content ?? "";
                    var shortText = content.Length > previewLength ? content.Substring(0, previewLength) + "..." : content;
                    var needsToggle = content.Length > previewLength;
                    var baseId = $"content_{chapter.Id}";

                    <div class="rm-accordion-item">
                        <button class="rm-accordion-btn collapsed"
                                type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#@collapseId">
                            <span class="rm-badge rm-badge-order">@chapter.Order</span>
                            <span class="rm-accordion-title">@chapter.Title</span>
                            <i class="bi bi-chevron-down rm-accordion-chevron ms-auto"></i>
                        </button>
                        <div id="@collapseId" class="accordion-collapse collapse">
                            <div class="rm-accordion-body">
                                <p style="font-size:0.875rem;color:var(--rm-text-muted);margin-bottom:16px;">
                                    <span id="@(baseId)_short">@shortText</span>
                                    @if (needsToggle)
                                    {
                                        <span id="@(baseId)_full" class="d-none">@content</span>
                                        <a href="javascript:void(0)" class="rm-text-link ms-2"
                                           onclick="toggleContent('@baseId', this)">Vezi mai mult</a>
                                    }
                                </p>

                                @if (!isPublished)
                                {
                                    <div class="d-flex gap-2 mb-4">
                                        <a asp-controller="Chapters"
                                           asp-action="Edit"
                                           asp-route-id="@chapter.Id"
                                           class="btn-rm-outline">
                                            <i class="bi bi-pencil"></i> Editează
                                        </a>
                                        <form asp-controller="Chapters" asp-action="Delete" method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@chapter.Id" />
                                            <button type="submit"
                                                    class="btn-rm-outline btn-rm-outline-danger"
                                                    onclick="return confirm('Ești sigur că vrei să ștergi capitolul \'@chapter.Title\'? Această acțiune nu poate fi anulată.');">
                                                <i class="bi bi-trash"></i> Șterge
                                            </button>
                                        </form>
                                    </div>
                                }

                                @if (chapter.Attachments != null && chapter.Attachments.Any())
                                {
                                    <p class="rm-section-sublabel"><i class="bi bi-paperclip me-1"></i> Atașamente</p>
                                    <div class="rm-attachments-list">
                                        @foreach (var att in chapter.Attachments)
                                        {
                                            <div class="rm-attachment-item">
                                                <div class="d-flex align-items-center gap-2">
                                                    @if (att.Type == AttachmentType.Image)
                                                    {
                                                        <i class="bi bi-image" style="color:#0ea5e9;"></i>
                                                    }
                                                    else if (att.Type == AttachmentType.Video)
                                                    {
                                                        <i class="bi bi-camera-video" style="color:#f59e0b;"></i>
                                                    }
                                                    else if (att.Type == AttachmentType.Pdf)
                                                    {
                                                        <i class="bi bi-file-earmark-pdf" style="color:var(--rm-red);"></i>
                                                    }
                                                    <span style="font-size:0.85rem;max-width:240px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                                                        @att.FileName
                                                    </span>
                                                </div>
                                                <a href="@att.FilePath" target="_blank" class="btn-rm-outline" style="font-size:0.78rem;padding:5px 12px;">
                                                    <i class="bi bi-box-arrow-up-right"></i> Deschide
                                                </a>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <p style="font-size:0.85rem;color:var(--rm-text-muted);margin:0;">
                                        <i class="bi bi-paperclip me-1"></i> Niciun atașament
                                    </p>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<!-- ===================== -->
<!-- QUESTIONS SECTION -->
<!-- ===================== -->
<div class="rm-form-card mb-4">
    <div class="rm-form-card-header" style="justify-content:space-between;">
        <div style="display:flex;align-items:center;gap:8px;">
            <i class="bi bi-patch-question" style="color:#f59e0b;"></i>
            Întrebări
            <span class="rm-count-badge rm-count-yellow">@(course.Questions?.Count ?? 0)</span>
        </div>
        @if (!isPublished)
        {
            <a asp-controller="Questions"
               asp-action="Create"
               asp-route-courseId="@course.Id"
               class="btn-rm-warning" style="font-size:0.78rem;padding:6px 14px;">
                <i class="bi bi-plus-lg"></i> Adaugă Întrebare
            </a>
        }
    </div>
    <div class="rm-form-card-body">
        @if (course.Questions == null || !course.Questions.Any())
        {
            <div class="rm-empty-state">
                <i class="bi bi-question-circle"></i>
                <p>Nicio întrebare adăugată încă.</p>
            </div>
        }
        else
        {
            <div class="accordion rm-accordion" id="questionsAccordion">
                @foreach (var q in course.Questions.OrderBy(q => q.Difficulty))
                {
                    var qCollapseId = $"qcollapse_{q.Id}";
                    <div class="rm-accordion-item">
                        <button class="rm-accordion-btn collapsed"
                                type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#@qCollapseId">
                            <div class="d-flex align-items-center gap-2 flex-grow-1 min-width-0">
                                <span class="rm-badge" style="white-space:nowrap;">
                                    <i class="bi bi-bar-chart" style="font-size:0.7rem;"></i> @Html.DisplayFor(_ => q.Difficulty)
                                </span>
                                <span class="rm-accordion-title">@q.Text</span>
                            </div>
                            <span style="font-size:0.75rem;color:var(--rm-text-muted);white-space:nowrap;margin-right:8px;">
                                <i class="bi bi-list-check me-1"></i>@(q.Answers?.Count ?? 0) răspunsuri
                            </span>
                            <i class="bi bi-chevron-down rm-accordion-chevron"></i>
                        </button>
                        <div id="@qCollapseId" class="accordion-collapse collapse">
                            <div class="rm-accordion-body">
                                @if (q.Answers != null && q.Answers.Any())
                                {
                                    <ul style="list-style:none;padding:0;margin:0 0 12px 0;">
                                        @foreach (var a in q.Answers.OrderBy(a => a.Id))
                                        {
                                            <li style="display:flex;align-items:center;gap:8px;padding:5px 0;font-size:0.875rem;">
                                                @if (a.IsCorrect)
                                                {
                                                    <i class="bi bi-check-circle-fill" style="color:#16a34a;flex-shrink:0;"></i>
                                                    <span style="font-weight:600;color:#16a34a;">@a.Text</span>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-circle" style="color:#d1d5db;flex-shrink:0;"></i>
                                                    <span style="color:var(--rm-text-muted);">@a.Text</span>
                                                }
                                            </li>
                                        }
                                    </ul>
                                }
                                @if (!isPublished)
                                {
                                    <div class="d-flex gap-2">
                                        <a asp-controller="Questions"
                                           asp-action="Edit"
                                           asp-route-id="@q.Id"
                                           class="btn-rm-outline">
                                            <i class="bi bi-pencil"></i> Editează
                                        </a>
                                        <form asp-controller="Questions" asp-action="Delete" method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@q.Id" />
                                            <input type="hidden" name="courseId" value="@course.Id" />
                                            <button type="submit"
                                                    class="btn-rm-outline btn-rm-outline-danger"
                                                    onclick="return confirm('Ești sigur că vrei să ștergi această întrebare? Această acțiune nu poate fi anulată.');">
                                                <i class="bi bi-trash"></i> Șterge
                                            </button>
                                        </form>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>




@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function toggleContent(id, link) {
            const shortEl = document.getElementById(id + "_short");
            const fullEl  = document.getElementById(id + "_full");
            if (fullEl.classList.contains("d-none")) {
                shortEl.classList.add("d-none");
                fullEl.classList.remove("d-none");
                link.innerText = "Vezi mai puțin";
            } else {
                fullEl.classList.add("d-none");
                shortEl.classList.remove("d-none");
                link.innerText = "Vezi mai mult";
            }
        }
    </script>
}

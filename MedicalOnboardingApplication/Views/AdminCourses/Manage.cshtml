@model MedicalOnboardingApplication.Models.CourseViewModel
@using MedicalOnboardingApplication.Data
@using MedicalOnboardingApplication.Models

@{
    ViewData["Title"] = "Manage Course";
    var course = ViewBag.Course as Course;
}

<h1 class="mb-4">Manage Course</h1>

<!-- COURSE EDIT FORM -->
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <h5 class="mb-3">Course Details</h5>

        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row">
                <div class="col-md-5 mb-3">
                    <label asp-for="Title" class="form-label"></label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="col-md-5 mb-3">
                    <label asp-for="Description" class="form-label"></label>
                    <input asp-for="Description" class="form-control" />
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="col-md-2 mb-3">
                    <label asp-for="Order" class="form-label"></label>
                    <input asp-for="Order" class="form-control" />
                    <span asp-validation-for="Order" class="text-danger"></span>
                </div>
            </div>

            <h6 class="mt-3">Assign to Employee Types</h6>

            <div class="row">
                @for (int i = 0; i < Model.EmployeeTypes.Count; i++)
                {
                    <div class="col-md-3 form-check">
                        <input asp-for="EmployeeTypes[i].IsSelected" class="form-check-input" />
                        <label class="form-check-label">
                            @Model.EmployeeTypes[i].Name
                        </label>
                        <input type="hidden" asp-for="EmployeeTypes[i].Id" />
                    </div>
                }
            </div>

            <div class="d-flex justify-content-end mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-save"></i> Save Course
                </button>
            </div>
        </form>
    </div>
</div>

<!-- CHAPTERS SECTION -->
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">Chapters</h5>

            <a asp-controller="Chapters"
               asp-action="Create"
               asp-route-courseId="@course.Id"
               class="btn btn-success btn-sm">
                <i class="bi bi-plus-circle"></i> Add Chapter
            </a>
        </div>

        @if (course.Chapters == null || !course.Chapters.Any())
        {
            <div class="alert alert-info">
                No chapters yet.
            </div>
        }
        else
        {
            <div class="accordion" id="chaptersAccordion">
                @foreach (var chapter in course.Chapters.OrderBy(c => c.Order))
                {
                    var collapseId = $"collapse_{chapter.Id}";

                    <div class="accordion-item mb-2">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed"
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#@collapseId">
                                <strong>@chapter.Order.</strong> @chapter.Title
                            </button>
                        </h2>

                        <div id="@collapseId" class="accordion-collapse collapse">
                            <div class="accordion-body">
                                <p>@chapter.Content</p>

                                <div class="mb-2">
                                    <a asp-controller="Chapters"
                                       asp-action="Edit"
                                       asp-route-id="@chapter.Id"
                                       class="btn btn-sm btn-outline-primary">
                                        Edit
                                    </a>

                                    <a asp-controller="Chapters"
                                       asp-action="Delete"
                                       asp-route-id="@chapter.Id"
                                       class="btn btn-sm btn-outline-danger">
                                        Delete
                                    </a>

                                    <a asp-controller="ChapterAttachments"
                                       asp-action="Create"
                                       asp-route-chapterId="@chapter.Id"
                                       class="btn btn-sm btn-outline-success">
                                        Add Attachment
                                    </a>
                                </div>

                                <h6 class="mt-3">Attachments</h6>

                                @if (chapter.Attachments == null || !chapter.Attachments.Any())
                                {
                                    <p class="text-muted">No attachments</p>
                                }
                                else
                                {
                                    <ul class="list-group list-group-flush">
                                        @foreach (var att in chapter.Attachments)
                                        {
                                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                                <span>
                                                    @if (att.Type == AttachmentType.Link)
                                                    {
                                                        @att.Url
                                                    }
                                                    else
                                                    {
                                                        @att.FileName
                                                    }
                                                </span>

                                                <a href="@(att.Type == AttachmentType.Link ? att.Url : att.FilePath)"
                                                   target="_blank"
                                                   class="btn btn-sm btn-outline-secondary">
                                                    Open
                                                </a>
                                            </li>
                                        }
                                    </ul>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<!-- TESTS SECTION -->
<div class="card shadow-sm">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">Tests</h5>

            <a asp-controller="Tests"
               asp-action="Create"
               asp-route-courseId="@course.Id"
               class="btn btn-warning btn-sm">
                <i class="bi bi-plus-circle"></i> Add Test
            </a>
        </div>

        @if (course.Tests == null || !course.Tests.Any())
        {
            <div class="alert alert-info">
                No tests yet.
            </div>
        }
        else
        {
            <div class="list-group">
                @foreach (var test in course.Tests)
                {
                    <div class="list-group-item d-flex justify-content-between align-items-center">
                        <div>
                            <strong>@test.Title</strong>
                            <div class="small text-muted">
                                Questions: @(test.Questions?.Count ?? 0)
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <a asp-controller="Tests"
                               asp-action="Details"
                               asp-route-id="@test.Id"
                               class="btn btn-sm btn-outline-primary">
                                View
                            </a>

                            <a asp-controller="Tests"
                               asp-action="Edit"
                               asp-route-id="@test.Id"
                               class="btn btn-sm btn-outline-secondary">
                                Edit
                            </a>

                            <a asp-controller="Tests"
                               asp-action="Delete"
                               asp-route-id="@test.Id"
                               class="btn btn-sm btn-outline-danger">
                                Delete
                            </a>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

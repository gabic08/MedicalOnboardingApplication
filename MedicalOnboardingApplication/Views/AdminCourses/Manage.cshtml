@model CourseViewModel
@using MedicalOnboardingApplication.Data
@using MedicalOnboardingApplication.Models
@using MedicalOnboardingApplication.ViewModels

@{
    ViewData["Title"] = "Manage Course";
    var course = ViewBag.Course as Course;
}

<div class="mb-4">
    <a asp-controller="AdminCourses" asp-action="Index" class="btn btn-outline-secondary mb-2">
        <i class="bi bi-arrow-left"></i> Back to Courses
    </a>
    <div class="d-flex justify-content-between align-items-center">
        <h1 class="mb-0">Manage Course</h1>
        <button type="button"
                class="btn btn-outline-danger"
                data-bs-toggle="modal"
                data-bs-target="#deleteCourseModal">
            <i class="bi bi-trash"></i> Delete Course
        </button>
    </div>
</div>

<!-- ===================== -->
<!-- COURSE EDIT FORM -->
<!-- ===================== -->
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <h5 class="mb-3">Course Details</h5>

        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row">
                <div class="col-md-5 mb-3">
                    <label asp-for="Title" class="form-label"></label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="col-md-5 mb-3">
                    <label asp-for="Description" class="form-label"></label>
                    <input asp-for="Description" class="form-control" />
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="col-md-2 mb-3">
                    <label asp-for="Order" class="form-label"></label>
                    <input asp-for="Order" class="form-control" />
                    <span asp-validation-for="Order" class="text-danger"></span>
                </div>
            </div>

            <h6 class="mt-3">Assign to Employee Types</h6>

            <div class="row">
                @for (int i = 0; i < Model.EmployeeTypes.Count; i++)
                {
                    <div class="col-md-3 form-check">
                        <input asp-for="EmployeeTypes[i].IsSelected" class="form-check-input" />
                        <label class="form-check-label">
                            @Model.EmployeeTypes[i].Name
                        </label>
                        <input type="hidden" asp-for="EmployeeTypes[i].Id" />
                    </div>
                }
            </div>

            <div class="d-flex justify-content-end mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-save"></i> Save Course
                </button>
            </div>
        </form>
    </div>
</div>

<!-- ===================== -->
<!-- CHAPTERS SECTION -->
<!-- ===================== -->
<div class="card shadow-sm mb-4">
    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">Chapters</h5>

            <a asp-controller="Chapters"
               asp-action="Create"
               asp-route-courseId="@course.Id"
               class="btn btn-success btn-sm">
                <i class="bi bi-plus-circle"></i> Add Chapter
            </a>
        </div>

        @if (course.Chapters == null || !course.Chapters.Any())
        {
            <div class="alert alert-info">
                No chapters yet.
            </div>
        }
        else
        {
            <div class="accordion" id="chaptersAccordion">
                @foreach (var chapter in course.Chapters.OrderBy(c => c.Order))
                {
                    var collapseId = $"collapse_{chapter.Id}";

                    var previewLength = 1000;
                    var content = chapter.Content ?? "";
                    var shortText = content.Length > previewLength
                    ? content.Substring(0, previewLength) + "..."
                    : content;

                    var needsToggle = content.Length > previewLength;

                    var baseId = $"content_{chapter.Id}";
                    var shortId = baseId + "_short";
                    var fullId = baseId + "_full";

                    <div class="accordion-item mb-2">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed"
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#@collapseId">
                                <strong>@chapter.Order.</strong>&nbsp;@chapter.Title
                            </button>
                        </h2>

                        <div id="@collapseId" class="accordion-collapse collapse">
                            <div class="accordion-body">

                                <!-- Chapter Content -->
                                <p>
                                    <span id="@shortId">
                                        @shortText
                                    </span>

                                    @if (needsToggle)
                                    {
                                        <span id="@fullId" class="d-none">
                                            @content
                                        </span>

                                        <a href="javascript:void(0)"
                                           class="ms-2"
                                           onclick="toggleContent('@baseId', this)">
                                            See more
                                        </a>
                                    }
                                </p>

                                <a asp-controller="Chapters"
                                   asp-action="Edit"
                                   asp-route-id="@chapter.Id"
                                   class="btn btn-sm btn-outline-primary me-1">
                                    Edit
                                </a>

                                <button type="button"
                                        class="btn btn-sm btn-outline-danger"
                                        data-bs-toggle="modal"
                                        data-bs-target="#deleteChapterModal"
                                        data-chapter-id="@chapter.Id"
                                        data-chapter-title="@chapter.Title">
                                    Delete
                                </button>

                                <!-- Attachments -->
                                <h6 class="mt-3">Attachments</h6>

                                @if (chapter.Attachments == null || !chapter.Attachments.Any())
                                {
                                    <p class="text-muted">No attachments</p>
                                }
                                else
                                {
                                    <ul class="list-group list-group-flush">
                                        @foreach (var att in chapter.Attachments)
                                        {
                                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                                <div class="d-flex align-items-center gap-2">
                                                    @if (att.Type == AttachmentType.Image)
                                                    {
                                                        <i class="bi bi-image"></i>
                                                    }
                                                    else if (att.Type == AttachmentType.Video)
                                                    {
                                                        <i class="bi bi-camera-video"></i>
                                                    }
                                                    else if (att.Type == AttachmentType.Pdf)
                                                    {
                                                        <i class="bi bi-file-earmark-pdf"></i>
                                                    }

                                                    <span class="text-truncate" style="max-width: 220px;">
                                                        @att.FileName
                                                    </span>
                                                </div>

                                                <a href="@att.FilePath"
                                                   target="_blank"
                                                   class="btn btn-sm btn-outline-secondary">
                                                    Open
                                                </a>
                                            </li>
                                        }
                                    </ul>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

    </div>
</div>



<!-- ===================== -->
<!-- QUESTIONS SECTION -->
<!-- ===================== -->
<div class="card shadow-sm">
    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">Questions</h5>

            <a asp-controller="Questions"
               asp-action="Create"
               asp-route-courseId="@course.Id"
               class="btn btn-warning btn-sm">
                <i class="bi bi-plus-circle"></i> Add Question
            </a>
        </div>

        @if (course.Questions == null || !course.Questions.Any())
        {
            <div class="alert alert-info">
                No questions added yet.
            </div>
        }
        else
        {
            <div class="list-group">
                @foreach (var q in course.Questions.OrderBy(q => q.Difficulty))
                {
                    <div class="list-group-item d-flex justify-content-between align-items-center">
                        <div class="me-3">
                            <strong>@q.Text</strong>

                            <div class="small text-muted mt-1">
                                Difficulty:
                                <span class="badge bg-secondary">
                                    @q.Difficulty
                                </span>
                                • Answers: @(q.Answers?.Count ?? 0)
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <a asp-controller="Questions"
                               asp-action="Edit"
                               asp-route-id="@q.Id"
                               class="btn btn-sm btn-outline-primary">
                                Edit
                            </a>

                            <button type="button"
                                    class="btn btn-sm btn-outline-danger"
                                    data-bs-toggle="modal"
                                    data-bs-target="#deleteQuestionModal"
                                    data-question-id="@q.Id"
                                    data-question-text="@q.Text">
                                Delete
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>


<form id="deleteCourseForm"
      asp-controller="AdminCourses"
      asp-action="Delete"
      asp-route-id="@course.Id"
      method="post"
      class="d-none">
    @Html.AntiForgeryToken()
</form>

<form id="deleteChapterForm"
      asp-controller="Chapters"
      asp-action="DeleteConfirmed"
      method="post"
      class="d-none">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="deleteChapterId" />
</form>

<form id="deleteQuestionForm"
      asp-controller="Questions"
      asp-action="Delete"
      method="post"
      class="d-none">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="deleteQuestionId" />
</form>

<div class="modal fade" id="deleteQuestionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-danger">
                    <i class="bi bi-exclamation-triangle"></i>
                    Confirm Question Deletion
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete <strong id="deleteQuestionText"></strong>?</p>
                <div class="alert alert-warning mb-0">
                    This will also delete all answers associated with it.
                    This action cannot be undone.
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button"
                        class="btn btn-danger"
                        onclick="document.getElementById('deleteQuestionForm').submit();">
                    Yes, Delete
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade"
     id="deleteChapterModal"
     tabindex="-1"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title text-danger">
                    <i class="bi bi-exclamation-triangle"></i>
                    Confirm Chapter Deletion
                </h5>
                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <div class="modal-body">
                <p>
                    Are you sure you want to delete
                    <strong id="deleteChapterTitle"></strong>?
                </p>
                <div class="alert alert-warning mb-0">
                    This will also delete all attachments associated with it.
                    This action cannot be undone.
                </div>
            </div>

            <div class="modal-footer">
                <button type="button"
                        class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    Cancel
                </button>
                <button type="button"
                        class="btn btn-danger"
                        onclick="document.getElementById('deleteChapterForm').submit();">
                    Yes, Delete
                </button>
            </div>

        </div>
    </div>
</div>

<div class="modal fade"
     id="deleteCourseModal"
     tabindex="-1"
     aria-hidden="true">

    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title text-danger">
                    <i class="bi bi-exclamation-triangle"></i>
                    Confirm Course Deletion
                </h5>
                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <div class="modal-body">
                <p>
                    Are you sure you want to delete
                    <strong>@course.Title</strong>?
                </p>

                <div class="alert alert-warning mb-0">
                    This will also delete all chapters,
                    attachments, and questions associated with it.
                    This action cannot be undone.
                </div>
            </div>

            <div class="modal-footer">
                <button type="button"
                        class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    Cancel
                </button>

                <button type="button"
                        class="btn btn-danger"
                        onclick="document.getElementById('deleteCourseForm').submit();">
                    Yes, Delete
                </button>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function toggleContent(id, link) {
            const shortEl = document.getElementById(id + "_short");
            const fullEl = document.getElementById(id + "_full");
            if (fullEl.classList.contains("d-none")) {
                shortEl.classList.add("d-none");
                fullEl.classList.remove("d-none");
                link.innerText = "See less";
            } else {
                fullEl.classList.add("d-none");
                shortEl.classList.remove("d-none");
                link.innerText = "See more";
            }
        }

        document.getElementById('deleteChapterModal').addEventListener('show.bs.modal', function (e) {
            const btn = e.relatedTarget;
            document.getElementById('deleteChapterId').value = btn.getAttribute('data-chapter-id');
            document.getElementById('deleteChapterTitle').innerText = btn.getAttribute('data-chapter-title');
        });

        document.getElementById('deleteQuestionModal').addEventListener('show.bs.modal', function (e) {
            const btn = e.relatedTarget;
            document.getElementById('deleteQuestionId').value = btn.getAttribute('data-question-id');
            document.getElementById('deleteQuestionText').innerText = btn.getAttribute('data-question-text');
        });
    </script>
}

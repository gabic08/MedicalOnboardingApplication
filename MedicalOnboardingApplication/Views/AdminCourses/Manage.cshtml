@model CourseViewModel
@using MedicalOnboardingApplication.Enums
@using MedicalOnboardingApplication.Models
@using MedicalOnboardingApplication.ViewModels

@{
    ViewData["Title"] = "Gestionare Curs";
    var course = ViewBag.Course as Course;
}

<!-- Page Header -->
<div class="rm-page-header">
    <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
        <div>
            <div class="breadcrumb-label">
                <a asp-controller="Admin" asp-action="Index" class="text-decoration-none" style="color:inherit;">Panou Admin</a>
                <i class="bi bi-chevron-right mx-1" style="font-size:0.65rem;"></i>
                <a asp-controller="AdminCourses" asp-action="Index" class="text-decoration-none" style="color:inherit;">Cursuri</a>
                <i class="bi bi-chevron-right mx-1" style="font-size:0.65rem;"></i>
                Gestionare
            </div>
            <h1>@course.Title</h1>
            <p>Editează detaliile, capitolele și întrebările cursului</p>
        </div>
        <button type="button"
                class="btn-rm-danger align-self-end"
                data-bs-toggle="modal"
                data-bs-target="#deleteCourseModal">
            <i class="bi bi-trash"></i> Șterge Cursul
        </button>
    </div>
</div>

<!-- ===================== -->
<!-- COURSE EDIT FORM -->
<!-- ===================== -->
<div class="rm-form-card mb-4">
    <div class="rm-form-card-header">
        <i class="bi bi-pencil-square" style="color:var(--rm-red);"></i>
        Detalii Curs
    </div>
    <div class="rm-form-card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            @if (ViewData.ModelState.ErrorCount > 0)
            {
                <div class="rm-alert rm-alert-error mb-4">
                    <i class="bi bi-exclamation-circle-fill"></i>
                    <div asp-validation-summary="ModelOnly"></div>
                </div>
            }

            <div class="row g-3 mb-4">
                <div class="col-md-5">
                    <div class="rm-field">
                        <label asp-for="Title" class="rm-label"></label>
                        <input asp-for="Title" class="rm-input" />
                        <span asp-validation-for="Title" class="rm-field-error"></span>
                    </div>
                </div>
                <div class="col-md-5">
                    <div class="rm-field">
                        <label asp-for="Description" class="rm-label"></label>
                        <input asp-for="Description" class="rm-input" />
                        <span asp-validation-for="Description" class="rm-field-error"></span>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="rm-field">
                        <label asp-for="Order" class="rm-label"></label>
                        <input asp-for="Order" class="rm-input" />
                        <span asp-validation-for="Order" class="rm-field-error"></span>
                    </div>
                </div>
            </div>

            <div class="mb-4">
                <p class="rm-section-sublabel">
                    <i class="bi bi-people me-1"></i> Tipuri de Angajați
                </p>
                <div class="d-flex flex-wrap gap-2">
                    @for (int i = 0; i < Model.EmployeeTypes.Count; i++)
                    {
                        var checkId = $"empType_{i}";
                        <div>
                            <input type="checkbox"
                                   class="rm-btn-check"
                                   asp-for="EmployeeTypes[i].IsSelected"
                                   id="@checkId"
                                   autocomplete="off" />
                            <label class="rm-toggle-btn" for="@checkId">
                                <i class="bi bi-person-badge"></i>
                                @Model.EmployeeTypes[i].Name
                            </label>
                            <input type="hidden" asp-for="EmployeeTypes[i].Id" />
                        </div>
                    }
                </div>
            </div>

            <div class="d-flex justify-content-end">
                <button type="submit" class="btn-rm-primary">
                    <i class="bi bi-save"></i> Salvează Modificările
                </button>
            </div>
        </form>
    </div>
</div>

<!-- ===================== -->
<!-- CHAPTERS SECTION -->
<!-- ===================== -->
<div class="rm-form-card mb-4">
    <div class="rm-form-card-header" style="justify-content:space-between;">
        <div style="display:flex;align-items:center;gap:8px;">
            <i class="bi bi-journals" style="color:#16a34a;"></i>
            Capitole
            <span class="rm-count-badge rm-count-green">@(course.Chapters?.Count ?? 0)</span>
        </div>
        <a asp-controller="Chapters"
               asp-action="Create"
               asp-route-courseId="@course.Id"
               class="btn-rm-success" style="font-size:0.78rem;padding:6px 14px;">
            <i class="bi bi-plus-lg"></i> Adaugă Capitol
        </a>
    </div>
    <div class="rm-form-card-body">
        @if (course.Chapters == null || !course.Chapters.Any())
        {
            <div class="rm-empty-state">
                <i class="bi bi-journal-x"></i>
                <p>Niciun capitol adăugat. Adaugă primul capitol pentru a începe.</p>
            </div>
        }
        else
        {
            <div class="accordion rm-accordion" id="chaptersAccordion">
                @foreach (var chapter in course.Chapters.OrderBy(c => c.Order))
                {
                    var collapseId = $"collapse_{chapter.Id}";
                    var previewLength = 1000;
                    var content = chapter.Content ?? "";
                    var shortText = content.Length > previewLength ? content.Substring(0, previewLength) + "..." : content;
                    var needsToggle = content.Length > previewLength;
                    var baseId = $"content_{chapter.Id}";

                    <div class="rm-accordion-item">
                        <button class="rm-accordion-btn collapsed"
                                type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#@collapseId">
                            <span class="rm-badge rm-badge-order">@chapter.Order</span>
                            <span class="rm-accordion-title">@chapter.Title</span>
                            <i class="bi bi-chevron-down rm-accordion-chevron ms-auto"></i>
                        </button>
                        <div id="@collapseId" class="accordion-collapse collapse">
                            <div class="rm-accordion-body">
                                <p style="font-size:0.875rem;color:var(--rm-text-muted);margin-bottom:16px;">
                                    <span id="@(baseId)_short">@shortText</span>
                                    @if (needsToggle)
                                    {
                                        <span id="@(baseId)_full" class="d-none">@content</span>
                                        <a href="javascript:void(0)" class="rm-text-link ms-2"
                                           onclick="toggleContent('@baseId', this)">Vezi mai mult</a>
                                    }
                                </p>

                                <div class="d-flex gap-2 mb-4">
                                    <a asp-controller="Chapters"
                                           asp-action="Edit"
                                           asp-route-id="@chapter.Id"
                                           class="btn-rm-outline">
                                        <i class="bi bi-pencil"></i> Editează
                                    </a>
                                    <button type="button"
                                            class="btn-rm-outline btn-rm-outline-danger"
                                            data-bs-toggle="modal"
                                            data-bs-target="#deleteChapterModal"
                                            data-chapter-id="@chapter.Id"
                                            data-chapter-title="@chapter.Title">
                                        <i class="bi bi-trash"></i> Șterge
                                    </button>
                                </div>

                                @if (chapter.Attachments != null && chapter.Attachments.Any())
                                {
                                    <p class="rm-section-sublabel"><i class="bi bi-paperclip me-1"></i> Atașamente</p>
                                    <div class="rm-attachments-list">
                                        @foreach (var att in chapter.Attachments)
                                        {
                                            <div class="rm-attachment-item">
                                                <div class="d-flex align-items-center gap-2">
                                                    @if (att.Type == AttachmentType.Image)
                                                    {
                                                        <i class="bi bi-image" style="color:#0ea5e9;"></i>
                                                    }
                                                    else if (att.Type == AttachmentType.Video)
                                                    {
                                                        <i class="bi bi-camera-video" style="color:#f59e0b;"></i>
                                                    }
                                                    else if (att.Type == AttachmentType.Pdf)
                                                    {
                                                        <i class="bi bi-file-earmark-pdf" style="color:var(--rm-red);"></i>
                                                    }
                                                    <span style="font-size:0.85rem;max-width:240px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                                                        @att.FileName
                                                    </span>
                                                </div>
                                                <a href="@att.FilePath" target="_blank" class="btn-rm-outline" style="font-size:0.78rem;padding:5px 12px;">
                                                    <i class="bi bi-box-arrow-up-right"></i> Deschide
                                                </a>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <p style="font-size:0.85rem;color:var(--rm-text-muted);margin:0;">
                                        <i class="bi bi-paperclip me-1"></i> Niciun atașament
                                    </p>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<!-- ===================== -->
<!-- QUESTIONS SECTION -->
<!-- ===================== -->
<div class="rm-form-card mb-4">
    <div class="rm-form-card-header" style="justify-content:space-between;">
        <div style="display:flex;align-items:center;gap:8px;">
            <i class="bi bi-patch-question" style="color:#f59e0b;"></i>
            Întrebări
            <span class="rm-count-badge rm-count-yellow">@(course.Questions?.Count ?? 0)</span>
        </div>
        <a asp-controller="Questions"
               asp-action="Create"
               asp-route-courseId="@course.Id"
               class="btn-rm-warning" style="font-size:0.78rem;padding:6px 14px;">
            <i class="bi bi-plus-lg"></i> Adaugă Întrebare
        </a>
    </div>
    <div class="rm-form-card-body">
        @if (course.Questions == null || !course.Questions.Any())
        {
            <div class="rm-empty-state">
                <i class="bi bi-question-circle"></i>
                <p>Nicio întrebare adăugată încă.</p>
            </div>
        }
        else
        {
            <div class="rm-question-list">
                @foreach (var q in course.Questions.OrderBy(q => q.Difficulty))
                {
                    <div class="rm-question-item">
                        <div class="rm-question-body">
                            <p class="rm-question-text">@q.Text</p>
                            <div class="d-flex gap-2 align-items-center">
                                <span class="rm-badge">
                                    <i class="bi bi-bar-chart" style="font-size:0.7rem;"></i> @q.Difficulty
                                </span>
                                <span style="font-size:0.8rem;color:var(--rm-text-muted);">
                                    <i class="bi bi-list-check me-1"></i>@(q.Answers?.Count ?? 0) răspunsuri
                                </span>
                            </div>
                        </div>
                        <div class="d-flex gap-2 flex-shrink-0">
                            <a asp-controller="Questions"
                                   asp-action="Edit"
                                   asp-route-id="@q.Id"
                                   class="btn-rm-outline">
                                <i class="bi bi-pencil"></i> Editează
                            </a>
                            <button type="button"
                                    class="btn-rm-outline btn-rm-outline-danger"
                                    data-bs-toggle="modal"
                                    data-bs-target="#deleteQuestionModal"
                                    data-question-id="@q.Id"
                                    data-question-text="@q.Text"
                                    data-course-id="@course.Id">
                                <i class="bi bi-trash"></i> Șterge
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<!-- Hidden Forms -->
<form id="deleteCourseForm" asp-controller="AdminCourses" asp-action="Delete"
      asp-route-id="@course.Id" method="post" class="d-none">
    @Html.AntiForgeryToken()
</form>
<form id="deleteChapterForm" asp-controller="Chapters" asp-action="DeleteConfirmed"
      method="post" class="d-none">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="deleteChapterId" />
</form>
<form id="deleteQuestionForm" asp-controller="Questions" asp-action="Delete"
      method="post" class="d-none">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="deleteQuestionId" />
    <input type="hidden" name="courseId" id="deleteQuestionCourseId" />
</form>

<!-- Delete Question Modal -->
<div class="modal fade" id="deleteQuestionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="rm-modal-content">
            <div class="rm-modal-header">
                <div class="rm-modal-icon rm-modal-icon-danger">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                </div>
                <button type="button" class="rm-modal-close" data-bs-dismiss="modal">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="rm-modal-body">
                <h5 class="rm-modal-title">Șterge Întrebarea</h5>
                <p class="rm-modal-text">Ești sigur că vrei să ștergi <strong id="deleteQuestionText"></strong>?</p>
                <div class="rm-modal-warning">
                    <i class="bi bi-info-circle"></i>
                    Aceasta va șterge și toate răspunsurile. Această acțiune nu poate fi anulată.
                </div>
            </div>
            <div class="rm-modal-footer">
                <button type="button" class="btn-rm-secondary" data-bs-dismiss="modal">Anulează</button>
                <button type="button" class="btn-rm-danger"
                        onclick="document.getElementById('deleteQuestionForm').submit();">
                    <i class="bi bi-trash"></i> Da, Șterge
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Chapter Modal -->
<div class="modal fade" id="deleteChapterModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="rm-modal-content">
            <div class="rm-modal-header">
                <div class="rm-modal-icon rm-modal-icon-danger">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                </div>
                <button type="button" class="rm-modal-close" data-bs-dismiss="modal">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="rm-modal-body">
                <h5 class="rm-modal-title">Șterge Capitolul</h5>
                <p class="rm-modal-text">Ești sigur că vrei să ștergi <strong id="deleteChapterTitle"></strong>?</p>
                <div class="rm-modal-warning">
                    <i class="bi bi-info-circle"></i>
                    Aceasta va șterge și toate atașamentele. Această acțiune nu poate fi anulată.
                </div>
            </div>
            <div class="rm-modal-footer">
                <button type="button" class="btn-rm-secondary" data-bs-dismiss="modal">Anulează</button>
                <button type="button" class="btn-rm-danger"
                        onclick="document.getElementById('deleteChapterForm').submit();">
                    <i class="bi bi-trash"></i> Da, Șterge
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Course Modal -->
<div class="modal fade" id="deleteCourseModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="rm-modal-content">
            <div class="rm-modal-header">
                <div class="rm-modal-icon rm-modal-icon-danger">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                </div>
                <button type="button" class="rm-modal-close" data-bs-dismiss="modal">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="rm-modal-body">
                <h5 class="rm-modal-title">Șterge Cursul</h5>
                <p class="rm-modal-text">Ești sigur că vrei să ștergi <strong>@course.Title</strong>?</p>
                <div class="rm-modal-warning">
                    <i class="bi bi-info-circle"></i>
                    Aceasta va șterge și toate capitolele, atașamentele și întrebările. Această acțiune nu poate fi anulată.
                </div>
            </div>
            <div class="rm-modal-footer">
                <button type="button" class="btn-rm-secondary" data-bs-dismiss="modal">Anulează</button>
                <button type="button" class="btn-rm-danger"
                        onclick="document.getElementById('deleteCourseForm').submit();">
                    <i class="bi bi-trash"></i> Da, Șterge
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function toggleContent(id, link) {
            const shortEl = document.getElementById(id + "_short");
            const fullEl  = document.getElementById(id + "_full");
            if (fullEl.classList.contains("d-none")) {
                shortEl.classList.add("d-none");
                fullEl.classList.remove("d-none");
                link.innerText = "Vezi mai puțin";
            } else {
                fullEl.classList.add("d-none");
                shortEl.classList.remove("d-none");
                link.innerText = "Vezi mai mult";
            }
        }

        document.getElementById('deleteChapterModal').addEventListener('show.bs.modal', function (e) {
            const btn = e.relatedTarget;
            document.getElementById('deleteChapterId').value   = btn.getAttribute('data-chapter-id');
            document.getElementById('deleteChapterTitle').innerText = btn.getAttribute('data-chapter-title');
        });

        document.getElementById('deleteQuestionModal').addEventListener('show.bs.modal', function (e) {
            const btn = e.relatedTarget;
            document.getElementById('deleteQuestionId').value       = btn.getAttribute('data-question-id');
            document.getElementById('deleteQuestionText').innerText  = btn.getAttribute('data-question-text');
            document.getElementById('deleteQuestionCourseId').value  = btn.getAttribute('data-course-id');
        });
    </script>
}
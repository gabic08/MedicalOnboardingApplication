@model CourseViewModel
@using MedicalOnboardingApplication.Data
@using MedicalOnboardingApplication.Models
@using MedicalOnboardingApplication.ViewModels

@{
    ViewData["Title"] = "Manage Course";
    var course = ViewBag.Course as Course;
}

<div class="mb-4">
    <a asp-controller="AdminCourses" asp-action="Index" class="btn btn-outline-secondary mb-2">
        <i class="bi bi-arrow-left"></i> Back to Courses
    </a>
    <div class="d-flex justify-content-between align-items-center">
        <h1 class="mb-0">Manage Course</h1>
        <button type="button"
                class="btn btn-outline-danger"
                data-bs-toggle="modal"
                data-bs-target="#deleteCourseModal">
            <i class="bi bi-trash"></i> Delete Course
        </button>
    </div>
</div>

<!-- ===================== -->
<!-- COURSE EDIT FORM -->
<!-- ===================== -->
<div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-white border-bottom py-3">
        <h5 class="mb-0 fw-semibold">
            <i class="bi bi-pencil-square me-2 text-primary"></i> Course Details
        </h5>
    </div>
    <div class="card-body p-4">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-3"></div>

            <div class="row g-3">
                <div class="col-md-5">
                    <label asp-for="Title" class="form-label fw-semibold small"></label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>
                <div class="col-md-5">
                    <label asp-for="Description" class="form-label fw-semibold small"></label>
                    <input asp-for="Description" class="form-control" />
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>
                <div class="col-md-2">
                    <label asp-for="Order" class="form-label fw-semibold small"></label>
                    <input asp-for="Order" class="form-control" />
                    <span asp-validation-for="Order" class="text-danger small"></span>
                </div>
            </div>

            <div class="mt-4">
                <h6 class="fw-semibold small text-muted text-uppercase mb-3">
                    <i class="bi bi-people me-1"></i> Assign to Employee Types
                </h6>
                <div class="d-flex flex-wrap gap-2">
                    @for (int i = 0; i < Model.EmployeeTypes.Count; i++)
                    {
                        var checkId = $"empType_{i}";
                        <div>
                            <input type="checkbox"
                                   class="btn-check"
                                   asp-for="EmployeeTypes[i].IsSelected"
                                   id="@checkId"
                                   autocomplete="off" />
                            <label class="btn btn-outline-primary btn-sm rounded-pill px-3"
                                   for="@checkId">
                                <i class="bi bi-person-badge me-1"></i>
                                @Model.EmployeeTypes[i].Name
                            </label>
                            <input type="hidden" asp-for="EmployeeTypes[i].Id" />
                        </div>
                    }
                </div>
            </div>

            <div class="d-flex justify-content-end mt-4">
                <button type="submit" class="btn btn-primary px-4">
                    <i class="bi bi-save me-1"></i> Save Course
                </button>
            </div>
        </form>
    </div>
</div>

<!-- ===================== -->
<!-- CHAPTERS SECTION -->
<!-- ===================== -->
<div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-semibold">
            <i class="bi bi-journals me-2 text-success"></i> Chapters
            <span class="badge bg-success bg-opacity-10 text-success ms-1">@(course.Chapters?.Count ?? 0)</span>
        </h5>
        <a asp-controller="Chapters"
           asp-action="Create"
           asp-route-courseId="@course.Id"
           class="btn btn-success btn-sm">
            <i class="bi bi-plus-circle me-1"></i> Add Chapter
        </a>
    </div>
    <div class="card-body p-4">
        @if (course.Chapters == null || !course.Chapters.Any())
        {
            <div class="text-center py-4 text-muted">
                <i class="bi bi-journal-x fs-1 d-block mb-2 opacity-25"></i>
                No chapters yet. Add your first chapter to get started.
            </div>
        }
        else
        {
            <div class="accordion" id="chaptersAccordion">
                @foreach (var chapter in course.Chapters.OrderBy(c => c.Order))
                {
                    var collapseId = $"collapse_{chapter.Id}";
                    var previewLength = 1000;
                    var content = chapter.Content ?? "";
                    var shortText = content.Length > previewLength ? content.Substring(0, previewLength) + "..." : content;
                    var needsToggle = content.Length > previewLength;
                    var baseId = $"content_{chapter.Id}";

                    <div class="accordion-item border rounded mb-2">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed rounded fw-semibold"
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#@collapseId">
                                <span class="badge bg-secondary me-2">@chapter.Order</span>
                                @chapter.Title
                            </button>
                        </h2>
                        <div id="@collapseId" class="accordion-collapse collapse">
                            <div class="accordion-body pt-2">

                                <p class="text-muted small">
                                    <span id="@(baseId)_short">@shortText</span>
                                    @if (needsToggle)
                                    {
                                        <span id="@(baseId)_full" class="d-none">@content</span>
                                        <a href="javascript:void(0)" class="ms-2 text-primary small"
                                           onclick="toggleContent('@baseId', this)">See more</a>
                                    }
                                </p>

                                <div class="d-flex gap-2 mb-3">
                                    <a asp-controller="Chapters"
                                       asp-action="Edit"
                                       asp-route-id="@chapter.Id"
                                       class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-pencil me-1"></i> Edit
                                    </a>
                                    <button type="button"
                                            class="btn btn-sm btn-outline-danger"
                                            data-bs-toggle="modal"
                                            data-bs-target="#deleteChapterModal"
                                            data-chapter-id="@chapter.Id"
                                            data-chapter-title="@chapter.Title">
                                        <i class="bi bi-trash me-1"></i> Delete
                                    </button>
                                </div>

                                @if (chapter.Attachments != null && chapter.Attachments.Any())
                                {
                                    <h6 class="small fw-semibold text-muted text-uppercase mb-2">
                                        <i class="bi bi-paperclip me-1"></i> Attachments
                                    </h6>
                                    <ul class="list-group list-group-flush">
                                        @foreach (var att in chapter.Attachments)
                                        {
                                            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                                <div class="d-flex align-items-center gap-2">
                                                    @if (att.Type == AttachmentType.Image)
                                                    {
                                                        <i class="bi bi-image text-info"></i>
                                                    }
                                                    else if (att.Type == AttachmentType.Video)
                                                    {
                                                        <i class="bi bi-camera-video text-warning"></i>
                                                    }
                                                    else if (att.Type == AttachmentType.Pdf)
                                                    {
                                                        <i class="bi bi-file-earmark-pdf text-danger"></i>
                                                    }
                                                    <span class="text-truncate small" style="max-width: 220px;">
                                                        @att.FileName
                                                    </span>
                                                </div>
                                                <a href="@att.FilePath"
                                                   target="_blank"
                                                   class="btn btn-sm btn-outline-secondary">
                                                    <i class="bi bi-box-arrow-up-right me-1"></i> Open
                                                </a>
                                            </li>
                                        }
                                    </ul>
                                }
                                else
                                {
                                    <p class="text-muted small mb-0">
                                        <i class="bi bi-paperclip me-1"></i> No attachments
                                    </p>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<!-- ===================== -->
<!-- QUESTIONS SECTION -->
<!-- ===================== -->
<div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-semibold">
            <i class="bi bi-patch-question me-2 text-warning"></i> Questions
            <span class="badge bg-warning bg-opacity-10 text-warning ms-1">@(course.Questions?.Count ?? 0)</span>
        </h5>
        <a asp-controller="Questions"
           asp-action="Create"
           asp-route-courseId="@course.Id"
           class="btn btn-warning btn-sm">
            <i class="bi bi-plus-circle me-1"></i> Add Question
        </a>
    </div>
    <div class="card-body p-4">
        @if (course.Questions == null || !course.Questions.Any())
        {
            <div class="text-center py-4 text-muted">
                <i class="bi bi-question-circle fs-1 d-block mb-2 opacity-25"></i>
                No questions added yet.
            </div>
        }
        else
        {
            <div class="list-group list-group-flush">
                @foreach (var q in course.Questions.OrderBy(q => q.Difficulty))
                {
                    <div class="list-group-item d-flex justify-content-between align-items-center px-0 py-3">
                        <div class="me-3">
                            <p class="mb-1 fw-semibold">@q.Text</p>
                            <div class="d-flex gap-2 align-items-center">
                                <span class="badge bg-secondary bg-opacity-10 text-secondary">
                                    <i class="bi bi-bar-chart me-1"></i> @q.Difficulty
                                </span>
                                <span class="text-muted small">
                                    <i class="bi bi-list-check me-1"></i> @(q.Answers?.Count ?? 0) answers
                                </span>
                            </div>
                        </div>
                        <div class="d-flex gap-2 flex-shrink-0">
                            <a asp-controller="Questions"
                               asp-action="Edit"
                               asp-route-id="@q.Id"
                               class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil me-1"></i> Edit
                            </a>
                            <button type="button"
                                    class="btn btn-sm btn-outline-danger"
                                    data-bs-toggle="modal"
                                    data-bs-target="#deleteQuestionModal"
                                    data-question-id="@q.Id"
                                    data-question-text="@q.Text"
                                    data-course-id="@course.Id">
                                <i class="bi bi-trash me-1"></i> Delete
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<!-- Hidden Forms -->
<form id="deleteCourseForm" asp-controller="AdminCourses" asp-action="Delete"
      asp-route-id="@course.Id" method="post" class="d-none">
    @Html.AntiForgeryToken()
</form>

<form id="deleteChapterForm" asp-controller="Chapters" asp-action="DeleteConfirmed"
      method="post" class="d-none">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="deleteChapterId" />
</form>

<form id="deleteQuestionForm"
      asp-controller="Questions"
      asp-action="Delete"
      method="post"
      class="d-none">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="deleteQuestionId" />
    <input type="hidden" name="courseId" id="deleteQuestionCourseId" />
</form>

<!-- Delete Question Modal -->
<div class="modal fade" id="deleteQuestionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title text-danger">
                    <i class="bi bi-exclamation-triangle me-2"></i> Delete Question
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete <strong id="deleteQuestionText"></strong>?</p>
                <div class="alert alert-warning small mb-0">
                    <i class="bi bi-info-circle me-1"></i>
                    This will also delete all answers. This action cannot be undone.
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger"
                        onclick="document.getElementById('deleteQuestionForm').submit();">
                    <i class="bi bi-trash me-1"></i> Yes, Delete
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Chapter Modal -->
<div class="modal fade" id="deleteChapterModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title text-danger">
                    <i class="bi bi-exclamation-triangle me-2"></i> Delete Chapter
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete <strong id="deleteChapterTitle"></strong>?</p>
                <div class="alert alert-warning small mb-0">
                    <i class="bi bi-info-circle me-1"></i>
                    This will also delete all attachments. This action cannot be undone.
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger"
                        onclick="document.getElementById('deleteChapterForm').submit();">
                    <i class="bi bi-trash me-1"></i> Yes, Delete
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Course Modal -->
<div class="modal fade" id="deleteCourseModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title text-danger">
                    <i class="bi bi-exclamation-triangle me-2"></i> Delete Course
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete <strong>@course.Title</strong>?</p>
                <div class="alert alert-warning small mb-0">
                    <i class="bi bi-info-circle me-1"></i>
                    This will also delete all chapters, attachments, and questions. This action cannot be undone.
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger"
                        onclick="document.getElementById('deleteCourseForm').submit();">
                    <i class="bi bi-trash me-1"></i> Yes, Delete
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function toggleContent(id, link) {
            const shortEl = document.getElementById(id + "_short");
            const fullEl = document.getElementById(id + "_full");
            if (fullEl.classList.contains("d-none")) {
                shortEl.classList.add("d-none");
                fullEl.classList.remove("d-none");
                link.innerText = "See less";
            } else {
                fullEl.classList.add("d-none");
                shortEl.classList.remove("d-none");
                link.innerText = "See more";
            }
        }

        document.getElementById('deleteChapterModal').addEventListener('show.bs.modal', function (e) {
            const btn = e.relatedTarget;
            document.getElementById('deleteChapterId').value = btn.getAttribute('data-chapter-id');
            document.getElementById('deleteChapterTitle').innerText = btn.getAttribute('data-chapter-title');
        });

        document.getElementById('deleteQuestionModal').addEventListener('show.bs.modal', function (e) {
            const btn = e.relatedTarget;
            document.getElementById('deleteQuestionId').value = btn.getAttribute('data-question-id');
            document.getElementById('deleteQuestionText').innerText = btn.getAttribute('data-question-text');
            document.getElementById('deleteQuestionCourseId').value = btn.getAttribute('data-course-id');
        });
    </script>
}
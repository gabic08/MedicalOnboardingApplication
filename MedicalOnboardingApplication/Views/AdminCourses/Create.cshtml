@using MedicalOnboardingApplication.ViewModels
@model CourseViewModel
@{
    ViewData["Title"] = "Creare Curs";
}

<!-- Page Header -->
<div class="rm-page-header">
    <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
        <div>
            <div class="breadcrumb-label">
                <a asp-controller="Admin" asp-action="Index" class="text-decoration-none" style="color:inherit;">Panou Admin</a>
                <i class="bi bi-chevron-right mx-1" style="font-size:0.65rem;"></i>
                <a asp-action="Index" class="text-decoration-none" style="color:inherit;">Cursuri</a>
                <i class="bi bi-chevron-right mx-1" style="font-size:0.65rem;"></i>
                Creare
            </div>
            <a asp-controller="AdminCourses"
                   asp-action="Index"
                   class="btn btn-outline-secondary btn-rm-back mb-2"
                   style="color:var(--rm-red);border-color:var(--rm-red);">
                <i class="bi bi-arrow-left"></i> Înapoi la Cursuri
            </a>
            <h1>Creare Curs</h1>
            <p>Completează detaliile pentru a adăuga un curs nou</p>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12 col-lg-9 mx-auto">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            @if (ViewData.ModelState.ErrorCount > 0)
            {
                <div class="rm-alert rm-alert-error mb-4">
                    <i class="bi bi-exclamation-circle-fill"></i>
                    <div asp-validation-summary="ModelOnly"></div>
                </div>
            }

            <!-- Course Details -->
            <div class="rm-form-card mb-4">
                <div class="rm-form-card-header">
                    <i class="bi bi-journal-text" style="color:var(--rm-red);"></i>
                    Detalii Curs
                </div>
                <div class="rm-form-card-body">
                    <div class="rm-field mb-3">
                        <label asp-for="Title" class="rm-label"></label>
                        <input asp-for="Title" class="rm-input" placeholder="Introdu titlul cursului..." />
                        <span asp-validation-for="Title" class="rm-field-error"></span>
                    </div>
                    <div class="rm-field mb-3">
                        <label asp-for="Description" class="rm-label"></label>
                        <input asp-for="Description" class="rm-input" placeholder="Introdu descrierea cursului..." />
                        <span asp-validation-for="Description" class="rm-field-error"></span>
                    </div>
                    <div class="rm-field" style="max-width:160px;">
                        <label asp-for="Order" class="rm-label"></label>
                        <input asp-for="Order" class="rm-input" />
                        <span asp-validation-for="Order" class="rm-field-error"></span>
                    </div>
                </div>
            </div>

            <!-- Employee Types -->
            <div class="rm-form-card mb-4">
                <div class="rm-form-card-header">
                    <i class="bi bi-people" style="color:var(--rm-red);"></i>
                    Atribuie Tipurilor de Angajați
                </div>
                <div class="rm-form-card-body">
                    <p style="font-size:0.85rem;color:var(--rm-text-muted);margin-bottom:16px;">
                        Selectează tipurile de angajați care vor avea acces la acest curs.
                    </p>
                    <div class="d-flex flex-wrap gap-2" id="employeeTypeContainer">
                        @for (int i = 0; i < Model?.EmployeeTypes?.Count; i++)
                        {
                            var checkId = $"empType_{i}";
                            <div>
                                <input type="checkbox"
                                       class="rm-btn-check emp-type-check"
                                       asp-for="EmployeeTypes[i].IsSelected"
                                       id="@checkId"
                                       autocomplete="off" />
                                <label class="rm-toggle-btn" for="@checkId">
                                    <i class="bi bi-person-badge"></i>
                                    @Model.EmployeeTypes[i].Name
                                </label>
                                <input type="hidden" asp-for="EmployeeTypes[i].Id" />
                            </div>
                        }
                    </div>

                    <div id="noTypeWarning"
                         class="rm-modal-warning mt-3"
                         style="display:@(Model?.EmployeeTypes?.Any(e => e.IsSelected) == true ? "none" : "flex");">
                        <i class="bi bi-exclamation-triangle"></i>
                        Niciun tip de angajat selectat. Cursul nu va fi vizibil pentru niciun angajat până când nu adaugi cel puțin un tip.
                    </div>
                </div>
            </div>

            <!-- Actions -->
            <div class="d-flex justify-content-end gap-2">
                <a asp-action="Index" class="btn-rm-secondary">
                    <i class="bi bi-x"></i> Anulează
                </a>
                <button type="submit" class="btn-rm-primary">
                    <i class="bi bi-save"></i> Salvează Cursul
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function updateWarning() {
            const anyChecked = [...document.querySelectorAll('.emp-type-check')].some(cb => cb.checked);
            document.getElementById('noTypeWarning').style.display = anyChecked ? 'none' : 'flex';
        }
        document.querySelectorAll('.emp-type-check').forEach(cb => {
            cb.addEventListener('change', updateWarning);
        });
    </script>
}
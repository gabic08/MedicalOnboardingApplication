@using MedicalOnboardingApplication.ViewModels
@model CourseViewModel
@{
    ViewData["Title"] = "Create Course";
}

<div class="mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary mb-2">
        <i class="bi bi-arrow-left"></i> Back to Courses
    </a>
    <h1 class="mb-0">Create Course</h1>
</div>

<div class="row">
    <div class="col-12 col-lg-10 mx-auto">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-3"></div>

            <!-- Course Details -->
            <div class="card shadow-sm border-0 mb-3">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="mb-0 fw-semibold text-muted text-uppercase">
                        <i class="bi bi-journal-text me-2 text-primary"></i> Course Details
                    </h6>
                </div>
                <div class="card-body p-4">
                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-semibold small"></label>
                        <input asp-for="Title" class="form-control" placeholder="Enter course title..." />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold small"></label>
                        <input asp-for="Description" class="form-control" placeholder="Enter course description..." />
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>
                    <div class="mb-0" style="max-width: 150px;">
                        <label asp-for="Order" class="form-label fw-semibold small"></label>
                        <input asp-for="Order" class="form-control" />
                        <span asp-validation-for="Order" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <!-- Employee Types -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="mb-0 fw-semibold text-muted text-uppercase">
                        <i class="bi bi-people me-2 text-primary"></i> Assign to Employee Types
                    </h6>
                </div>
                <div class="card-body p-4">
                    <div class="d-flex flex-wrap gap-2">
                        @for (int i = 0; i < Model?.EmployeeTypes?.Count; i++)
                        {
                            var checkId = $"empType_{i}";
                            <div>
                                <input type="checkbox"
                                       class="btn-check"
                                       asp-for="EmployeeTypes[i].IsSelected"
                                       id="@checkId"
                                       autocomplete="off" />
                                <label class="btn btn-outline-primary btn-sm rounded-pill px-3"
                                       for="@checkId">
                                    <i class="bi bi-person-badge me-1"></i>
                                    @Model.EmployeeTypes[i].Name
                                </label>
                                <input type="hidden" asp-for="EmployeeTypes[i].Id" />
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-end gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                <button type="submit" class="btn btn-primary px-4">
                    <i class="bi bi-save me-1"></i> Save Course
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

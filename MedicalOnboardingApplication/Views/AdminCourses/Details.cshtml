@model MedicalOnboardingApplication.Models.Course

@using MedicalOnboardingApplication.Data
@using MedicalOnboardingApplication.Models

@{
    ViewData["Title"] = "Course Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-0">@Model.Title</h1>
        <p class="text-muted mb-0">@Model.Description</p>
    </div>

    <div>
        <a asp-action="Index" class="btn btn-outline-secondary me-2">
            <i class="bi bi-arrow-left"></i> Back to Courses
        </a>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
            <i class="bi bi-pencil-square"></i> Edit Course
        </a>
    </div>
</div>

<!-- Course Meta -->
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <div class="row text-center">
            <div class="col-md-4">
                <h6 class="text-muted">Order</h6>
                <span class="fw-bold">@Model.Order</span>
            </div>
            <div class="col-md-4">
                <h6 class="text-muted">Chapters</h6>
                <span class="fw-bold">@Model.Chapters?.Count ?? 0</span>
            </div>
            <div class="col-md-4">
                <h6 class="text-muted">Tests</h6>
                <span class="fw-bold">@Model.Tests?.Count ?? 0</span>
            </div>
        </div>
    </div>
</div>

<!-- Chapters Section -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Chapters</h3>
    <a asp-controller="Chapters"
       asp-action="Create"
       asp-route-courseId="@Model.Id"
       class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Add Chapter
    </a>
</div>

@if (Model.Chapters == null || !Model.Chapters.Any())
{
    <div class="alert alert-info">
        No chapters yet. Click <strong>Add Chapter</strong> to create the first one.
    </div>
}
else
{
    <div class="accordion" id="chaptersAccordion">
        @foreach (var chapter in Model.Chapters.OrderBy(c => c.Order))
        {
            var collapseId = $"collapse_{chapter.Id}";
            var headingId = $"heading_{chapter.Id}";

            <div class="accordion-item mb-2 shadow-sm">
                <h2 class="accordion-header" id="@headingId">
                    <button class="accordion-button collapsed" type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#@collapseId"
                            aria-expanded="false"
                            aria-controls="@collapseId">
                        <div class="w-100 d-flex justify-content-between align-items-center">
                            <div>
                                <strong>@chapter.Order.</strong> @chapter.Title
                            </div>
                            <div class="text-muted small">
                                Attachments: @(chapter.Attachments?.Count ?? 0)
                            </div>
                        </div>
                    </button>
                </h2>

                <div id="@collapseId" class="accordion-collapse collapse"
                     aria-labelledby="@headingId"
                     data-bs-parent="#chaptersAccordion">
                    <div class="accordion-body">

                        <!-- Chapter Content -->
                        <div class="mb-3">
                            <h6 class="text-muted">Content</h6>
                            <p>@chapter.Content</p>
                        </div>

                        <!-- Chapter Actions -->
                        <div class="mb-3 d-flex gap-2">
                            <a asp-controller="Chapters"
                               asp-action="Edit"
                               asp-route-id="@chapter.Id"
                               class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i> Edit Chapter
                            </a>

                            <a asp-controller="Chapters"
                               asp-action="Delete"
                               asp-route-id="@chapter.Id"
                               class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i> Delete Chapter
                            </a>

                            <a asp-controller="ChapterAttachments"
                               asp-action="Create"
                               asp-route-chapterId="@chapter.Id"
                               class="btn btn-sm btn-outline-success">
                                <i class="bi bi-paperclip"></i> Add Attachment
                            </a>
                        </div>

                        <!-- Attachments -->
                        <h6 class="text-muted">Attachments</h6>

                        @if (chapter.Attachments == null || !chapter.Attachments.Any())
                        {
                            <p class="text-muted">No attachments added yet.</p>
                        }
                        else
                        {
                            <ul class="list-group list-group-flush">
                                @foreach (var att in chapter.Attachments)
                                {
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        <div>
                                            <i class="bi bi-paperclip me-2"></i>

                                            @if (att.Type == AttachmentType.Link)
                                            {
                                                <span>@att.Url</span>
                                            }
                                            else
                                            {
                                                <span>@att.FileName</span>
                                            }

                                            <span class="badge bg-secondary ms-2">
                                                @att.Type
                                            </span>
                                        </div>

                                        <a href="@(att.Type == AttachmentType.Link ? att.Url : att.FilePath)"
                                           target="_blank"
                                           class="btn btn-sm btn-outline-primary">
                                            Open
                                        </a>
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

<!-- Tests Section -->
<div class="mt-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="mb-0">Tests</h3>
        <a asp-controller="Tests"
           asp-action="Create"
           asp-route-courseId="@Model.Id"
           class="btn btn-warning">
            <i class="bi bi-plus-circle"></i> Add Test
        </a>
    </div>

    @if (Model.Tests == null || !Model.Tests.Any())
    {
        <div class="alert alert-info">
            No tests added yet.
        </div>
    }
    else
    {
        <div class="list-group shadow-sm">
            @foreach (var test in Model.Tests)
            {
                <div class="list-group-item d-flex justify-content-between align-items-center">
                    <div>
                        <strong>@test.Title</strong>
                        <div class="text-muted small">
                            Questions: @(test.Questions?.Count ?? 0)
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <a asp-controller="Tests"
                           asp-action="Details"
                           asp-route-id="@test.Id"
                           class="btn btn-sm btn-outline-primary">
                            View
                        </a>

                        <a asp-controller="Tests"
                           asp-action="Edit"
                           asp-route-id="@test.Id"
                           class="btn btn-sm btn-outline-secondary">
                            Edit
                        </a>

                        <a asp-controller="Tests"
                           asp-action="Delete"
                           asp-route-id="@test.Id"
                           class="btn btn-sm btn-outline-danger">
                            Delete
                        </a>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .accordion-button strong {
        margin-right: 0.5rem;
    }

    .accordion-item {
        border-radius: 0.75rem;
        overflow: hidden;
    }

    .list-group-item {
        border: none;
        border-bottom: 1px solid #eee;
    }

        .list-group-item:last-child {
            border-bottom: none;
        }
</style>

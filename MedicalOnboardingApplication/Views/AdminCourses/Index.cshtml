@model IEnumerable<MedicalOnboardingApplication.Models.Course>

@{
    ViewData["Title"] = "AdminCourses";
    var employeeTypes = ViewBag.EmployeeTypes as List<MedicalOnboardingApplication.Models.EmployeeType>;
    var selectedTypeId = ViewBag.SelectedEmployeeTypeId as int?;
    var search = ViewBag.Search as string;
}

<h1>Courses</h1>

<div class="mb-3">
    <form method="get" class="row g-2 align-items-end">
        <div class="col-md-4">
            <label class="form-label">Search</label>
            <input type="text"
                   name="search"
                   value="@search"
                   class="form-control"
                   placeholder="Search title or description..." />
        </div>

        <div class="col-md-4">
            <label class="form-label">Filter by Employee Type</label>
            <select name="employeeTypeId" class="form-select">
                <option value="">All</option>
                @foreach (var type in employeeTypes)
                {
                    <option value="@type.Id" selected="@(selectedTypeId == type.Id)">
                        @type.Name
                    </option>
                }
            </select>
        </div>

        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">
                <i class="bi bi-search"></i> Apply
            </button>
        </div>

        <div class="col-md-2 text-end">
            <a asp-action="Create" class="btn btn-success w-100">
                <i class="bi bi-plus-circle"></i> New Course
            </a>
        </div>
    </form>
</div>

<table class="table table-striped align-middle">
    <thead>
        <tr>
            <th style="width: 80px;">Order</th>
            <th>Title</th>
            <th>Description</th>
            <th>Employee Types</th>
            <th style="width: 220px;"></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var course in Model)
        {
            <tr>
                <td>
                    <span class="badge bg-secondary">@course.Order</span>
                </td>
                <td>@course.Title</td>
                <td class="text-muted">
                    @course.Description
                </td>
                <td>
                    @string.Join(", ", course.CourseEmployeeTypes.Select(cet => cet.EmployeeType.Name))
                </td>
                <td class="text-end">
                    <a asp-action="Manage"
                       asp-route-id="@course.Id"
                       class="btn btn-sm btn-outline-primary me-1">
                        <i class="bi bi-sliders"></i> Manage
                    </a>
                    <a asp-action="Delete"
                       asp-route-id="@course.Id"
                       class="btn btn-sm btn-outline-danger">
                        Delete
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
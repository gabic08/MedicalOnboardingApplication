@model IEnumerable<MedicalOnboardingApplication.Models.EmployeeType>

@{
    ViewData["Title"] = "Employee Types";
    var search = ViewBag.Search as string;
    int? editId = ViewBag.EditId as int?;
}

<div class="mb-4">
    <a asp-controller="AdminEmployees"
       asp-action="Index"
       class="btn btn-outline-secondary mb-2">
        <i class="bi bi-arrow-left"></i> Back to Employees
    </a>
    <h1 class="mb-0">Employee Types</h1>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<!-- SEARCH + CREATE -->
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form method="get" class="row g-2 mb-3">
            <div class="col-md-8">
                <input type="text"
                       name="search"
                       value="@search"
                       class="form-control"
                       placeholder="Search employee types..." />
            </div>
            <div class="col-md-4">
                <button class="btn btn-primary w-100">
                    <i class="bi bi-search"></i> Search
                </button>
            </div>
        </form>

        <form asp-action="Create" method="post" class="row g-2">
            @Html.AntiForgeryToken()
            <div class="col-md-8">
                <input name="name"
                       class="form-control"
                       placeholder="New employee type name..." />
            </div>
            <div class="col-md-4">
                <button class="btn btn-success w-100">
                    <i class="bi bi-plus-circle"></i> Add
                </button>
            </div>
        </form>
    </div>
</div>

<!-- TABLE -->
<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-striped align-middle mb-0">
            <thead>
                <tr>
                    <th>Name</th>
                    <th style="width: 220px;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var type in Model)
                {
                    <tr>
                        <td>
                            @if (editId == type.Id)
                            {
                                <form asp-action="Edit" method="post" class="d-flex gap-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@type.Id" />

                                    <input name="name"
                                           value="@type.Name"
                                           class="form-control form-control-sm"
                                           autofocus />

                                    <button class="btn btn-sm btn-primary">
                                        <i class="bi bi-save"></i>
                                    </button>

                                    <a asp-action="Index"
                                       class="btn btn-sm btn-outline-secondary">
                                        <i class="bi bi-x"></i>
                                    </a>
                                </form>
                            }
                            else
                            {
                                @type.Name
                            }
                        </td>

                        <td class="text-end">
                            @if (editId != type.Id)
                            {
                                <a asp-action="Index"
                                   asp-route-editId="@type.Id"
                                   class="btn btn-sm btn-outline-secondary me-1">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>

                                <form asp-action="Delete"
                                      method="post"
                                      class="d-inline"
                                      onsubmit="return confirm('Delete this employee type?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@type.Id" />
                                    <button class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

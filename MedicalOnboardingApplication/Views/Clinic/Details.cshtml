@model MedicalOnboardingApplication.Models.Clinic

@{
    ViewData["Title"] = "My Clinic";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="mb-0">
            <i class="bi bi-hospital"></i> Clinic Information
        </h3>

        <button type="button"
                class="btn btn-outline-primary"
                onclick="enableEdit()"
                id="editButton">
            <i class="bi bi-pencil"></i> Edit Clinic
        </button>
    </div>

    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body">

            <form asp-action="Edit" method="post">

                <input type="hidden" asp-for="Id" />

                <div class="row mb-4">
                    <div class="col-md-3 text-muted fw-semibold">
                        Name
                    </div>
                    <div class="col-md-9">
                        <input asp-for="Name"
                               class="form-control-plaintext editable"
                               readonly />
                    </div>
                </div>

                <hr />

                <div class="row mb-4">
                    <div class="col-md-3 text-muted fw-semibold">
                        Address
                    </div>
                    <div class="col-md-9">
                        <input asp-for="Address"
                               class="form-control-plaintext editable"
                               readonly />
                    </div>
                </div>

                <hr />

                <div class="row mb-4">
                    <div class="col-md-3 text-muted fw-semibold">
                        Phone
                    </div>
                    <div class="col-md-9">
                        <input asp-for="Phone"
                               class="form-control-plaintext editable"
                               readonly />
                    </div>
                </div>

                <div class="text-end d-none" id="saveSection">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save"></i> Save Changes
                    </button>
                </div>

            </form>

        </div>
    </div>

    <div class="mt-4">
        <a asp-controller="Admin"
           asp-action="Index"
           class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Dashboard
        </a>
    </div>

</div>

<script>
    function enableEdit() {
        const inputs = document.querySelectorAll('.editable');
        inputs.forEach(input => {
            input.removeAttribute('readonly');
            input.classList.remove('form-control-plaintext');
            input.classList.add('form-control');
        });

        document.getElementById('saveSection').classList.remove('d-none');
        document.getElementById('editButton').classList.add('d-none');
    }

    // Auto-enable edit if no clinic exists yet
    if (@Json.Serialize(ViewBag.AutoEdit)) {
        enableEdit();
    }
</script>
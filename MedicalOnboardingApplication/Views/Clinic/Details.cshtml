@model MedicalOnboardingApplication.Models.Clinic

@{
    ViewData["Title"] = "My Clinic";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="mb-0">
            <i class="bi bi-hospital"></i> Clinic Information
        </h3>

        <a asp-action="Edit" class="btn btn-outline-primary">
            <i class="bi bi-pencil"></i> Edit Clinic
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body">

            <div class="row mb-4">
                <div class="col-md-3 text-muted fw-semibold">
                    Name
                </div>
                <div class="col-md-9">
                    @Model.Name
                </div>
            </div>

            <hr />

            <div class="row mb-4">
                <div class="col-md-3 text-muted fw-semibold">
                    Address
                </div>
                <div class="col-md-9">
                    @Model.Address
                </div>
            </div>

            <hr />

            <div class="row">
                <div class="col-md-3 text-muted fw-semibold">
                    Phone
                </div>
                <div class="col-md-9">
                    @Model.Phone
                </div>
            </div>

        </div>
    </div>

    <div class="mt-4">
        <a asp-controller="Admin"
           asp-action="Index"
           class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Dashboard
        </a>
    </div>

</div>

@model MedicalOnboardingApplication.Models.Clinic
@{
    ViewData["Title"] = "Clinica Mea";
}

<!-- Page Header -->
<div class="rm-page-header">
    <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
        <div>
            <div class="breadcrumb-label">
                <a asp-controller="Admin" asp-action="Index" class="text-decoration-none" style="color:inherit;">Panou Admin</a>
                <i class="bi bi-chevron-right mx-1" style="font-size:0.65rem;"></i>
                Clinica Mea
            </div>
            <h1>Informații Clinică</h1>
            <p>Gestionează datele și imaginea clinicii tale</p>
        </div>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="rm-alert rm-status-green mb-4" style="background:#dcfce7;border:1px solid #bbf7d0;color:#16a34a;">
        <i class="bi bi-check-circle-fill"></i>
        @TempData["Success"]
    </div>
}

<form asp-action="Edit" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="ImagePath" />

    <div class="rm-two-col" style="grid-template-columns: 260px 1fr; align-items: start;">

        <!-- LEFT: Clinic Image -->
        <div class="rm-two-col-main">
            <div class="rm-form-card">
                <div class="rm-form-card-body" style="display:flex;flex-direction:column;align-items:center;text-align:center;padding:36px 24px;">

                    <div style="position:relative;margin-bottom:16px;">
                        <img id="clinicImagePreview"
                             src="@(Model.ImagePath ?? "/required/NoClinicImage.jpg")"
                             style="width:110px;height:110px;border-radius:var(--rm-radius);object-fit:cover;border:2px solid var(--rm-border);" />
                    </div>

                    <input type="file"
                           name="image"
                           id="clinicImageInput"
                           class="d-none"
                           accept="image/*"
                           onchange="previewClinicImage(this)" />

                    <h5 style="font-weight:700;margin-bottom:4px;font-size:1rem;">@Model.Name</h5>
                    <p style="font-size:0.78rem;color:var(--rm-text-muted);margin-bottom:24px;">Unitate Medicală</p>

                    <button type="button"
                            class="btn-rm-secondary d-none mb-2"
                            id="uploadImageBtn"
                            style="width:100%;justify-content:center;"
                            onclick="document.getElementById('clinicImageInput').click()">
                        <i class="bi bi-upload"></i> Schimbă Imaginea
                    </button>

                    <button type="button"
                            class="btn-rm-primary"
                            style="width:100%;justify-content:center;"
                            onclick="enableEdit()"
                            id="editButton">
                        <i class="bi bi-pencil"></i> Editează Clinica
                    </button>

                </div>
            </div>
        </div>

        <!-- RIGHT: Clinic Details -->
        <div class="rm-two-col-side">
            <div class="rm-form-card">
                <div class="rm-form-card-header">
                    <i class="bi bi-info-circle" style="color:var(--rm-red);"></i>
                    Detalii Clinică
                </div>
                <div class="rm-form-card-body">

                    <!-- Subdomain -->
                    <div class="rm-clinic-field">
                        <label class="rm-clinic-field-label">
                            <i class="bi bi-link-45deg"></i> Subdomeniu
                        </label>
                        <div style="display:flex;align-items:center;gap:0;">
                            <input asp-for="Subdomain"
                                   class="rm-clinic-input editable"
                                   readonly />
                            <span class="rm-clinic-suffix d-none" id="subdomainSuffix">.localtest.me:5000</span>
                        </div>
                        <small class="rm-clinic-hint d-none" id="subdomainHint">
                            ex: "clinica-mea" → clinica-mea.localtest.me:5000
                        </small>
                    </div>

                    <div class="rm-clinic-divider"></div>

                    <!-- Name -->
                    <div class="rm-clinic-field">
                        <label class="rm-clinic-field-label">
                            <i class="bi bi-building"></i> Nume Clinică
                        </label>
                        <input asp-for="Name"
                               class="rm-clinic-input editable rm-clinic-input--large"
                               readonly />
                    </div>

                    <div class="rm-clinic-divider"></div>

                    <!-- Address -->
                    <div class="rm-clinic-field">
                        <label class="rm-clinic-field-label">
                            <i class="bi bi-geo-alt"></i> Adresă
                        </label>
                        <input asp-for="Address" class="rm-clinic-input editable" readonly />
                    </div>

                    <div class="rm-clinic-divider"></div>

                    <!-- City -->
                    <div class="rm-clinic-field">
                        <label class="rm-clinic-field-label">
                            <i class="bi bi-map"></i> Oraș
                        </label>
                        <input asp-for="City" class="rm-clinic-input editable" readonly />
                    </div>

                    <div class="rm-clinic-divider"></div>

                    <!-- Country -->
                    <div class="rm-clinic-field">
                        <label class="rm-clinic-field-label">
                            <i class="bi bi-flag"></i> Țară
                        </label>
                        <input asp-for="Country" class="rm-clinic-input editable" readonly />
                    </div>

                    <div class="rm-clinic-divider"></div>

                    <!-- Phone -->
                    <div class="rm-clinic-field">
                        <label class="rm-clinic-field-label">
                            <i class="bi bi-telephone"></i> Telefon
                        </label>
                        <input asp-for="Phone" class="rm-clinic-input editable" readonly />
                    </div>

                    <div class="rm-clinic-divider"></div>

                    <!-- Email -->
                    <div class="rm-clinic-field">
                        <label class="rm-clinic-field-label">
                            <i class="bi bi-envelope"></i> Email
                        </label>
                        <input asp-for="Email" class="rm-clinic-input editable" readonly />
                    </div>

                    <div class="rm-clinic-divider"></div>

                    <!-- Website -->
                    <div class="rm-clinic-field" style="margin-bottom:0;">
                        <label class="rm-clinic-field-label">
                            <i class="bi bi-globe"></i> Website
                        </label>
                        <input asp-for="Website" class="rm-clinic-input editable" readonly />
                    </div>

                    <!-- Save / Cancel -->
                    <div class="d-none mt-4 d-flex justify-content-end gap-2" id="saveSection">
                        <button type="button" class="btn-rm-secondary" onclick="cancelEdit()">
                            <i class="bi bi-x"></i> Anulează
                        </button>
                        <button type="submit" class="btn-rm-primary">
                            <i class="bi bi-save"></i> Salvează Modificările
                        </button>
                    </div>

                </div>
            </div>
        </div>

    </div>
</form>

<script>
    const originalValues = {};

    function enableEdit() {
        document.querySelectorAll('.editable').forEach(input => {
            originalValues[input.name] = input.value;
            input.removeAttribute('readonly');
            input.classList.add('rm-clinic-input--active');
        });
        document.getElementById('saveSection').classList.remove('d-none');
        document.getElementById('editButton').classList.add('d-none');
        document.getElementById('uploadImageBtn').classList.remove('d-none');
        document.getElementById('subdomainSuffix').classList.remove('d-none');
        document.getElementById('subdomainHint').classList.remove('d-none');
    }

    function cancelEdit() {
        document.querySelectorAll('.editable').forEach(input => {
            input.value = originalValues[input.name] ?? input.value;
            input.setAttribute('readonly', true);
            input.classList.remove('rm-clinic-input--active');
        });
        document.getElementById('saveSection').classList.add('d-none');
        document.getElementById('editButton').classList.remove('d-none');
        document.getElementById('uploadImageBtn').classList.add('d-none');
        document.getElementById('clinicImagePreview').src = '@(Model.ImagePath ?? "/required/NoClinicImage.jpg")';
        document.getElementById('clinicImageInput').value = '';
        document.getElementById('subdomainSuffix').classList.add('d-none');
        document.getElementById('subdomainHint').classList.add('d-none');
    }

    function previewClinicImage(input) {
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = e => document.getElementById('clinicImagePreview').src = e.target.result;
            reader.readAsDataURL(input.files[0]);
        }
    }

    if (@Json.Serialize(ViewBag.AutoEdit)) {
        enableEdit();
    }
</script>
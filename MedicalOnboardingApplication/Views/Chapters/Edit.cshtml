@model MedicalOnboardingApplication.Models.Chapter
@using MedicalOnboardingApplication.Data
@using MedicalOnboardingApplication.Models

@{
    ViewData["Title"] = "Edit Chapter";
}

<h1 class="mb-4">Edit Chapter</h1>

<div class="row">
    <div class="col-lg-7">

        <!-- CHAPTER FORM -->
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()

                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="CourseId" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label"></label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Order" class="form-label"></label>
                        <input asp-for="Order" class="form-control" />
                        <span asp-validation-for="Order" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Content" class="form-label"></label>
                        <textarea asp-for="Content"
                                  class="form-control"
                                  rows="18"
                                  placeholder="Write your chapter content here..."></textarea>
                        <span asp-validation-for="Content" class="text-danger"></span>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-controller="AdminCourses"
                           asp-action="Manage"
                           asp-route-id="@Model.CourseId"
                           class="btn btn-outline-secondary">
                            Back to Course
                        </a>

                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save"></i> Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- ATTACHMENTS PANEL -->
    <div class="col-lg-5">
        <div class="card shadow-sm">
            <div class="card-body">

                <h5 class="mb-3">Attachments</h5>

                <!-- UPLOAD FORM -->
                <form asp-controller="ChapterAttachments"
                      asp-action="Create"
                      method="post"
                      enctype="multipart/form-data"
                      class="mb-3">

                    @Html.AntiForgeryToken()
                    <input type="hidden" name="chapterId" value="@Model.Id" />

                    <div class="input-group">
                        <input type="file"
                               name="file"
                               class="form-control"
                               accept=".jpg,.jpeg,.png,.gif,.webp,.mp4,.webm,.mov,.pdf"
                               required />

                        <button class="btn btn-success" type="submit">
                            <i class="bi bi-upload"></i>
                        </button>
                    </div>

                    <small class="text-muted">
                        Allowed: Images, Videos, PDF
                    </small>
                </form>

                <!-- ATTACHMENTS LIST -->
                @if (Model.Attachments == null || !Model.Attachments.Any())
                {
                    <div class="alert alert-info">
                        No attachments added yet.
                    </div>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var att in Model.Attachments)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <div class="d-flex align-items-center gap-2">
                                    @if (att.Type == AttachmentType.Image)
                                    {
                                        <i class="bi bi-image"></i>
                                    }
                                    else if (att.Type == AttachmentType.Video)
                                    {
                                        <i class="bi bi-camera-video"></i>
                                    }
                                    else if (att.Type == AttachmentType.Pdf)
                                    {
                                        <i class="bi bi-file-earmark-pdf"></i>
                                    }

                                    <span class="text-truncate" style="max-width: 200px;">
                                        @att.FileName
                                    </span>
                                </div>

                                <div class="d-flex gap-2">
                                    <a href="@att.FilePath"
                                       target="_blank"
                                       class="btn btn-sm btn-outline-secondary">
                                        Open
                                    </a>

                                    <form asp-controller="ChapterAttachments"
                                          asp-action="Delete"
                                          asp-route-id="@att.Id"
                                          method="post"
                                          onsubmit="return confirm('Delete this attachment?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </li>
                        }
                    </ul>
                }

            </div>
        </div>
    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

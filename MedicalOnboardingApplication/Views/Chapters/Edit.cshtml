@model MedicalOnboardingApplication.Models.Chapter
@using MedicalOnboardingApplication.Enums
@using MedicalOnboardingApplication.Models

@{
    ViewData["Title"] = "Editare Capitol";
}

<div class="mb-3">
    <a asp-controller="AdminCourses"
       asp-action="Manage"
       asp-route-id="@Model.CourseId"
       class="btn btn-outline-secondary mb-2">
        <i class="bi bi-arrow-left"></i> Înapoi la Curs
    </a>
    <h1 class="mb-0">Editare Capitol</h1>
</div>

<div class="row g-3" style="height: calc(100vh - 180px);">

    <!-- CHAPTER FORM -->
    <div class="col-lg-6 h-100">
        <div class="card shadow-sm h-100">
            <div class="card-body d-flex flex-column">
                <form asp-action="Edit" method="post" class="d-flex flex-column flex-grow-1">
                    @Html.AntiForgeryToken()

                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="CourseId" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label"></label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Order" class="form-label"></label>
                        <input asp-for="Order" class="form-control" />
                        <span asp-validation-for="Order" class="text-danger"></span>
                    </div>

                    <div class="mb-3 flex-grow-1 d-flex flex-column">
                        <label asp-for="Content" class="form-label"></label>
                        <textarea asp-for="Content"
                                  class="form-control flex-grow-1"
                                  style="resize: none; font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; line-height: 1.6;"
                                  placeholder="Scrie conținutul capitolului aici..."></textarea>
                        <span asp-validation-for="Content" class="text-danger"></span>
                    </div>

                    <div class="d-flex justify-content-end">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save"></i> Salvează Modificările
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- ATTACHMENTS PANEL -->
    <div class="col-lg-6 h-100">
        <div class="card shadow-sm h-100">
            <div class="card-body d-flex flex-column">

                <h5 class="mb-3">Atașamente</h5>

                <!-- UPLOAD FORM -->
                <form asp-controller="ChapterAttachments"
                      asp-action="Create"
                      method="post"
                      enctype="multipart/form-data"
                      class="mb-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="chapterId" value="@Model.Id" />

                    <div class="input-group">
                        <input type="file"
                               name="file"
                               class="form-control"
                               accept=".jpg,.jpeg,.png,.gif,.webp,.mp4,.webm,.mov,.pdf"
                               required />
                        <button class="btn btn-success" type="submit">
                            <i class="bi bi-upload"></i>
                        </button>
                    </div>
                    <small class="text-muted">Acceptat: Imagini, Videoclipuri, PDF</small>
                </form>

                <!-- ATTACHMENTS LIST -->
                <div class="flex-grow-1 overflow-auto">
                    @if (Model.Attachments == null || !Model.Attachments.Any())
                    {
                        <div class="alert alert-info">
                            Niciun atașament adăugat încă.
                        </div>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var att in Model.Attachments)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center gap-2">
                                        @if (att.Type == AttachmentType.Image)
                                        {
                                            <i class="bi bi-image"></i>
                                        }
                                        else if (att.Type == AttachmentType.Video)
                                        {
                                            <i class="bi bi-camera-video"></i>
                                        }
                                        else if (att.Type == AttachmentType.Pdf)
                                        {
                                            <i class="bi bi-file-earmark-pdf"></i>
                                        }
                                        <span class="text-truncate" style="max-width: 200px;">
                                            @att.FileName
                                        </span>
                                    </div>
                                    <div class="d-flex gap-2">
                                        <a href="@att.FilePath"
                                           target="_blank"
                                           class="btn btn-sm btn-outline-secondary">
                                            Deschide
                                        </a>
                                        <form asp-controller="ChapterAttachments"
                                              asp-action="Delete"
                                              asp-route-id="@att.Id"
                                              method="post"
                                              onsubmit="return confirm('Ștergi acest atașament?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                </div>

            </div>
        </div>
    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

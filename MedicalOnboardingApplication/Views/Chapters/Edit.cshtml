@model MedicalOnboardingApplication.ViewModels.EditChapterViewModel
@using MedicalOnboardingApplication.Enums
@using MedicalOnboardingApplication.Models

@{
    ViewData["Title"] = "Editare Capitol";
    var attachments = ViewBag.Attachments as IEnumerable<MedicalOnboardingApplication.Models.ChapterAttachment>;
}

<!-- Page Header -->
<div class="rm-page-header">
    <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
        <div>
            <div class="breadcrumb-label">
                <a asp-controller="Admin" asp-action="Index" class="text-decoration-none" style="color:inherit;">Panou Admin</a>
                <i class="bi bi-chevron-right mx-1" style="font-size:0.65rem;"></i>
                <a asp-controller="AdminCourses" asp-action="Index" class="text-decoration-none" style="color:inherit;">Cursuri</a>
                <i class="bi bi-chevron-right mx-1" style="font-size:0.65rem;"></i>
                <a asp-controller="AdminCourses" asp-action="Manage" asp-route-id="@Model.CourseId" class="text-decoration-none" style="color:inherit;">Gestionare</a>
                <i class="bi bi-chevron-right mx-1" style="font-size:0.65rem;"></i>
                Editare Capitol
            </div>
            <a asp-controller="AdminCourses"
                   asp-action="Manage"
                   asp-route-id="@Model.CourseId"
                   class="btn btn-outline-secondary btn-rm-back mb-2"
                   style="color:var(--rm-red);border-color:var(--rm-red);">
                <i class="bi bi-arrow-left"></i> Înapoi la Gestionare Curs
            </a>
            <h1>Editare Capitol</h1>
            <p>Modifică conținutul și atașamentele capitolului</p>
        </div>
    </div>
</div>

<div class="rm-two-col" style="grid-template-columns: 3fr 2fr; height: calc(100vh - 220px); min-height: 700px;">

    <!-- LEFT: Chapter Form -->
    <div class="rm-two-col-main" style="display:flex;flex-direction:column;min-height:0;">
        <div class="rm-form-card" style="flex:1;display:flex;flex-direction:column;overflow:hidden;">
            <div class="rm-form-card-header">
                <i class="bi bi-pencil-square" style="color:var(--rm-red);"></i>
                Detalii Capitol
            </div>
            <div class="rm-form-card-body" style="flex:1;display:flex;flex-direction:column;overflow:hidden;padding-bottom:20px;">
                <form asp-action="Edit" method="post" style="display:flex;flex-direction:column;flex:1;min-height:0;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="CourseId" />

                    @if (ViewData.ModelState.ErrorCount > 0)
                    {
                        <div class="rm-alert rm-alert-error mb-3">
                            <i class="bi bi-exclamation-circle-fill"></i>
                            <div asp-validation-summary="ModelOnly"></div>
                        </div>
                    }

                    <div class="d-flex gap-3 mb-3">
                        <div class="rm-field flex-grow-1">
                            <label asp-for="Title" class="rm-label"></label>
                            <input asp-for="Title" class="rm-input" placeholder="Titlul capitolului..." />
                            <span asp-validation-for="Title" class="rm-field-error"></span>
                        </div>
                        <div class="rm-field" style="width:110px;flex-shrink:0;">
                            <label asp-for="Order" class="rm-label"></label>
                            <input asp-for="Order" class="rm-input" placeholder="1, 2, 3..." />
                            <span asp-validation-for="Order" class="rm-field-error"></span>
                        </div>
                    </div>

                    <div class="rm-field" style="flex:1;display:flex;flex-direction:column;min-height:0;margin-bottom:0;">
                        <label asp-for="Content" class="rm-label"></label>
                        <textarea asp-for="Content"
                                  class="rm-input rm-textarea"
                                  placeholder="Scrie conținutul capitolului aici..."></textarea>
                        <span asp-validation-for="Content" class="rm-field-error"></span>
                    </div>

                    <div class="d-flex justify-content-end mt-3">
                        <button type="submit" class="btn-rm-primary">
                            <i class="bi bi-save"></i> Salvează Modificările
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- RIGHT: Attachments Panel -->
    <div class="rm-two-col-side" style="display:flex;flex-direction:column;min-height:0;">
        <div class="rm-form-card" style="flex:1;display:flex;flex-direction:column;overflow:hidden;">
            <div class="rm-form-card-header">
                <i class="bi bi-paperclip" style="color:var(--rm-red);"></i>
                Atașamente
            </div>
            <div class="rm-form-card-body" style="flex:1;display:flex;flex-direction:column;overflow:hidden;">

                <!-- Upload Form -->
                <form asp-controller="ChapterAttachments" asp-action="Create"
                      method="post" enctype="multipart/form-data" class="mb-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="chapterId" value="@Model.Id" />
                    <input type="file" id="uploadFile" name="file"
                           accept=".jpg,.jpeg,.png,.gif,.webp,.mp4,.webm,.mov,.pdf"
                           style="display:none;"
                           onchange="this.closest('form').submit()" />

                    <label class="rm-upload-btn" for="uploadFile" style="width:100%;">
                        <div style="width:36px;height:36px;border-radius:10px;background:var(--rm-red-light);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                            <i class="bi bi-upload" style="color:var(--rm-red);"></i>
                        </div>
                        <div style="flex:1;">
                            <div style="font-weight:600;font-size:0.85rem;">Adaugă Atașament</div>
                            <div style="font-size:0.72rem;color:var(--rm-text-muted);">Imagine, Video, PDF</div>
                        </div>
                        <i class="bi bi-plus-lg" style="color:var(--rm-text-muted);font-size:0.85rem;"></i>
                    </label>
                </form>

                <div style="border-top:1px solid var(--rm-border);margin-bottom:16px;"></div>

                <!-- Attachments List -->
                <div style="flex:1;overflow-y:auto;">
                    @if (attachments == null || !attachments.Any())
                    {
                        <div class="rm-empty-state" style="padding:40px 16px;">
                            <i class="bi bi-paperclip"></i>
                            <p>Niciun atașament adăugat încă.</p>
                        </div>
                    }
                    else
                    {
                        <div style="display:flex;flex-direction:column;gap:8px;">
                            @foreach (var att in attachments)
                            {
                                <div class="rm-attachment-item">
                                    <div style="display:flex;align-items:center;gap:10px;min-width:0;">
                                        <div style="width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;
                                            background:@(att.Type == AttachmentType.Image ? "#e0f2fe" : att.Type == AttachmentType.Video ? "#fef9c3" : "#fdf0f2");">
                                            @if (att.Type == AttachmentType.Image)
                                            {
                                                <i class="bi bi-image" style="color:#0ea5e9;"></i>
                                            }
                                            else if (att.Type == AttachmentType.Video)
                                            {
                                                <i class="bi bi-camera-video" style="color:#ca8a04;"></i>
                                            }
                                            else if (att.Type == AttachmentType.Pdf)
                                            {
                                                <i class="bi bi-file-earmark-pdf" style="color:var(--rm-red);"></i>
                                            }
                                        </div>
                                        <span style="font-size:0.82rem;font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                                            @att.FileName
                                        </span>
                                    </div>
                                    <div style="display:flex;gap:6px;flex-shrink:0;">
                                        <a href="@att.FilePath"
                                               target="_blank"
                                               class="btn-rm-outline"
                                               style="font-size:0.78rem;padding:5px 10px;">
                                            <i class="bi bi-box-arrow-up-right"></i>
                                        </a>
                                        <form asp-controller="ChapterAttachments"
                                              asp-action="Delete"
                                              asp-route-id="@att.Id"
                                              method="post"
                                              onsubmit="return confirm('Ștergi acest atașament?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit"
                                                    class="btn-rm-outline btn-rm-outline-danger"
                                                    style="font-size:0.78rem;padding:5px 10px;">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>

            </div>
        </div>
    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
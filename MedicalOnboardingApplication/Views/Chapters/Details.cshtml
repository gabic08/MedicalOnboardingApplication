<div class="row g-4">

    <!-- MAIN CONTENT -->
    <div class="col-lg-8">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body p-4">

                <div class="d-flex align-items-center gap-2 mb-4">
                    <span class="badge bg-primary rounded-pill px-3 py-2 fs-6">@Model.Order</span>
                    <h4 class="mb-0 fw-semibold">@Model.Title</h4>
                    @if (!isAdmin && isCompleted)
                    {
                        <span class="badge bg-success ms-auto">
                            <i class="bi bi-check-circle-fill me-1"></i> Completed
                        </span>
                    }
                </div>

                <hr class="mb-4" />

                <div class="chapter-content lh-lg">
                    @Html.Raw(Model.Content?.Replace("\n", "<br />"))
                </div>

            </div>
        </div>

        <!-- Attachments -->
        @if (Model.Attachments != null && Model.Attachments.Any())
        {
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="mb-0 fw-semibold text-muted text-uppercase">
                        <i class="bi bi-paperclip me-2"></i> Attachments
                    </h6>
                </div>
                <div class="card-body p-4">
                    @foreach (var att in Model.Attachments)
                    {
                        <div class="mb-4">
                            @if (att.Type == AttachmentType.Image)
                            {
                                <img src="@att.FilePath"
                                     class="img-fluid rounded shadow-sm w-100"
                                     style="max-height: 500px; object-fit: contain;"
                                     alt="@att.FileName" />
                            }
                            else if (att.Type == AttachmentType.Video)
                            {
                                <video controls
                                       class="w-100 rounded shadow-sm"
                                       style="max-height: 500px;"
                                       preload="metadata">
                                    <source src="@att.FilePath" type="video/mp4" />
                                    Your browser does not support the video tag.
                                </video>
                            }
                            else if (att.Type == AttachmentType.Pdf)
                            {
                                <div class="d-flex justify-content-between align-items-center border rounded p-3 bg-light">
                                    <div class="d-flex align-items-center gap-2">
                                        <i class="bi bi-file-earmark-pdf text-danger fs-4"></i>
                                        <span class="fw-semibold">@att.FileName</span>
                                    </div>
                                    <a href="@att.FilePath"
                                       target="_blank"
                                       class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-box-arrow-up-right me-1"></i> Open PDF
                                    </a>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }


        @if (!isAdmin)
        {
            <div class="mt-4 pt-3 border-top d-flex justify-content-end">
                @if (isCompleted)
                {
                    <form asp-action="UnmarkComplete" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="chapterId" value="@Model.Id" />
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-circle-fill me-1"></i> Completed
                        </button>
                    </form>
                }
                else
                {
                    <form asp-action="MarkComplete" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="chapterId" value="@Model.Id" />
                        <button type="submit" class="btn btn-outline-success">
                            <i class="bi bi-check-circle me-1"></i> Mark as Complete
                        </button>
                    </form>
                }
            </div>
        }

        <!-- Navigation -->
        <div class="d-flex justify-content-between align-items-center">
            <div>
                @if (previousChapter != null)
                {
                    <a asp-action="Details"
                       asp-route-id="@previousChapter.Id"
                       class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i> Previous
                    </a>
                }
            </div>
            <div>
                @if (nextChapter != null)
                {
                    <a asp-action="Details"
                       asp-route-id="@nextChapter.Id"
                       class="btn btn-primary">
                        Next <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                }
                else
                {
                    <a asp-controller="Courses"
                       asp-action="Details"
                       asp-route-id="@Model.CourseId"
                       class="btn btn-success">
                        <i class="bi bi-check-circle me-1"></i> Finish Course
                    </a>
                }
            </div>
        </div>
    </div>

    <!-- SIDEBAR: Chapter List -->
    <div class="col-lg-4">
        <div class="card shadow-sm border-0 sticky-top" style="top: 20px;">
            <div class="card-header bg-white border-bottom py-3">
                <h6 class="mb-0 fw-semibold text-muted text-uppercase">
                    <i class="bi bi-list-ol me-2"></i> Chapters
                </h6>
            </div>
            <div class="card-body p-0">
                <ul class="list-group list-group-flush">
                    @foreach (var ch in orderedChapters)
                    {
                        var isActive = ch.Id == Model.Id;
                        var chCompleted = completedIds.Contains(ch.Id);
                        <li class="list-group-item @(isActive ? "bg-primary bg-opacity-10" : "") px-3 py-2">
                            <a asp-action="Details"
                               asp-route-id="@ch.Id"
                               class="text-decoration-none d-flex align-items-center gap-2 @(isActive ? "text-primary fw-semibold" : "text-muted")">
                                <span class="badge @(isActive ? "bg-primary" : "bg-secondary bg-opacity-25 text-secondary") rounded-pill"
                                      style="min-width: 24px;">
                                    @ch.Order
                                </span>
                                <span class="small">@ch.Title</span>
                                @if (chCompleted && !isAdmin)
                                {
                                    <i class="bi bi-check-circle-fill text-success ms-auto"></i>
                                }
                                else if (isActive)
                                {
                                    <i class="bi bi-chevron-right ms-auto"></i>
                                }
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>

</div>

<style>
    .chapter-content {
        font-size: 1.05rem;
        color: #333;
        line-height: 1.8;
    }
</style>

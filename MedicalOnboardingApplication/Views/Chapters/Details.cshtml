@using MedicalOnboardingApplication.Data
@model MedicalOnboardingApplication.Models.Chapter

@{
    ViewData["Title"] = Model.Title;

    var orderedChapters = Model.Course.Chapters
        .OrderBy(c => c.Order)
        .ToList();

    var currentIndex = orderedChapters.FindIndex(c => c.Id == Model.Id);

    var previousChapter = currentIndex > 0
        ? orderedChapters[currentIndex - 1]
        : null;

    var nextChapter = currentIndex < orderedChapters.Count - 1
        ? orderedChapters[currentIndex + 1]
        : null;
}

<div class="mb-4">
    <a asp-controller="Courses"
       asp-action="Details"
       asp-route-id="@Model.CourseId"
       class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i> Back to Course
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="mb-0">
                <span class="badge bg-secondary me-2">
                    @Model.Order
                </span>
                @Model.Title
            </h4>
        </div>

        <hr />

        <!-- Chapter Content -->
        <div class="mb-4">
            @Html.Raw(Model.Content?.Replace("\n", "<br />"))
        </div>

        <!-- Attachments -->
        @if (Model.Attachments != null && Model.Attachments.Any())
        {
            @foreach (var att in Model.Attachments)
            {
                <div class="mb-4 text-center">

                    @if (att.Type == AttachmentType.Image)
                    {
                        <img src="@att.FilePath"
                             class="img-fluid rounded shadow-sm"
                             style="max-height: 500px; object-fit: contain;"
                             alt="Chapter Image" />
                    }
                    else if (att.Type == AttachmentType.Video)
                    {
                        <video controls
                               class="w-100 rounded shadow-sm"
                               style="max-height: 500px;"
                               preload="metadata">
                            <source src="@att.FilePath" type="video/mp4" />
                            Your browser does not support the video tag.
                        </video>
                    }
                    else if (att.Type == AttachmentType.Pdf)
                    {
                        <div class="d-flex justify-content-between align-items-center border rounded p-3">
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-file-earmark-pdf text-danger"></i>
                                @att.FileName
                            </div>

                            <a href="@att.FilePath"
                               target="_blank"
                               class="btn btn-sm btn-outline-primary">
                                Open PDF
                            </a>
                        </div>
                    }

                </div>
            }
        }


        <!-- Navigation -->
        <div class="d-flex justify-content-between">

            <div>
                @if (previousChapter != null)
                {
                    <a asp-action="Details"
                       asp-route-id="@previousChapter.Id"
                       class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i>
                        Previous
                    </a>
                }
            </div>

            <div>
                @if (nextChapter != null)
                {
                    <a asp-action="Details"
                       asp-route-id="@nextChapter.Id"
                       class="btn btn-primary">
                        Next
                        <i class="bi bi-arrow-right"></i>
                    </a>
                }
            </div>

        </div>

    </div>
</div>
    
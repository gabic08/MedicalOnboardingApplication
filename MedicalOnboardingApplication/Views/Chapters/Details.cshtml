@using MedicalOnboardingApplication.Data
@model MedicalOnboardingApplication.Models.Chapter

@{
    ViewData["Title"] = Model.Title;

    var orderedChapters = Model.Course.Chapters
        .OrderBy(c => c.Order)
        .ToList();

    var currentIndex = orderedChapters.FindIndex(c => c.Id == Model.Id);
    var previousChapter = currentIndex > 0 ? orderedChapters[currentIndex - 1] : null;
    var nextChapter = currentIndex < orderedChapters.Count - 1 ? orderedChapters[currentIndex + 1] : null;
    var totalChapters = orderedChapters.Count;
    var progress = (int)Math.Round((double)(currentIndex + 1) / totalChapters * 100);

    var isAdmin = ViewBag.IsAdmin as bool? ?? false;
    var completedIds = ViewBag.CompletedChapterIds as List<int> ?? new List<int>();
    var isCompleted = completedIds.Contains(Model.Id);
}

<div class="mb-3">
    <a asp-controller="Courses"
       asp-action="Details"
       asp-route-id="@Model.CourseId"
       class="btn btn-outline-secondary btn-sm mb-2">
        <i class="bi bi-arrow-left"></i> Înapoi la Curs
    </a>
</div>

<!-- Progress Bar -->
<div class="mb-4">
    <div class="d-flex justify-content-between align-items-center mb-1">
        <small class="text-muted">Capitolul @(currentIndex + 1) din @totalChapters</small>
    </div>
    <div class="progress" style="height: 6px;">
        <div class="progress-bar" role="progressbar"
             style="width: @progress%"
             aria-valuenow="@progress"
             aria-valuemin="0"
             aria-valuemax="100">
        </div>
    </div>
</div>

<div class="card shadow-sm border-0 mb-2">
    <div class="card-body p-2">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-1">

            <!-- Previous -->
            <div>
                @if (previousChapter != null)
                {
                    <a asp-action="Details"
                       asp-route-id="@previousChapter.Id"
                       class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i> Anterior
                    </a>
                }
            </div>

            <!-- Next -->
            <div>
                @if (nextChapter != null)
                {
                    <a asp-action="Details"
                       asp-route-id="@nextChapter.Id"
                       class="btn btn-primary">
                        Următorul <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                }
            </div>

        </div>
    </div>
</div>

<!-- MAIN CONTENT -->
<div class="card shadow-sm border-0 mb-4">
    <div class="card-body p-4">

        <div class="d-flex align-items-center gap-2 mb-4">
            <span class="badge bg-primary rounded-pill px-3 py-2 fs-6">@Model.Order</span>
            <h4 class="mb-0 fw-semibold">@Model.Title</h4>
            @if (!isAdmin && isCompleted)
            {
                <span class="badge bg-success ms-auto px-3 py-2">
                    <i class="bi bi-check-circle-fill me-1"></i> Finalizat
                </span>
            }
        </div>

        <hr class="mb-4" />

        <div class="chapter-content lh-lg">
            @Html.Raw(Model.Content?.Replace("\n", "<br />"))
        </div>

    </div>
</div>

<!-- Attachments -->
@if (Model.Attachments != null && Model.Attachments.Any())
{
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-4">
            @foreach (var att in Model.Attachments)
            {
                <div class="mb-4">
                    @if (att.Type == AttachmentType.Image)
                    {
                        <img src="@att.FilePath"
                             class="img-fluid rounded shadow-sm w-100"
                             style="max-height: 500px; object-fit: contain;"
                             alt="@att.FileName" />
                    }
                    else if (att.Type == AttachmentType.Video)
                    {
                        <video controls
                               class="w-100 rounded shadow-sm"
                               style="max-height: 500px;"
                               preload="metadata">
                            <source src="@att.FilePath" type="video/mp4" />
                            Browserul tău nu suportă redarea video.
                        </video>
                    }
                    else if (att.Type == AttachmentType.Pdf)
                    {
                        <div class="d-flex justify-content-between align-items-center border rounded p-3 bg-light">
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-file-earmark-pdf text-danger fs-4"></i>
                                <span class="fw-semibold">@att.FileName</span>
                            </div>
                            <a href="@att.FilePath"
                               target="_blank"
                               class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-box-arrow-up-right me-1"></i> Deschide PDF
                            </a>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

<!-- Mark as Complete + Navigation -->
<div class="card shadow-sm border-0 mb-3">
    <div class="card-body p-3">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">

            <!-- Previous -->
            <div>
                @if (previousChapter != null)
                {
                    <a asp-action="Details"
                       asp-route-id="@previousChapter.Id"
                       class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i> Anterior
                    </a>
                }
            </div>

            <!-- Mark Complete -->
            @if (!isAdmin)
            {
                <div id="completeSection">
                    @if (isCompleted)
                    {
                        <button type="button"
                                id="completeBtn"
                                onclick="toggleComplete(@Model.Id, true)"
                                class="btn btn-success px-4">
                            <i class="bi bi-check-circle-fill me-2"></i> Finalizat — Click pentru Anulare
                        </button>
                    }
                    else
                    {
                        <button type="button"
                                id="completeBtn"
                                onclick="toggleComplete(@Model.Id, false)"
                                class="btn btn-outline-success px-4">
                            <i class="bi bi-check-circle me-2"></i> Marchează ca Finalizat
                        </button>
                    }
                </div>
            }

            <!-- Next -->
            <div>
                @if (nextChapter != null)
                {
                    <a asp-action="Details"
                       asp-route-id="@nextChapter.Id"
                       class="btn btn-primary">
                        Următorul <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                }
            </div>

        </div>
    </div>
</div>

<div class="mb-3">
    <a asp-controller="Courses"
       asp-action="Details"
       asp-route-id="@Model.CourseId"
       class="btn btn-outline-secondary btn-sm mb-2">
        <i class="bi bi-arrow-left"></i> Înapoi la Curs
    </a>
</div>

<style>
    .chapter-content {
        font-size: 1.05rem;
        color: #333;
        line-height: 1.8;
    }
</style>

@section Scripts {
    <script>
        async function toggleComplete(chapterId, isCurrentlyCompleted) {
            const action = isCurrentlyCompleted ? 'UnmarkComplete' : 'MarkComplete';
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value
                       ?? '@Html.AntiForgeryToken()';

            const formData = new FormData();
            formData.append('chapterId', chapterId);
            formData.append('__RequestVerificationToken',
                document.cookie.match(/RequestVerificationToken=([^;]+)/)?.[1] ?? '');

            try {
                const response = await fetch(`/Chapters/${action}`, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': document.querySelector(
                            'input[name="__RequestVerificationToken"]').value
                    },
                    body: formData
                });

                if (response.ok || response.redirected) {
                    const btn = document.getElementById('completeBtn');
                    const header = document.querySelector('.badge.bg-success');

                    if (isCurrentlyCompleted) {
                        btn.className = 'btn btn-outline-success px-4';
                        btn.innerHTML = '<i class="bi bi-check-circle me-2"></i> Marchează ca Finalizat';
                        btn.setAttribute('onclick', `toggleComplete(${chapterId}, false)`);
                        if (header) header.remove();
                    } else {
                        btn.className = 'btn btn-success px-4';
                        btn.innerHTML = '<i class="bi bi-check-circle-fill me-2"></i> Finalizat — Click pentru Anulare';
                        btn.setAttribute('onclick', `toggleComplete(${chapterId}, true)`);

                        const titleRow = document.querySelector('.d-flex.align-items-center.gap-2.mb-4');
                        if (titleRow && !titleRow.querySelector('.badge.bg-success')) {
                            const badge = document.createElement('span');
                            badge.className = 'badge bg-success ms-auto px-3 py-2';
                            badge.innerHTML = '<i class="bi bi-check-circle-fill me-1"></i> Finalizat';
                            titleRow.appendChild(badge);
                        }
                    }
                }
            } catch (err) {
                console.error('Eroare la schimbarea stării capitolului:', err);
            }
        }
    </script>
}
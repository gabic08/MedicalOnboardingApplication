@using MedicalOnboardingApplication.Enums
@model MedicalOnboardingApplication.Models.Chapter

@{
    ViewData["Title"] = Model.Title;

    var orderedChapters = Model.Course.Chapters.OrderBy(c => c.Order).ToList();
    var currentIndex = orderedChapters.FindIndex(c => c.Id == Model.Id);
    var previousChapter = currentIndex > 0 ? orderedChapters[currentIndex - 1] : null;
    var nextChapter = currentIndex < orderedChapters.Count - 1 ? orderedChapters[currentIndex + 1] : null;
    var totalChapters = orderedChapters.Count;
    var progress = (int)Math.Round((double)(currentIndex + 1) / totalChapters * 100);

    var isAdmin = ViewBag.IsAdmin as bool? ?? false;
    var completedIds = ViewBag.CompletedChapterIds as List<int> ?? new List<int>();
    var isCompleted = completedIds.Contains(Model.Id);

    string backUrlCourses = isAdmin
        ? Url.Action("Index", "AdminCourses")
        : Url.Action("Index", "Courses");

    string backUrlDashboard = isAdmin
        ? Url.Action("Index", "Admin")
        : Url.Action("Index", "Dashboard");

    string backUrlCurrentCourse = isAdmin
            ? Url.Action("Manage", "AdminCourses", new { id = Model.CourseId })
            : Url.Action("Details", "Courses", new { id = Model.CourseId });
}

<div class="rm-page-header">
    <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
        <div>
            <div class="breadcrumb-label">
                <a href="@backUrlDashboard" class="text-decoration-none" style="color:inherit;">
                    @(isAdmin ? "Panou Admin" : "Panou")
                </a>
                <i class="bi bi-chevron-right mx-1" style="font-size:0.65rem;"></i>

                <a href="@backUrlCourses" class="text-decoration-none" style="color:inherit;">
                    @(isAdmin ? "Cursuri Admin" : "Cursuri")
                </a>
                <i class="bi bi-chevron-right mx-1" style="font-size:0.65rem;"></i>

                <a href="@backUrlCurrentCourse" class="text-decoration-none" style="color:inherit;">
                    @Model.Course.Title
                </a>
                <i class="bi bi-chevron-right mx-1" style="font-size:0.65rem;"></i>
                @Model.Title
            </div>
        </div>
    </div>
</div>

<div class="rm-chapter-layout">

    <!-- ===================== -->
    <!-- SIDEBAR               -->
    <!-- ===================== -->
    <aside class="rm-chapter-sidebar">
        <div class="rm-chapter-sidebar-inner">

            <div class="rm-chapter-sidebar-header">
                <a asp-controller="Courses"
                       asp-action="Details"
                       asp-route-id="@Model.CourseId"
                       class="btn btn-outline-secondary btn-rm-back mb-2"
                       style="color:var(--rm-red);border-color:var(--rm-red);">
                    <i class="bi bi-arrow-left"></i> Înapoi la Curs
                </a>
                <p class="rm-chapter-course-name">@Model.Course.Title</p>
                <div class="rm-chapter-progress-label">
                    <span>@(currentIndex + 1) / @totalChapters capitole</span>
                    <span>@progress%</span>
                </div>
            </div>

            <nav class="rm-chapter-nav">
                @foreach (var ch in orderedChapters)
                {
                    var chCompleted = completedIds.Contains(ch.Id);
                    var isCurrent = ch.Id == Model.Id;
                    <a asp-action="Details"
                           asp-route-id="@ch.Id"
                           class="rm-chapter-nav-item @(isCurrent ? "rm-chapter-nav-item--active" : "") @(chCompleted ? "rm-chapter-nav-item--done" : "")">
                        <div class="rm-chapter-nav-dot">
                            @if (chCompleted)
                            {
                                <i class="bi bi-check-lg"></i>
                            }
                            else
                            {
                                <span>@ch.Order</span>
                            }
                        </div>
                        <span class="rm-chapter-nav-title">@ch.Title</span>
                    </a>
                }
            </nav>

        </div>
    </aside>

    <!-- ===================== -->
    <!-- MAIN CONTENT          -->
    <!-- ===================== -->
    <main class="rm-chapter-main">

        <!-- Scrollable area: header + content + attachments -->
        <div class="rm-chapter-scroll-area">

            <!-- Chapter Header -->
            <div class="rm-chapter-header">
                <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
                    <span class="rm-badge rm-badge-order" style="font-size:0.85rem;padding:6px 12px;">@Model.Order</span>
                    <h1 class="rm-chapter-title">@Model.Title</h1>
                    @if (!isAdmin && isCompleted)
                    {
                        <span class="rm-status-badge rm-status-green ms-auto">
                            <i class="bi bi-check-circle-fill"></i> Finalizat
                        </span>
                    }
                </div>
            </div>

            <!-- Content -->
            <div class="rm-form-card mb-4">
                <div class="rm-form-card-body">
                    <div class="rm-chapter-content">
                        @Html.Raw(Model.Content?.Replace("\n", "<br />"))
                    </div>
                </div>
            </div>

            <!-- Attachments -->
            @if (Model.Attachments != null && Model.Attachments.Any())
            {
                <div class="rm-form-card mb-4">
                    <div class="rm-form-card-header">
                        <i class="bi bi-paperclip" style="color:var(--rm-red);"></i>
                        Atașamente
                        <span class="rm-count-badge" style="background:#f0f0f0;color:#666;">@Model.Attachments.Count</span>
                    </div>
                    <div class="rm-form-card-body" style="display:flex;flex-direction:column;gap:20px;">
                        @foreach (var att in Model.Attachments)
                        {
                            @if (att.Type == AttachmentType.Image)
                            {
                                <img src="@att.FilePath"
                                     style="width:100%;max-height:500px;object-fit:contain;border-radius:var(--rm-radius-sm);border:1px solid var(--rm-border);"
                                     alt="@att.FileName" />
                            }
                            else if (att.Type == AttachmentType.Video)
                            {
                                <video controls
                                       style="width:100%;max-height:500px;border-radius:var(--rm-radius-sm);"
                                       preload="metadata">
                                    <source src="@att.FilePath" type="video/mp4" />
                                    Browserul tău nu suportă redarea video.
                                </video>
                            }
                            else if (att.Type == AttachmentType.Pdf)
                            {
                                <div class="rm-attachment-item">
                                    <div style="display:flex;align-items:center;gap:10px;">
                                        <div style="width:36px;height:36px;border-radius:10px;background:#fdf0f2;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                            <i class="bi bi-file-earmark-pdf" style="color:var(--rm-red);font-size:1.1rem;"></i>
                                        </div>
                                        <span style="font-weight:600;font-size:0.875rem;">@att.FileName</span>
                                    </div>
                                    <a href="@att.FilePath" target="_blank" class="btn-rm-outline" style="font-size:0.82rem;">
                                        <i class="bi bi-box-arrow-up-right"></i> Deschide PDF
                                    </a>
                                </div>
                            }
                        }
                    </div>
                </div>
            }

        </div>
        <!-- end .rm-chapter-scroll-area -->
        <!-- Bottom Navigation — pinned outside scroll area -->
        <div class="rm-chapter-nav-footer">
            <div>
                @if (previousChapter != null)
                {
                    <a asp-action="Details" asp-route-id="@previousChapter.Id" class="btn-rm-secondary">
                        <i class="bi bi-arrow-left"></i> Anterior
                    </a>
                }
            </div>

            @if (!isAdmin)
            {
                <div id="completeSection">
                    @if (isCompleted)
                    {
                        <button type="button" id="completeBtn"
                                onclick="toggleComplete(@Model.Id, true)"
                                class="btn-rm-success">
                            <i class="bi bi-check-circle-fill"></i> Finalizat — Click pentru Anulare
                        </button>
                    }
                    else
                    {
                        <button type="button" id="completeBtn"
                                onclick="toggleComplete(@Model.Id, false)"
                                class="btn-rm-outline">
                            <i class="bi bi-check-circle"></i> Marchează ca Finalizat
                        </button>
                    }
                </div>
            }

            <div>
                @if (nextChapter != null)
                {
                    <a asp-action="Details" asp-route-id="@nextChapter.Id" class="btn-rm-primary">
                        Următorul <i class="bi bi-arrow-right"></i>
                    </a>
                }
            </div>
        </div>

    </main>

</div>

@section Scripts {
    <script>
        async function toggleComplete(chapterId, isCurrentlyCompleted) {
            const action = isCurrentlyCompleted ? 'UnmarkComplete' : 'MarkComplete';
            const formData = new FormData();
            formData.append('chapterId', chapterId);

            try {
                const response = await fetch(`/Chapters/${action}`, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': document.querySelector(
                            'input[name="__RequestVerificationToken"]').value
                    },
                    body: formData
                });

                if (response.ok || response.redirected) {
                    const btn = document.getElementById('completeBtn');
                    const headerBadge = document.querySelector('.rm-status-badge.rm-status-green');
                    const titleRow = document.querySelector('.rm-chapter-header .d-flex');

                    if (isCurrentlyCompleted) {
                        btn.className = 'btn-rm-outline';
                        btn.innerHTML = '<i class="bi bi-check-circle"></i> Marchează ca Finalizat';
                        btn.setAttribute('onclick', `toggleComplete(${chapterId}, false)`);
                        if (headerBadge) headerBadge.remove();

                        const sidebarItem = document.querySelector('.rm-chapter-nav-item--active .rm-chapter-nav-dot');
                        if (sidebarItem) {
                            sidebarItem.innerHTML = '<span>@Model.Order</span>';
                        }
                        document.querySelector('.rm-chapter-nav-item--active')?.classList.remove('rm-chapter-nav-item--done');
                    } else {
                        btn.className = 'btn-rm-success';
                        btn.innerHTML = '<i class="bi bi-check-circle-fill"></i> Finalizat — Click pentru Anulare';
                        btn.setAttribute('onclick', `toggleComplete(${chapterId}, true)`);

                        if (titleRow && !headerBadge) {
                            const badge = document.createElement('span');
                            badge.className = 'rm-status-badge rm-status-green ms-auto';
                            badge.innerHTML = '<i class="bi bi-check-circle-fill"></i> Finalizat';
                            titleRow.appendChild(badge);
                        }

                        const sidebarItem = document.querySelector('.rm-chapter-nav-item--active .rm-chapter-nav-dot');
                        if (sidebarItem) {
                            sidebarItem.innerHTML = '<i class="bi bi-check-lg"></i>';
                        }
                        document.querySelector('.rm-chapter-nav-item--active')?.classList.add('rm-chapter-nav-item--done');
                    }
                }
            } catch (err) {
                console.error('Eroare:', err);
            }
        }
    </script>
}
@using MedicalOnboardingApplication.Data
@model MedicalOnboardingApplication.Models.Chapter

@{
    ViewData["Title"] = Model.Title;

    var orderedChapters = Model.Course.Chapters
        .OrderBy(c => c.Order)
        .ToList();

    var currentIndex = orderedChapters.FindIndex(c => c.Id == Model.Id);
    var previousChapter = currentIndex > 0 ? orderedChapters[currentIndex - 1] : null;
    var nextChapter = currentIndex < orderedChapters.Count - 1 ? orderedChapters[currentIndex + 1] : null;
    var totalChapters = orderedChapters.Count;
    var progress = (int)Math.Round((double)(currentIndex + 1) / totalChapters * 100);

    var isAdmin = ViewBag.IsAdmin as bool? ?? false;
    var completedIds = ViewBag.CompletedChapterIds as List<int> ?? new List<int>();
    var isCompleted = completedIds.Contains(Model.Id);
}

<div class="mb-3">
    <a asp-controller="Courses"
       asp-action="Details"
       asp-route-id="@Model.CourseId"
       class="btn btn-outline-secondary btn-sm mb-2">
        <i class="bi bi-arrow-left"></i> Back to Course
    </a>
    <h1 class="mb-0">@Model.Title</h1>
</div>


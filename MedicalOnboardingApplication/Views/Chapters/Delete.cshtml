@model MedicalOnboardingApplication.Models.Chapter

@{
    ViewData["Title"] = "Delete Chapter";
}

<h1>Delete Chapter</h1>

<hr />

<div class="alert alert-danger">
    Are you sure you want to delete this chapter?
</div>

<div class="card mb-3">
    <div class="card-body">
        <h5 class="card-title">@Model.Order. @Model.Title</h5>
        <p class="card-text">@Model.Content</p>
    </div>
</div>

<form asp-action="DeleteConfirmed" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <div class="d-flex justify-content-between">
        <a asp-controller="AdminCourses"
           asp-action="Details"
           asp-route-id="@Model.CourseId"
           class="btn btn-outline-secondary">
            Cancel
        </a>

        <button type="submit" class="btn btn-danger">
            Delete Chapter
        </button>
    </div>
</form>

@model MedicalOnboardingApplication.Models.Chapter

@{
    ViewData["Title"] = "Create Chapter";
}

<h1 class="mb-4">Create Chapter</h1>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="CourseId" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row">
                <div class="col-md-8 mb-3">
                    <label asp-for="Title" class="form-label"></label>
                    <input asp-for="Title" class="form-control" placeholder="Chapter title..." />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="col-md-4 mb-3">
                    <label asp-for="Order" class="form-label"></label>
                    <input asp-for="Order" class="form-control" />
                    <span asp-validation-for="Order" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Content" class="form-label"></label>
                <textarea asp-for="Content"
                          class="form-control chapter-content-box"
                          rows="22"
                          placeholder="Write your chapter content here. You can paste guides, policies, or long documentation (1000+ words supported)."></textarea>
                <span asp-validation-for="Content" class="text-danger"></span>
            </div>

            <hr />

            <div class="alert alert-info d-flex align-items-center">
                <i class="bi bi-info-circle me-2"></i>
                Save this chapter first to add file or link attachments.
            </div>

            <div class="d-flex justify-content-between mt-4">
                <a asp-controller="AdminCourses"
                   asp-action="Manage"
                   asp-route-id="@Model.CourseId"
                   class="btn btn-outline-secondary">
                    Cancel
                </a>

                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-save"></i> Save Chapter
                </button>
            </div>
        </form>
    </div>
</div>

<style>
    .chapter-content-box {
        min-height: 420px;
        resize: vertical;
        font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        line-height: 1.6;
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

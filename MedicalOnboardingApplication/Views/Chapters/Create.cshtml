@model MedicalOnboardingApplication.ViewModels.CreateChapterViewModel
@using MedicalOnboardingApplication.Models

@{
    ViewData["Title"] = "Creare Capitol";
}

<!-- Page Header -->
<div class="rm-page-header">
    <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
        <div>
            <div class="breadcrumb-label">
                <a asp-controller="Admin" asp-action="Index" class="text-decoration-none" style="color:inherit;">Panou Admin</a>
                <i class="bi bi-chevron-right mx-1" style="font-size:0.65rem;"></i>
                <a asp-controller="AdminCourses" asp-action="Index" class="text-decoration-none" style="color:inherit;">Cursuri</a>
                <i class="bi bi-chevron-right mx-1" style="font-size:0.65rem;"></i>
                <a asp-controller="AdminCourses" asp-action="Manage" asp-route-id="@Model.CourseId" class="text-decoration-none" style="color:inherit;">Gestionare</a>
                <i class="bi bi-chevron-right mx-1" style="font-size:0.65rem;"></i>
                Capitol Nou
            </div>
            <h1>Creare Capitol</h1>
            <p>Adaugă un capitol nou cu conținut și atașamente</p>
        </div>
    </div>
</div>

<div class="rm-two-col" style="grid-template-columns: 3fr 2fr; height: calc(100vh - 220px); min-height: 700px;">

    <!-- LEFT: Chapter Form -->
    <div class="rm-two-col-main" style="display:flex;flex-direction:column;min-height:0;">
        <div class="rm-form-card" style="flex:1;display:flex;flex-direction:column;overflow:hidden;">
            <div class="rm-form-card-header">
                <i class="bi bi-journal-text" style="color:var(--rm-red);"></i>
                Detalii Capitol
            </div>
            <div class="rm-form-card-body" style="flex:1;display:flex;flex-direction:column;overflow:hidden;padding-bottom:20px;">
                <form asp-action="Create" method="post" style="display:flex;flex-direction:column;flex:1;min-height:0;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="CourseId" />

                    @if (ViewData.ModelState.ErrorCount > 0)
                    {
                        <div class="rm-alert rm-alert-error mb-3">
                            <i class="bi bi-exclamation-circle-fill"></i>
                            <div asp-validation-summary="ModelOnly"></div>
                        </div>
                    }

                    <div class="rm-field mb-3">
                        <label asp-for="Title" class="rm-label"></label>
                        <input asp-for="Title" class="rm-input" placeholder="Titlul capitolului..." />
                        <span asp-validation-for="Title" class="rm-field-error"></span>
                    </div>

                    <div class="rm-field mb-3" style="max-width:160px;">
                        <label asp-for="Order" class="rm-label"></label>
                        <input asp-for="Order" class="rm-input" placeholder="1, 2, 3..." />
                        <span asp-validation-for="Order" class="rm-field-error"></span>
                    </div>

                    <div class="rm-field" style="flex:1;display:flex;flex-direction:column;min-height:0;margin-bottom:0;">
                        <label asp-for="Content" class="rm-label"></label>
                        <textarea asp-for="Content"
                                  class="rm-input rm-textarea"
                                  placeholder="Scrie conținutul capitolului aici..."></textarea>
                        <span asp-validation-for="Content" class="rm-field-error"></span>
                    </div>

                    <div class="d-flex justify-content-end mt-3">
                        <button type="submit" class="btn-rm-primary">
                            <i class="bi bi-save"></i> Salvează Capitolul
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- RIGHT: Attachments Panel -->
    <div class="rm-two-col-side" style="display:flex;flex-direction:column;min-height:0;">
        <div class="rm-form-card" style="flex:1;display:flex;flex-direction:column;overflow:hidden;">
            <div class="rm-form-card-header" style="justify-content:space-between;">
                <div style="display:flex;align-items:center;gap:8px;">
                    <i class="bi bi-paperclip" style="color:var(--rm-red);"></i>
                    Atașamente
                </div>
                <button class="btn-rm-success" style="font-size:0.78rem;padding:5px 12px;opacity:0.4;pointer-events:none;" disabled>
                    <i class="bi bi-plus-lg"></i> Adaugă
                </button>
            </div>
            <div class="rm-form-card-body" style="flex:1;overflow-y:auto;">
                <div class="rm-info-notice mb-4">
                    <i class="bi bi-info-circle-fill"></i>
                    Salvează capitolul mai întâi pentru a activa atașamentele.
                </div>

                <div style="opacity:0.4;pointer-events:none;">
                    <div class="rm-attachment-item mb-2">
                        <div style="display:flex;align-items:center;gap:8px;font-size:0.875rem;">
                            <i class="bi bi-image" style="color:#0ea5e9;"></i>
                            Atașament Imagine
                        </div>
                        <button class="btn-rm-outline" style="font-size:0.78rem;padding:5px 12px;" disabled>
                            Deschide
                        </button>
                    </div>

                    <div class="rm-attachment-item mb-2">
                        <div style="display:flex;align-items:center;gap:8px;font-size:0.875rem;">
                            <i class="bi bi-camera-video" style="color:#ca8a04;"></i>
                            Atașament Video
                        </div>
                        <button class="btn-rm-outline" style="font-size:0.78rem;padding:5px 12px;" disabled>
                            Deschide
                        </button>
                    </div>

                    <div class="rm-attachment-item">
                        <div style="display:flex;align-items:center;gap:8px;font-size:0.875rem;">
                            <i class="bi bi-file-earmark-pdf" style="color:var(--rm-red);"></i>
                            Atașament PDF
                        </div>
                        <button class="btn-rm-outline" style="font-size:0.78rem;padding:5px 12px;" disabled>
                            Deschide
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
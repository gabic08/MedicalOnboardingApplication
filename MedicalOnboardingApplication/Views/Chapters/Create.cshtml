@model MedicalOnboardingApplication.ViewModels.CreateChapterViewModel
@using MedicalOnboardingApplication.Models

@{
    ViewData["Title"] = "Creare Capitol";
}

<div class="mb-3">
    <a asp-controller="AdminCourses"
       asp-action="Manage"
       asp-route-id="@Model.CourseId"
       class="btn btn-outline-secondary mb-2">
        <i class="bi bi-arrow-left"></i> Înapoi la Curs
    </a>
    <h1 class="mb-0">Creare Capitol</h1>
</div>

<div class="row g-3" style="height: calc(100vh - 180px);">

    <!-- CHAPTER FORM -->
    <div class="col-lg-6 h-100">
        <div class="card shadow-sm h-100">
            <div class="card-body d-flex flex-column">
                <form asp-action="Create" method="post" class="d-flex flex-column flex-grow-1">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="CourseId" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label"></label>
                        <input asp-for="Title"
                               class="form-control"
                               placeholder="Titlul capitolului..." />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Order" class="form-label"></label>
                        <input asp-for="Order"
                               class="form-control"
                               placeholder="Ordinea capitolului (1, 2, 3...)" />
                        <span asp-validation-for="Order" class="text-danger"></span>
                    </div>

                    <div class="mb-3 flex-grow-1 d-flex flex-column">
                        <label asp-for="Content" class="form-label"></label>
                        <textarea asp-for="Content"
                                  class="form-control flex-grow-1"
                                  style="resize: none; font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; line-height: 1.6;"
                                  placeholder="Scrie conținutul capitolului aici..."></textarea>
                        <span asp-validation-for="Content" class="text-danger"></span>
                    </div>

                    <div class="d-flex justify-content-end">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save"></i> Salvează Capitolul
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- ATTACHMENTS PANEL -->
    <div class="col-lg-6 h-100">
        <div class="card shadow-sm h-100">
            <div class="card-body d-flex flex-column">

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">Atașamente</h5>
                    <button class="btn btn-sm btn-success" disabled>
                        <i class="bi bi-plus-circle"></i> Adaugă
                    </button>
                </div>

                <div class="alert alert-info">
                    <i class="bi bi-info-circle me-2"></i>
                    Salvează capitolul mai întâi pentru a activa atașamentele.
                </div>

                <ul class="list-group list-group-flush opacity-50">
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span class="d-flex align-items-center gap-2">
                            <i class="bi bi-image"></i>
                            Atașament Imagine
                        </span>
                        <button class="btn btn-sm btn-outline-secondary" disabled>
                            Deschide
                        </button>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span class="d-flex align-items-center gap-2">
                            <i class="bi bi-file-earmark-pdf"></i>
                            Atașament PDF
                        </span>
                        <button class="btn btn-sm btn-outline-secondary" disabled>
                            Deschide
                        </button>
                    </li>
                </ul>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

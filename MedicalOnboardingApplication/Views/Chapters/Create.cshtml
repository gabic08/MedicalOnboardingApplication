@model MedicalOnboardingApplication.Models.Chapter
@using MedicalOnboardingApplication.Models

@{
    ViewData["Title"] = "Create Chapter";
}

<h1 class="mb-4">Create Chapter</h1>

<div class="row">
    <!-- CHAPTER FORM -->
    <div class="col-lg-7">
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <input type="hidden" asp-for="CourseId" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label"></label>
                        <input asp-for="Title"
                               class="form-control"
                               placeholder="Chapter title..." />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Order" class="form-label"></label>
                        <input asp-for="Order"
                               class="form-control"
                               placeholder="Chapter order (1, 2, 3...)" />
                        <span asp-validation-for="Order" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Content" class="form-label"></label>
                        <textarea asp-for="Content"
                                  class="form-control chapter-content-box"
                                  rows="18"
                                  placeholder="Write your chapter content here..."></textarea>
                        <span asp-validation-for="Content" class="text-danger"></span>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-controller="AdminCourses"
                           asp-action="Manage"
                           asp-route-id="@Model.CourseId"
                           class="btn btn-outline-secondary">
                            Back to Course
                        </a>

                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save"></i> Save Chapter
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- ATTACHMENTS PANEL -->
    <div class="col-lg-5">
        <div class="card shadow-sm h-100">
            <div class="card-body">

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">Attachments</h5>

                    <button class="btn btn-sm btn-success" disabled>
                        <i class="bi bi-plus-circle"></i> Add
                    </button>
                </div>

                <div class="alert alert-info">
                    <i class="bi bi-info-circle me-2"></i>
                    Save this chapter first to enable attachments.
                </div>

                <ul class="list-group list-group-flush opacity-50">
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span class="d-flex align-items-center gap-2">
                            <i class="bi bi-image"></i>
                            Image Attachment
                        </span>
                        <button class="btn btn-sm btn-outline-secondary" disabled>
                            Open
                        </button>
                    </li>

                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span class="d-flex align-items-center gap-2">
                            <i class="bi bi-file-earmark-pdf"></i>
                            PDF Attachment
                        </span>
                        <button class="btn btn-sm btn-outline-secondary" disabled>
                            Open
                        </button>
                    </li>
                </ul>

            </div>
        </div>
    </div>
</div>

<style>
    .chapter-content-box {
        min-height: 420px;
        resize: vertical;
        font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        line-height: 1.6;
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

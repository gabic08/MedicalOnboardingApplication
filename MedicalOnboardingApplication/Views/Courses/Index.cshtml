@model IEnumerable<MedicalOnboardingApplication.Models.Course>
@{
    ViewData["Title"] = "Cursuri";
    var search = ViewBag.Search as string;
    var filter = ViewBag.Filter as string ?? "all";
    var completedCourseIds = ViewBag.CompletedCourseIds as List<int> ?? new List<int>();
    var completedChapterIds = ViewBag.CompletedChapterIds as List<int> ?? new List<int>();
}

<div class="mb-4">
    <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-secondary mb-2">
        <i class="bi bi-arrow-left"></i> Înapoi la Panou
    </a>
    <h1 class="mb-0">Cursuri</h1>
</div>

<!-- Search & Filter -->
<div class="mb-4">
    <form method="get" class="row g-2 align-items-center">
        <div class="col-md-4">
            <input type="text"
                   name="search"
                   value="@search"
                   class="form-control"
                   placeholder="Caută cursuri..." />
        </div>
        <div class="col-md-auto">
            <div class="btn-group" role="group">
                <a asp-action="Index"
                   asp-route-search="@search"
                   asp-route-filter="all"
                   class="btn @(filter == "all" ? "btn-primary" : "btn-outline-primary")">
                    Toate
                </a>
                <a asp-action="Index"
                   asp-route-search="@search"
                   asp-route-filter="notstarted"
                   class="btn @(filter == "notstarted" ? "btn-secondary" : "btn-outline-secondary")">
                    <i class="bi bi-circle me-1"></i> Neîncepute
                </a>
                <a asp-action="Index"
                   asp-route-search="@search"
                   asp-route-filter="inprogress"
                   class="btn @(filter == "inprogress" ? "btn-primary" : "btn-outline-primary")">
                    <i class="bi bi-hourglass-split me-1"></i> În Progres
                </a>
                <a asp-action="Index"
                   asp-route-search="@search"
                   asp-route-filter="completed"
                   class="btn @(filter == "completed" ? "btn-success" : "btn-outline-success")">
                    <i class="bi bi-check-circle me-1"></i> Finalizate
                </a>
            </div>
        </div>
        <div class="col-md-auto">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-search"></i>
            </button>
        </div>
        @if (!string.IsNullOrEmpty(search) || filter != "all")
        {
            <div class="col-md-auto">
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-x"></i> Șterge Filtrele
                </a>
            </div>
        }
    </form>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-journal-x fs-1 d-block mb-2 opacity-25"></i>
        Niciun curs găsit.
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var course in Model)
        {
            var isCourseCompleted = completedCourseIds.Contains(course.Id);
            var totalChapters = course.Chapters?.Count ?? 0;
            var completedCount = course.Chapters?
            .Count(ch => completedChapterIds.Contains(ch.Id)) ?? 0;
            var progressPct = totalChapters > 0
            ? (int)Math.Round((double)completedCount / totalChapters * 100)
            : 0;
            var isNotStarted = completedCount == 0 && !isCourseCompleted;
            var isInProgress = completedCount > 0 && !isCourseCompleted;

            <div class="col-md-4">
                <div class="card shadow-sm border-0 h-100 course-card">
                    <div class="card-body p-4 d-flex flex-column">

                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="badge bg-secondary bg-opacity-10 text-secondary">
                                <i class="bi bi-journals me-1"></i> @totalChapters capitole
                            </span>
                            @if (isCourseCompleted)
                            {
                                <span class="badge bg-success">
                                    <i class="bi bi-trophy-fill me-1"></i> Finalizat
                                </span>
                            }
                            else if (isInProgress)
                            {
                                <span class="badge bg-primary bg-opacity-10 text-primary">
                                    <i class="bi bi-hourglass-split me-1"></i> În Progres
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary bg-opacity-10 text-secondary">
                                    <i class="bi bi-circle me-1"></i> Neînceput
                                </span>
                            }
                        </div>

                        <h5 class="fw-semibold mt-2">@course.Title</h5>
                        <p class="text-muted small flex-grow-1">@course.Description</p>

                        @if (totalChapters > 0)
                        {
                            <div class="mb-3">
                                <div class="d-flex justify-content-between mb-1">
                                    <small class="text-muted">Progres</small>
                                    <small class="text-muted">@completedCount / @totalChapters</small>
                                </div>
                                <div class="progress" style="height: 6px;">
                                    <div class="progress-bar @(isCourseCompleted ? "bg-success" : "")"
                                         role="progressbar"
                                         style="width: @progressPct%">
                                    </div>
                                </div>
                            </div>
                        }

                        <a asp-action="Details"
                           asp-route-id="@course.Id"
                           class="btn @(isCourseCompleted ? "btn-outline-success" : isInProgress ? "btn-primary" : "btn-outline-primary") btn-sm mt-auto">
                            @if (isCourseCompleted)
                            {
                                <i class="bi bi-check-circle me-1"></i>
                                <text>Revizuiește Cursul</text>
                            }
                            else if (isInProgress)
                            {
                                <i class="bi bi-play-circle me-1"></i>
                                <text>Continuă</text>
                            }
                            else
                            {
                                <i class="bi bi-play-circle me-1"></i>
                                <text>Începe Cursul</text>
                            }
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}

<style>
    .course-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        border-radius: 0.75rem;
    }

        .course-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 0.75rem 1.5rem rgba(0,0,0,0.1) !important;
        }
</style>

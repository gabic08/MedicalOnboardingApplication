@model MedicalOnboardingApplication.Models.Course

@{
    ViewData["Title"] = Model.Title;
    bool isAdmin = User.IsInRole("Admin");
    string backUrlCourses = isAdmin
        ? Url.Action("Index", "AdminCourses")
        : Url.Action("Index", "Courses");

    string backUrlDashboard = isAdmin
        ? Url.Action("Index", "Admin")
        : Url.Action("Index", "Dashoard");

    var completedIds = ViewBag.CompletedChapterIds as List<int> ?? new List<int>();
    var totalChapters = Model.Chapters?.Count ?? 0;
    var completedCount = !isAdmin ? completedIds.Count : 0;
    var isCourseCompleted = !isAdmin && totalChapters > 0 && completedCount == totalChapters;
    var progressPct = totalChapters > 0 ? completedCount * 100 / totalChapters : 0;

    var coursesController = isAdmin ? "AdminCourses" : "Courses";
}

<!-- Page Header -->
<div class="rm-page-header">
    <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
        <div>
            <div class="breadcrumb-label">
                <a href="@backUrlDashboard" class="text-decoration-none" style="color:inherit;">
                    @(isAdmin ? "Panou Admin" : "Panou")
                </a>
                <i class="bi bi-chevron-right mx-1" style="font-size:0.65rem;"></i>
                <a href="@backUrlCourses" class="text-decoration-none" style="color:inherit;">
                    @(isAdmin ? "Cursuri Admin" : "Cursuri")
                </a>
                <i class="bi bi-chevron-right mx-1" style="font-size:0.65rem;"></i>
                Detalii Curs
            </div>

            <a asp-controller="@coursesController"
                   asp-action="Index"
                   class="btn btn-outline-secondary btn-rm-back mb-2"
                   style="color:var(--rm-red);border-color:var(--rm-red);">
                <i class="bi bi-arrow-left"></i> Înapoi la Cursuri
            </a>


            <h1>@Model.Title</h1>
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <p>@Model.Description</p>
            }
        </div>
        @if (!isAdmin && isCourseCompleted)
        {
            <span class="rm-status-badge rm-status-green align-self-end" style="font-size:0.85rem;padding:8px 16px;">
                <i class="bi bi-trophy-fill"></i> Curs Finalizat!
            </span>
        }
    </div>
</div>

<!-- Progress (employees only) -->
@if (!isAdmin && totalChapters > 0)
{
    <div class="rm-form-card mb-4">
        <div class="rm-form-card-body">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
                <span style="font-weight:600;font-size:0.9rem;">Progresul Tău</span>
                <span style="font-size:0.82rem;color:var(--rm-text-muted);">
                    @completedCount / @totalChapters capitole finalizate
                </span>
            </div>
            <div class="rm-progress-bar" style="height:8px;">
                <div class="rm-progress-fill @(isCourseCompleted ? "rm-progress-green" : "rm-progress-blue")"
                     style="width:@progressPct%;"></div>
            </div>
        </div>
    </div>
}

<!-- Chapters List -->
@if (Model.Chapters == null || !Model.Chapters.Any())
{
    <div class="rm-form-card">
        <div class="rm-form-card-body">
            <div class="rm-empty-state">
                <i class="bi bi-journal-x"></i>
                <p>Niciun capitol disponibil.</p>
            </div>
        </div>
    </div>
}
else
{
    <div class="rm-form-card">
        <div class="rm-form-card-header" style="justify-content:space-between;">
            <div style="display:flex;align-items:center;gap:8px;">
                <i class="bi bi-journals" style="color:var(--rm-red);"></i>
                Capitole
                <span class="rm-count-badge" style="background:#f0f0f0;color:#666;">@totalChapters</span>
            </div>
        </div>
        <div style="display:flex;flex-direction:column;">
            @foreach (var chapter in Model.Chapters.OrderBy(c => c.Order))
            {
                var chCompleted = !isAdmin && completedIds.Contains(chapter.Id);

                <a asp-controller="Chapters"
                       asp-action="Details"
                       asp-route-id="@chapter.Id"
                       class="rm-chapter-row @(chCompleted ? "rm-chapter-row--done" : "")">

                    <div class="rm-chapter-row-dot">
                        @if (chCompleted)
                        {
                            <i class="bi bi-check-lg"></i>
                        }
                        else
                        {
                            <span>@chapter.Order</span>
                        }
                    </div>

                    <div style="flex:1;min-width:0;">
                        <div style="font-weight:600;font-size:0.9rem;color:var(--rm-text);">@chapter.Title</div>
                        @if (chCompleted)
                        {
                            <div style="font-size:0.75rem;color:#16a34a;margin-top:2px;">
                                <i class="bi bi-check-circle-fill me-1"></i>Finalizat
                            </div>
                        }
                    </div>

                    <i class="bi bi-chevron-right" style="color:#ccc;font-size:0.85rem;flex-shrink:0;transition:transform 0.2s;"></i>
                </a>
            }
        </div>
    </div>
}
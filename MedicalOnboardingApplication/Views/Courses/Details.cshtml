@model MedicalOnboardingApplication.Models.Course

@{
    ViewData["Title"] = "Course Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">@Model.Title</h1>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary me-2">
            <i class="bi bi-pencil-square"></i> Edit Course
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Courses
        </a>
    </div>
</div>

<!-- Course Info Card -->
<div class="card mb-4 shadow-sm">
    <div class="card-body">
        <p><strong>Description:</strong></p>
        <p>@Model.Description</p>
        <p><strong>Order:</strong> @Model.Order</p>
    </div>
</div>

<!-- Chapters Section -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>Chapters (@(Model.Chapters != null ? Model.Chapters.Count : 0))</h4>
    <a asp-controller="Chapters"
       asp-action="Create"
       asp-route-courseId="@Model.Id"
       class="btn btn-primary btn-sm">
        <i class="bi bi-plus-circle"></i> Add Chapter
    </a>
</div>

@if (Model.Chapters != null && Model.Chapters.Any())
{
    @foreach (var chapter in Model.Chapters.OrderBy(c => c.Order).Take(3))
    {
        <div class="card mb-2 shadow-sm">
            <div class="card-body d-flex justify-content-between align-items-center">
                <span>@chapter.Order. @chapter.Title</span>
                <div>
                    <a asp-controller="Chapters"
                       asp-action="Edit"
                       asp-route-id="@chapter.Id"
                       class="btn btn-sm btn-outline-secondary me-1">
                        Edit
                    </a>
                    <a asp-controller="Chapters"
                       asp-action="Delete"
                       asp-route-id="@chapter.Id"
                       class="btn btn-sm btn-outline-danger">
                        Delete
                    </a>
                </div>
            </div>
        </div>
    }

    <!-- View All button below previews -->
    <a asp-controller="Chapters"
       asp-action="Index"
       asp-route-courseId="@Model.Id"
       class="btn btn-outline-secondary btn-sm mt-2">
        View All Chapters
    </a>
}
else
{
    <div class="alert alert-info">No chapters added yet.</div>
}

<!-- Tests Section -->
<div class="d-flex justify-content-between align-items-center mt-4 mb-3">
    <h4>Tests (@(Model.Tests != null ? Model.Tests.Count : 0))</h4>
    <a asp-controller="Tests"
       asp-action="Create"
       asp-route-courseId="@Model.Id"
       class="btn btn-primary btn-sm">
        <i class="bi bi-plus-circle"></i> Add Test
    </a>
</div>

@if (Model.Tests != null && Model.Tests.Any())
{
    @foreach (var test in Model.Tests.Take(3))
    {
        <div class="card mb-2 shadow-sm">
            <div class="card-body d-flex justify-content-between align-items-center">
                <span>@test.Title</span>
                <a asp-controller="Tests"
                   asp-action="Details"
                   asp-route-id="@test.Id"
                   class="btn btn-sm btn-outline-primary">
                    Manage
                </a>
            </div>
        </div>
    }

    <!-- View All button below previews -->
    <a asp-controller="Tests"
       asp-action="Index"
       asp-route-courseId="@Model.Id"
       class="btn btn-outline-secondary btn-sm mt-2">
        View All Tests
    </a>
}
else
{
    <div class="alert alert-info">No tests added yet.</div>
}
